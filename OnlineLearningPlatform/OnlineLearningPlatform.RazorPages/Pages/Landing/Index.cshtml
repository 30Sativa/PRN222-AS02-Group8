@page
@model OnlineLearningPlatform.RazorPages.Pages.Landing.IndexModel
@{
    ViewData["Title"] = "EduLearn — Nền tảng học trực tuyến";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <meta name="description" content="EduLearn — Học hỏi không giới hạn với hàng ngàn khóa học chất lượng từ các chuyên gia hàng đầu." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #f8f9fc;
            color: #1c1d1f;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
        }
        img { max-width: 100%; display: block; }
        a { text-decoration: none; }

        .lp-container { max-width: 1160px; margin: 0 auto; padding: 0 24px; }

        /* NAV */
        .lp-nav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
            height: 60px;
            background: rgba(255,255,255,.82);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border-bottom: 1px solid rgba(0,0,0,.06);
        }
        .lp-nav-inner {
            height: 100%; display: flex; align-items: center;
            justify-content: space-between; gap: 24px;
        }
        .lp-brand {
            display: flex; align-items: center; gap: 10px;
            font-size: 17px; font-weight: 800; letter-spacing: -.03em;
            color: #1c1d1f !important; text-decoration: none;
        }
        .lp-brand-mark {
            width: 34px; height: 34px; border-radius: 10px;
            background: linear-gradient(135deg, #5624d0, #a435f0);
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 4px 14px rgba(164,53,240,.3);
            flex-shrink: 0;
        }
        .lp-brand-mark svg { width: 18px; height: 18px; color: #fff; }
        .lp-nav-actions { display: flex; align-items: center; gap: 8px; }
        .lp-btn-login {
            font-size: 13.5px; font-weight: 600; color: #1c1d1f !important;
            padding: 8px 18px; border-radius: 9999px;
            border: 1.5px solid rgba(0,0,0,.14);
            background: transparent; text-decoration: none;
            transition: background .2s, border-color .2s;
        }
        .lp-btn-login:hover { background: rgba(0,0,0,.05); opacity: 1 !important; }
        .lp-btn-register {
            font-size: 13.5px; font-weight: 700; color: #fff !important;
            padding: 8px 20px; border-radius: 9999px;
            background: linear-gradient(135deg, #5624d0, #a435f0);
            text-decoration: none;
            box-shadow: 0 3px 12px rgba(164,53,240,.28);
            transition: opacity .2s, transform .2s;
        }
        .lp-btn-register:hover { opacity: .88; transform: translateY(-1px); }

        /* HERO */
        .hero {
            position: relative; padding: 160px 0 96px;
            text-align: center; overflow: hidden;
            background: radial-gradient(ellipse 90% 70% at 50% -10%, rgba(86,36,208,.09) 0%, transparent 65%),
                        radial-gradient(ellipse 60% 40% at 80% 60%, rgba(164,53,240,.05) 0%, transparent 60%);
        }
        .hero-particles { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
        .hero-particle {
            position: absolute; border-radius: 50%;
            background: rgba(86,36,208,.08);
            animation: particleFloat linear infinite;
        }
        @@keyframes particleFloat {
            0%   { transform: translateY(0) scale(1) rotate(0deg); opacity: .6; }
            50%  { transform: translateY(-40px) scale(1.08) rotate(180deg); opacity: 1; }
            100% { transform: translateY(0) scale(1) rotate(360deg); opacity: .6; }
        }
        .hero-badge {
            display: inline-flex; align-items: center; gap: 7px;
            font-size: 11.5px; font-weight: 700; letter-spacing: .06em;
            text-transform: uppercase; color: #5624d0;
            background: rgba(86,36,208,.09);
            padding: 5px 14px 5px 8px; border-radius: 9999px;
            margin-bottom: 28px; border: 1px solid rgba(86,36,208,.14);
            animation: fadeDown .6s ease both;
        }
        @@keyframes fadeDown {
            from { opacity: 0; transform: translateY(-14px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .hero-badge svg { width: 13px; height: 13px; }
        .hero h1 {
            font-size: clamp(2.8rem, 6.5vw, 4.6rem); font-weight: 800;
            letter-spacing: -.055em; line-height: 1.04;
            color: #1c1d1f; margin-bottom: 22px;
            max-width: 660px; margin-inline: auto;
            animation: fadeUp .7s .15s ease both;
        }
        .hero h1 .accent {
            background: linear-gradient(135deg, #5624d0, #a435f0);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .hero-sub {
            font-size: clamp(1.05rem, 2vw, 1.2rem); color: #6e6e73; font-weight: 400;
            max-width: 500px; margin: 0 auto 40px; line-height: 1.6;
            animation: fadeUp .7s .28s ease both;
        }
        .hero-actions {
            display: flex; align-items: center; justify-content: center;
            gap: 12px; flex-wrap: wrap;
            animation: fadeUp .7s .40s ease both;
        }
        .hero-btn-primary {
            font-size: 15px; font-weight: 700; color: #fff !important;
            padding: 14px 30px; border-radius: 9999px;
            background: linear-gradient(135deg, #5624d0, #a435f0);
            text-decoration: none;
            box-shadow: 0 4px 18px rgba(164,53,240,.32);
            transition: opacity .2s, transform .2s, box-shadow .2s;
        }
        .hero-btn-primary:hover {
            opacity: .88; transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(164,53,240,.38);
        }
        .hero-btn-secondary {
            font-size: 15px; font-weight: 500; color: #1c1d1f !important;
            padding: 14px 30px; border-radius: 9999px;
            border: 1.5px solid rgba(0,0,0,.14); background: transparent;
            text-decoration: none; transition: background .2s;
        }
        .hero-btn-secondary:hover { background: rgba(0,0,0,.05); opacity: 1 !important; }
        .stats-row {
            display: flex; justify-content: center; gap: clamp(28px, 6vw, 64px); flex-wrap: wrap;
            margin-top: 72px; padding-top: 40px;
            border-top: 1px solid rgba(0,0,0,.07);
            animation: fadeUp .7s .52s ease both;
        }
        .stat-item { text-align: center; min-width: 80px; }
        .stat-num {
            font-size: clamp(1.8rem, 3.5vw, 2.4rem); font-weight: 800;
            letter-spacing: -.04em; color: #1c1d1f; line-height: 1.1;
        }
        .stat-num .accent { color: #a435f0; }
        .stat-label { font-size: 12.5px; color: #86868b; margin-top: 4px; font-weight: 500; }

        /* FEATURES */
        .features-section { padding: 80px 0 72px; }
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
        }
        .feature-card {
            background: #fff; border-radius: 18px; padding: 28px 24px;
            border: 1px solid rgba(0,0,0,.06);
            box-shadow: 0 2px 12px rgba(0,0,0,.04);
            transition: box-shadow .3s, transform .3s;
            opacity: 0; transform: translateY(24px);
        }
        .feature-card.visible { animation: fadeUp .5s ease forwards; }
        .feature-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,.08); transform: translateY(-3px); }
        .feature-icon {
            width: 48px; height: 48px; border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 16px;
        }
        .feature-icon svg { width: 22px; height: 22px; }
        .fi-purple { background: rgba(86,36,208,.09); }
        .fi-purple svg { color: #5624d0; }
        .fi-blue   { background: rgba(0,113,227,.09); }
        .fi-blue svg { color: #0071e3; }
        .fi-green  { background: rgba(21,115,71,.09); }
        .fi-green svg { color: #157347; }
        .fi-amber  { background: rgba(146,97,10,.09); }
        .fi-amber svg { color: #92610a; }
        .feature-card h3 {
            font-size: 15px; font-weight: 700; color: #1c1d1f;
            margin-bottom: 8px; letter-spacing: -.01em;
        }
        .feature-card p { font-size: 13px; color: #6e6e73; line-height: 1.6; }

        /* COURSES */
        .courses-section { padding: 0 0 80px; }
        .courses-section-head {
            display: flex; align-items: flex-end; justify-content: space-between;
            gap: 16px; flex-wrap: wrap; margin-bottom: 28px;
        }
        .courses-section-head h2 {
            font-size: clamp(1.3rem, 2.5vw, 1.55rem); font-weight: 800;
            letter-spacing: -.03em; color: #1c1d1f;
        }
        .courses-section-head p { font-size: 13.5px; color: #86868b; margin-top: 4px; }
        .courses-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(265px, 1fr));
            gap: 20px;
        }
        .lp-card {
            background: #fff; border-radius: 20px;
            border: 1px solid rgba(0,0,0,.07);
            overflow: hidden; display: flex; flex-direction: column;
            text-decoration: none !important; color: inherit !important;
            transition: box-shadow .35s cubic-bezier(.16,1,.3,1), transform .35s cubic-bezier(.16,1,.3,1);
            cursor: pointer;
            opacity: 0; transform: translateY(28px);
        }
        .lp-card.visible { animation: cardReveal .55s cubic-bezier(.16,1,.3,1) forwards; }
        @@keyframes cardReveal {
            from { opacity: 0; transform: translateY(28px) scale(.97); }
            to   { opacity: 1; transform: translateY(0) scale(1); }
        }
        .lp-card:hover {
            box-shadow: 0 16px 48px rgba(0,0,0,.11);
            transform: translateY(-5px);
        }
        .lp-card-thumb {
            position: relative; padding-top: 56.25%;
            overflow: hidden; background: #f2f2f7; flex-shrink: 0;
        }
        .lp-card-thumb img {
            position: absolute; inset: 0; width: 100%; height: 100%;
            object-fit: cover; transition: transform .5s ease;
        }
        .lp-card:hover .lp-card-thumb img { transform: scale(1.06); }
        .lp-card-thumb-placeholder {
            position: absolute; inset: 0;
            background: linear-gradient(135deg, #e8f0fb 0%, #f0eeff 100%);
            display: flex; align-items: center; justify-content: center;
        }
        .lp-card-thumb-placeholder svg { width: 36px; height: 36px; color: #5624d0; opacity: .4; }
        .lp-badge-tag {
            position: absolute; top: 10px; right: 10px;
            font-size: 10.5px; font-weight: 800; padding: 4px 10px;
            border-radius: 9999px; backdrop-filter: blur(12px);
            letter-spacing: .02em;
        }
        .tag-free  { background: rgba(52,199,89,.18); color: #157347; border: 1px solid rgba(52,199,89,.28); }
        .tag-sale  { background: rgba(255,59,48,.12); color: #c0392b; border: 1px solid rgba(255,59,48,.2); }
        .tag-paid  { background: rgba(255,255,255,.88); color: #1c1d1f; border: 1px solid rgba(0,0,0,.1); }
        .lp-card-body { padding: 16px; flex: 1; display: flex; flex-direction: column; }
        .lp-card-cat {
            font-size: 10px; font-weight: 800; letter-spacing: .07em;
            text-transform: uppercase; color: #5624d0; margin-bottom: 7px;
        }
        .lp-card-title {
            font-size: 14.5px; font-weight: 700; color: #1c1d1f;
            line-height: 1.38; margin-bottom: 5px;
            display: -webkit-box; -webkit-line-clamp: 2;
            -webkit-box-orient: vertical; overflow: hidden;
        }
        .lp-card-teacher { font-size: 12px; color: #86868b; margin-bottom: 12px; flex: 1; }
        .lp-card-footer {
            display: flex; align-items: center; justify-content: space-between;
            gap: 8px; padding-top: 12px;
            border-top: 1px solid rgba(0,0,0,.06);
        }
        .lp-price { font-size: 14px; font-weight: 800; color: #1c1d1f; }
        .lp-price-free { color: #157347; }
        .lp-price-old { font-size: 11px; font-weight: 400; color: #aeaeb2; text-decoration: line-through; margin-left: 4px; }
        .lp-stars { display: flex; align-items: center; gap: 3px; }
        .lp-star { color: #ffc400; font-size: 11px; }
        .lp-star-empty { color: #d2d2d7; font-size: 11px; }
        .lp-rating-count { font-size: 11px; color: #86868b; margin-left: 3px; }
        .lp-empty { text-align: center; padding: 72px 0; }
        .lp-empty svg { width: 52px; height: 52px; color: #d2d2d7; margin: 0 auto 16px; }
        .lp-empty h3 { font-size: 17px; font-weight: 700; color: #1c1d1f; margin-bottom: 6px; }
        .lp-empty p { font-size: 14px; color: #86868b; }

        /* SEARCH */
        .search-section { padding: 0 0 40px; }
        .lp-search-wrap { position: relative; max-width: 540px; margin: 0 auto; }
        .lp-search-icon {
            position: absolute; left: 18px; top: 50%;
            transform: translateY(-50%); color: #aeaeb2; pointer-events: none;
        }
        .lp-search-icon svg { width: 16px; height: 16px; }
        .lp-search-input {
            width: 100%; padding: 14px 56px 14px 48px;
            font-family: inherit; font-size: 15px; color: #1c1d1f;
            background: #fff; border: 1.5px solid rgba(0,0,0,.1);
            border-radius: 9999px; outline: none;
            box-shadow: 0 3px 16px rgba(0,0,0,.05);
            transition: border-color .2s, box-shadow .2s;
        }
        .lp-search-input:focus {
            border-color: #5624d0;
            box-shadow: 0 0 0 4px rgba(86,36,208,.1), 0 3px 16px rgba(0,0,0,.06);
        }
        .lp-search-input::placeholder { color: #aeaeb2; }
        .lp-search-btn {
            position: absolute; right: 6px; top: 50%;
            transform: translateY(-50%);
            font-family: inherit; font-size: 13px; font-weight: 700;
            color: #fff; background: linear-gradient(135deg, #5624d0, #a435f0);
            border: none; padding: 9px 20px; border-radius: 9999px;
            cursor: pointer; box-shadow: 0 2px 10px rgba(164,53,240,.28);
            transition: opacity .2s;
        }
        .lp-search-btn:hover { opacity: .85; }

        /* TESTIMONIALS */
        .testimonials-section { padding: 0 0 80px; }
        .testimonials-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 20px;
        }
        .testi-card {
            background: #fff; border-radius: 18px; padding: 24px;
            border: 1px solid rgba(0,0,0,.07);
            box-shadow: 0 2px 10px rgba(0,0,0,.04);
            opacity: 0; transform: translateY(20px);
        }
        .testi-card.visible { animation: fadeUp .5s ease forwards; }
        .testi-stars { display: flex; gap: 2px; margin-bottom: 14px; }
        .testi-star { color: #ffc400; font-size: 14px; }
        .testi-quote {
            font-size: 14px; color: #1c1d1f; line-height: 1.65;
            margin-bottom: 18px; font-style: italic;
        }
        .testi-author { display: flex; align-items: center; gap: 10px; }
        .testi-av {
            width: 36px; height: 36px; border-radius: 50%;
            background: linear-gradient(135deg, #5624d0, #a435f0);
            color: #fff; font-size: 13px; font-weight: 800;
            display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        }
        .testi-name { font-size: 13px; font-weight: 700; color: #1c1d1f; }
        .testi-role { font-size: 11.5px; color: #86868b; }

        /* CTA */
        .cta-section {
            background: linear-gradient(135deg, #5624d0 0%, #a435f0 100%);
            border-radius: 28px; padding: clamp(40px, 6vw, 72px) clamp(24px, 5vw, 56px);
            text-align: center; margin-bottom: 80px;
            position: relative; overflow: hidden;
            box-shadow: 0 12px 48px rgba(86,36,208,.22);
        }
        .cta-section::before {
            content: ""; position: absolute; width: 300px; height: 300px;
            border-radius: 50%; background: rgba(255,255,255,.06);
            top: -120px; right: -60px;
        }
        .cta-section::after {
            content: ""; position: absolute; width: 180px; height: 180px;
            border-radius: 50%; background: rgba(255,255,255,.04);
            bottom: -80px; left: 8%;
        }
        .cta-inner { position: relative; z-index: 1; }
        .cta-section h2 {
            font-size: clamp(1.7rem, 4vw, 2.6rem); font-weight: 800;
            letter-spacing: -.04em; color: #fff; margin-bottom: 12px;
        }
        .cta-section p {
            font-size: clamp(1rem, 1.8vw, 1.15rem); color: rgba(255,255,255,.8); margin-bottom: 36px;
        }
        .cta-row { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; }
        .cta-btn-white {
            font-size: 15px; font-weight: 700; color: #5624d0 !important;
            padding: 13px 28px; border-radius: 9999px;
            background: #fff; text-decoration: none;
            box-shadow: 0 4px 16px rgba(0,0,0,.12);
            transition: transform .2s, box-shadow .2s;
        }
        .cta-btn-white:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,.18); }
        .cta-btn-outline {
            font-size: 15px; font-weight: 600; color: rgba(255,255,255,.9) !important;
            padding: 13px 28px; border-radius: 9999px;
            border: 1.5px solid rgba(255,255,255,.4); background: transparent;
            text-decoration: none; transition: background .2s;
        }
        .cta-btn-outline:hover { background: rgba(255,255,255,.12); opacity: 1 !important; }

        /* FOOTER */
        .lp-footer { border-top: 1px solid rgba(0,0,0,.07); padding: 32px 0; text-align: center; }
        .lp-footer p { font-size: 13px; color: #aeaeb2; }
        .lp-footer a { color: #86868b; text-decoration: none; }
        .lp-footer a:hover { color: #1c1d1f; }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(22px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        @@media (max-width: 640px) {
            .hero { padding: 120px 0 60px; }
            .courses-grid { grid-template-columns: 1fr; }
            .stats-row { gap: 20px; }
        }
    </style>
</head>
<body>

<!-- NAV -->
<nav class="lp-nav">
    <div class="lp-container lp-nav-inner">
        <a href="/" class="lp-brand">
            <div class="lp-brand-mark">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                </svg>
            </div>
            EduLearn
        </a>
        <div class="lp-nav-actions">
            <a href="/Auth/Login" class="lp-btn-login">Đăng nhập</a>
            <a href="/Auth/Register" class="lp-btn-register">Đăng ký miễn phí</a>
        </div>
    </div>
</nav>

<!-- HERO -->
<section class="hero">
    <div class="hero-particles" id="heroParticles"></div>
    <div class="lp-container">
        <div class="hero-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
            Nền tảng học trực tuyến hàng đầu Việt Nam
        </div>
        <h1>Học mọi thứ.<br /><span class="accent">Không giới hạn.</span></h1>
        <p class="hero-sub">Hàng ngàn khóa học chất lượng từ các chuyên gia hàng đầu. Học theo tốc độ của bạn, ở bất cứ đâu.</p>
        <div class="hero-actions">
            <a href="/Auth/Register" class="hero-btn-primary">Bắt đầu học ngay</a>
            <a href="#courses" class="hero-btn-secondary">Khám phá khóa học</a>
        </div>

        <div class="stats-row">
            <div class="stat-item">
                <div class="stat-num">@(Model.TotalCount)<span class="accent">+</span></div>
                <div class="stat-label">Khóa học</div>
            </div>
            <div class="stat-item">
                <div class="stat-num">10<span class="accent">K+</span></div>
                <div class="stat-label">Học viên</div>
            </div>
            <div class="stat-item">
                <div class="stat-num">200<span class="accent">+</span></div>
                <div class="stat-label">Giảng viên</div>
            </div>
            <div class="stat-item">
                <div class="stat-num">4.8<span class="accent">&#9733;</span></div>
                <div class="stat-label">Đánh giá TB</div>
            </div>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section class="features-section">
    <div class="lp-container">
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon fi-purple">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                </div>
                <h3>Học mọi lúc, mọi nơi</h3>
                <p>Truy cập khóa học trên mọi thiết bị &mdash; máy tính, máy tính bảng và điện thoại thông minh.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon fi-blue">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>
