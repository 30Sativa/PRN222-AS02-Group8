<!-- COURSES -->
<section class="courses-section" id="courses">
    <div class="lp-container">
        <div class="search-section">
            <div class="lp-search-wrap">
                <form method="get">
                    <span class="lp-search-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    </span>
                    <input type="text" name="keyword" value="@Model.SearchKeyword"
                           class="lp-search-input" placeholder="Tìm kiếm khóa học&hellip;" autocomplete="off" />
                    <button type="submit" class="lp-search-btn">Tìm</button>
                </form>
            </div>
        </div>

        <div class="courses-section-head">
            <div>
                <h2>@(string.IsNullOrEmpty(Model.SearchKeyword) ? "Tất cả khóa học" : $"Kết quả cho \"{Model.SearchKeyword}\"")</h2>
                <p>@Model.TotalCount khóa học</p>
            </div>
        </div>

        @if (!Model.Courses.Any())
        {
            <div class="lp-empty">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <h3>Không tìm thấy khóa học</h3>
                <p>Thử từ khóa khác hoặc <a href="/Landing">xem tất cả</a></p>
            </div>
        }
        else
        {
            <div class="courses-grid">
                @{ int cardIdx = 0; }
                @foreach (var course in Model.Courses)
                {
                    cardIdx++;
                    var delay = Math.Min((cardIdx - 1) * .07, .5);
                    var ratings = Model.CourseRatings.ContainsKey(course.CourseId) ? Model.CourseRatings[course.CourseId] : (0.0, 0);
                    <div class="lp-card scroll-reveal" data-delay="@delay">
                        <div class="lp-card-thumb">
                            @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                            {
                                <img src="@course.ThumbnailUrl" alt="@course.Title" loading="lazy" />
                            }
                            else
                            {
                                <div class="lp-card-thumb-placeholder">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
                                    </svg>
                                </div>
                            }
                            @if (course.Price == 0)
                            {
                                <span class="lp-badge-tag tag-free">Miễn phí</span>
                            }
                            else if (course.DiscountPrice.HasValue && course.DiscountPrice < course.Price)
                            {
                                <span class="lp-badge-tag tag-sale">Sale</span>
                            }
                            else
                            {
                                <span class="lp-badge-tag tag-paid">@course.Price.ToString("N0")₫</span>
                            }
                        </div>
                        <div class="lp-card-body">
                            @if (!string.IsNullOrEmpty(course.CategoryName))
                            {
                                <div class="lp-card-cat">@course.CategoryName</div>
                            }
                            <div class="lp-card-title">@course.Title</div>
                            <div class="lp-card-teacher">@course.TeacherName</div>
                            <div class="lp-card-footer">
                                <div>
                                    @if (course.Price == 0)
                                    {
                                        <span class="lp-price lp-price-free">Miễn phí</span>
                                    }
                                    else if (course.DiscountPrice.HasValue && course.DiscountPrice < course.Price)
                                    {
                                        <span class="lp-price">@course.DiscountPrice.Value.ToString("N0")₫</span>
                                        <span class="lp-price-old">@course.Price.ToString("N0")₫</span>
                                    }
                                    else
                                    {
                                        <span class="lp-price">@course.Price.ToString("N0")₫</span>
                                    }
                                </div>
                                @if (ratings.Item2 > 0)
                                {
                                    <div class="lp-stars">
                                        @{
                                            int full = (int)Math.Round(ratings.Item1);
                                            for (int s = 1; s <= 5; s++)
                                            {
                                                <span class="@(s <= full ? "lp-star" : "lp-star-empty")">&#9733;</span>
                                            }
                                        }
                                        <span class="lp-rating-count">(@ratings.Item2)</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

