@page
@model OnlineLearningPlatform.RazorPages.Areas.Admin.Pages.Courses.IndexModel
@using OnlineLearningPlatform.Models.Entities
@{
    ViewData["Title"] = "Duyệt khóa học";
}

<style>
    .status-pill {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 3px 10px; border-radius: 20px;
        font-size: 12px; font-weight: 600; white-space: nowrap;
    }
    .status-pending  { background: var(--color-amber-tint, #fff8e1); color: #b45309; }
    .status-published { background: var(--color-green-tint, #e8f5e9); color: #166534; }
    .status-rejected { background: var(--color-red-tint, #fff0f0);   color: #991b1b; }
    .status-draft    { background: var(--color-surface-2, #f0f0f5);  color: #6e6e73; }

    .status-dot {
        width: 6px; height: 6px; border-radius: 50%; display: inline-block;
    }
    .status-pending  .status-dot  { background: #d97706; }
    .status-published .status-dot { background: #16a34a; }
    .status-rejected .status-dot  { background: #dc2626; }
    .status-draft    .status-dot  { background: #9ca3af; }

    .course-code {
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-size: 12px; font-weight: 600;
        color: var(--color-label-2, #6e6e73);
        background: var(--color-surface-2, #f5f5f7);
        padding: 2px 7px; border-radius: 6px;
    }

    .teacher-cell {
        display: flex; align-items: center; gap: 8px;
    }
    .teacher-avatar {
        width: 28px; height: 28px; border-radius: 50%;
        background: var(--color-blue-tint, #e0f0ff);
        color: var(--color-blue, #0071e3);
        display: flex; align-items: center; justify-content: center;
        font-size: 11px; font-weight: 700; flex-shrink: 0;
    }
</style>

@* ── PAGE HEADER ── *@
<div class="page-head fade-up">
    <h1>Duyệt khóa học</h1>
    <div class="breadcrumb">
        <a asp-area="Admin" asp-page="/Dashboard">Dashboard</a>
        <span class="breadcrumb-sep">/</span>
        <span>Danh sách</span>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success fade-up">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger fade-up">@errorMessage</div>
}

<div class="card fade-up">
    <!-- Filter bar -->
    <form method="get" class="filter-bar">
        <div class="search-input-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" name="SearchTitle" value="@Model.SearchTitle" placeholder="Tìm tên khóa học..." />
        </div>

        <div class="search-input-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
            </svg>
            <input type="text" name="SearchTeacherName" value="@Model.SearchTeacherName" placeholder="Tìm tên giảng viên..." />
        </div>

        <button type="submit" class="btn btn-primary btn-sm">Tìm kiếm</button>

        @if (!string.IsNullOrWhiteSpace(Model.SearchTitle) || !string.IsNullOrWhiteSpace(Model.SearchTeacherName))
        {
            <a asp-page="/Courses/Index" asp-area="Admin" class="btn btn-secondary btn-sm">Xóa bộ lọc</a>
        }
    </form>

    <!-- Result count header -->
    <div class="card-header" style="border-top: 1px solid var(--color-border-light);">
        <h2>@Model.Courses.Count khóa học</h2>
    </div>

    @if (Model.Courses.Count > 0)
    {
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th style="width: 110px;">Mã khóa học</th>
                        <th>Tên khóa học</th>
                        <th>Giảng viên</th>
                        <th>Trạng thái</th>
                        <th style="width: 100px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model.Courses)
                    {
                        var statusClass = course.Status switch
                        {
                            CourseStatus.Pending   => "status-pending",
                            CourseStatus.Published => "status-published",
                            CourseStatus.Rejected  => "status-rejected",
                            _                      => "status-draft"
                        };
                        var statusLabel = course.Status switch
                        {
                            CourseStatus.Pending   => "Chờ duyệt",
                            CourseStatus.Published => "Đã xuất bản",
                            CourseStatus.Rejected  => "Bị từ chối",
                            _                      => course.Status.ToString()
                        };
                        var teacherInitial = course.Teacher?.FullName?[0].ToString().ToUpper() ?? "?";
                        <tr id="admin-course-row-@course.CourseId">
                            <td><span class="course-code">@course.CourseCode</span></td>
                            <td class="fw-medium">@course.Title</td>
                            <td>
                                <div class="teacher-cell">
                                    <div class="teacher-avatar">@teacherInitial</div>
                                    <span>@(course.Teacher?.FullName ?? "—")</span>
                                </div>
                            </td>
                            <td id="admin-course-status-@course.CourseId">
                                <span class="status-pill @statusClass">
                                    <span class="status-dot"></span>
                                    @statusLabel
                                </span>
                            </td>
                            <td>
                                <a class="btn btn-secondary btn-sm"
                                   asp-area="Admin"
                                   asp-page="/Courses/Details"
                                   asp-route-id="@course.CourseId">Xem</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                 style="width:40px;height:40px;margin:0 auto 12px;display:block;color:var(--color-label-3)">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                <line x1="8" y1="21" x2="16" y2="21"/>
                <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
            <h3>Không tìm thấy khóa học</h3>
            <p>Thử tìm kiếm với từ khóa hoặc bộ lọc khác.</p>
        </div>
    }
</div>

@section Scripts {
<script src="~/lib/microsoft-signalr/signalr.min.js"></script>
<script>
(function () {
    // ==== SignalR: Admin Courses realtime ====
    const connection = new signalR.HubConnectionBuilder()
        .withUrl('/hubs/data')
        .withAutomaticReconnect()
        .build();

    function escHtml(str) {
        return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function showToast(msg, type) {
        const toast = document.createElement('div');
        toast.className = 'alert alert-' + (type || 'info');
        toast.style.cssText = 'position:fixed;bottom:20px;right:20px;z-index:9999;min-width:300px;animation:fadeUp .3s ease forwards;max-width:420px;';
        toast.innerHTML = msg;
        document.body.appendChild(toast);
        setTimeout(() => { toast.style.opacity = '0'; toast.style.transition = 'opacity .3s'; setTimeout(() => toast.remove(), 300); }, 4500);
    }

    // Khi Teacher tạo khóa học mới → thêm row vào bảng của Admin ngay
    connection.on('CourseCreated', function (data) {
        const tbody = document.querySelector('table tbody');
        if (!tbody) return;

        if (document.getElementById('admin-course-row-' + data.courseId)) return;

        const initial = (data.teacherName || '?')[0].toUpperCase();
        const tr = document.createElement('tr');
        tr.id = 'admin-course-row-' + data.courseId;
        tr.style.animation = 'fadeUp .4s ease';
        tr.innerHTML = `
            <td><span class="course-code">${escHtml(data.courseCode || '')}</span></td>
            <td class="fw-medium">${escHtml(data.title || '')}</td>
            <td>
                <div class="teacher-cell">
                    <div class="teacher-avatar">${escHtml(initial)}</div>
                    <span>${escHtml(data.teacherName || '—')}</span>
                </div>
            </td>
            <td id="admin-course-status-${data.courseId}">
                <span class="status-pill status-pending">
                    <span class="status-dot"></span>
                    Chờ duyệt
                </span>
            </td>
            <td>
                <a class="btn btn-secondary btn-sm" href="/Admin/Courses/Details?id=${data.courseId}">Xem</a>
            </td>`;
        tbody.insertBefore(tr, tbody.firstChild);

        // Cập nhật count
        const countEl = document.querySelector('.card-header h2');
        if (countEl) {
            const n = parseInt(countEl.textContent) + 1;
            countEl.textContent = n + ' khóa học';
        }

        showToast('📚 Khóa học mới: <strong>' + escHtml(data.title) + '</strong> đang chờ duyệt.', 'info');
    });

    // Khi Admin approve/reject → cập nhật status cell ngay
    connection.on('CourseStatusChanged', function (data) {
        const statusCell = document.getElementById('admin-course-status-' + data.courseId);
        if (!statusCell) return;

        const isPublished = data.status === 'Published';
        const isRejected  = data.status === 'Rejected';
        const cls   = isPublished ? 'status-published' : isRejected ? 'status-rejected' : 'status-pending';
        const label = isPublished ? 'Đã xuất bản'      : isRejected ? 'Bị từ chối'      : 'Chờ duyệt';

        statusCell.innerHTML = `<span class="status-pill ${cls}"><span class="status-dot"></span>${label}</span>`;

        const row = document.getElementById('admin-course-row-' + data.courseId);
        if (row) {
            row.style.transition = 'background .4s ease';
            row.style.background = isPublished ? 'rgba(52,199,89,.06)' : isRejected ? 'rgba(255,59,48,.05)' : '';
            setTimeout(() => { row.style.background = ''; }, 1500);
        }
    });

    // Khi Teacher xóa khóa học → xóa row khỏi bảng
    connection.on('CourseDeleted', function (data) {
        const row = document.getElementById('admin-course-row-' + data.courseId);
        if (!row) return;
        row.style.transition = 'opacity .35s ease, transform .35s ease';
        row.style.opacity = '0';
        row.style.transform = 'translateX(20px)';
        setTimeout(() => {
            row.remove();
            const countEl = document.querySelector('.card-header h2');
            if (countEl) {
                const n = parseInt(countEl.textContent) - 1;
                countEl.textContent = Math.max(0, n) + ' khóa học';
            }
        }, 350);
        showToast('🗑️ Một khóa học đã bị xóa.', 'warning');
    });

    connection.start().catch(err => console.warn('[SignalR DataHub] Admin Courses connect error:', err));
})();
</script>
}
