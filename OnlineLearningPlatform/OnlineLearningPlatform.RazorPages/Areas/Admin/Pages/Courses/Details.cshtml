@page "{id:guid}"
@model OnlineLearningPlatform.RazorPages.Areas.Admin.Pages.Courses.DetailsModel
@using OnlineLearningPlatform.Models.Entities
@{
    ViewData["Title"] = Model.Course is not null ? $"Chi tiết: {Model.Course.Title}" : "Chi tiết khóa học";
}

<style>
    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-4, 16px) var(--space-6, 24px);
    }
    @@media (max-width: 640px) {
        .detail-grid { grid-template-columns: 1fr; }
    }
    .detail-grid.full { grid-template-columns: 1fr; }

    .detail-item {}
    .detail-label {
        font-size: 11px; font-weight: 600;
        text-transform: uppercase; letter-spacing: .05em;
        color: var(--color-label-3, #aeaeb2);
        margin-bottom: 4px;
    }
    .detail-value {
        font-size: var(--text-sm, 14px);
        color: var(--color-label-1, #1d1d1f);
        font-weight: 500;
    }
    .detail-value.mono {
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-size: 13px;
        background: var(--color-surface-2, #f5f5f7);
        border-radius: 6px; padding: 2px 8px;
        display: inline-block;
    }
    .detail-box {
        background: var(--color-surface-2, #f5f5f7);
        border-radius: var(--radius-sm, 8px);
        padding: var(--space-4, 16px);
        font-size: var(--text-sm, 14px);
        color: var(--color-label-1, #1d1d1f);
        line-height: 1.65;
        white-space: pre-wrap;
        margin-top: 4px;
    }

    .status-pill {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 4px 12px; border-radius: 20px;
        font-size: 12px; font-weight: 600;
    }
    .status-dot { width: 6px; height: 6px; border-radius: 50%; display: inline-block; }
    .status-pending   { background: var(--color-amber-tint, #fff8e1); color: #b45309; }
    .status-pending   .status-dot { background: #d97706; }
    .status-published { background: var(--color-green-tint, #e8f5e9); color: #166534; }
    .status-published .status-dot { background: #16a34a; }
    .status-rejected  { background: var(--color-red-tint, #fff0f0);   color: #991b1b; }
    .status-rejected  .status-dot { background: #dc2626; }
    .status-draft     { background: var(--color-surface-2, #f0f0f5);  color: #6e6e73; }
    .status-draft     .status-dot { background: #9ca3af; }

    .review-section {
        background: var(--color-amber-tint, #fff8e1);
        border: 1px solid #f4c660;
        border-radius: var(--radius-lg, 12px);
        padding: var(--space-5, 20px) var(--space-6, 24px);
        margin-top: var(--space-4, 16px);
    }
    .review-section h3 {
        font-size: var(--text-sm, 14px);
        font-weight: 700;
        color: #7d5200;
        margin-bottom: var(--space-4, 16px);
        display: flex; align-items: center; gap: 8px;
    }
    .reject-box {
        background: var(--color-red-tint, #fff0f0);
        border: 1px solid #fca5a5;
        border-radius: var(--radius-sm, 8px);
        padding: var(--space-4, 16px);
        margin-top: 4px;
    }
</style>

@* ── PAGE HEADER ── *@
<div class="page-head fade-up">
    <h1>Chi tiết khóa học</h1>
    <div class="breadcrumb">
        <a asp-area="Admin" asp-page="/Dashboard">Dashboard</a>
        <span class="breadcrumb-sep">/</span>
        <a asp-area="Admin" asp-page="/Courses/Index">Duyệt khóa học</a>
        <span class="breadcrumb-sep">/</span>
        <span>Chi tiết</span>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success fade-up">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger fade-up">@errorMessage</div>
}

@if (Model.Course is null)
{
    <div class="card fade-up">
        <div class="empty-state">
            <h3>Không tìm thấy khóa học</h3>
            <p>Khóa học này không tồn tại hoặc đã bị xóa.</p>
        </div>
    </div>
}
else
{
    var statusClass = Model.Course.Status switch
    {
        CourseStatus.Pending   => "status-pending",
        CourseStatus.Published => "status-published",
        CourseStatus.Rejected  => "status-rejected",
        _                      => "status-draft"
    };
    var statusLabel = Model.Course.Status switch
    {
        CourseStatus.Pending   => "Chờ duyệt",
        CourseStatus.Published => "Đã xuất bản",
        CourseStatus.Rejected  => "Bị từ chối",
        _                      => Model.Course.Status.ToString()
    };

    <div class="card fade-up">
        <div class="card-header">
            <h2>@Model.Course.Title</h2>
            <div>
                <span class="status-pill @statusClass">
                    <span class="status-dot"></span>
                    @statusLabel
                </span>
            </div>
        </div>

        <div class="card-body" style="padding: var(--space-5) var(--space-6);">

            <!-- Thông tin chính -->
            <div class="detail-grid">
                <div class="detail-item">
                    <div class="detail-label">Mã khóa học</div>
                    <div class="detail-value"><span class="mono">@Model.Course.CourseCode</span></div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Giảng viên</div>
                    <div class="detail-value">@(Model.Course.Teacher?.FullName ?? "—")</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Danh mục</div>
                    <div class="detail-value">@(Model.Course.Category?.CategoryName ?? "—")</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Cấp độ</div>
                    <div class="detail-value">@Model.Course.Level</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Giá (VNĐ)</div>
                    <div class="detail-value">@Model.Course.Price.ToString("N0") ₫</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Giá khuyến mãi</div>
                    <div class="detail-value">@(Model.Course.DiscountPrice.HasValue ? Model.Course.DiscountPrice.Value.ToString("N0") + " ₫" : "—")</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Ngôn ngữ</div>
                    <div class="detail-value">@Model.Course.Language</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Slug</div>
                    <div class="detail-value" style="font-size:12px;word-break:break-all;">@Model.Course.Slug</div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Course.ThumbnailUrl))
            {
                <div class="detail-item" style="margin-top: var(--space-4);">
                    <div class="detail-label">Ảnh bìa</div>
                    <div style="margin-top: 6px;">
                        <img src="@Model.Course.ThumbnailUrl" alt="Thumbnail"
                             style="max-width:320px;border-radius:var(--radius-sm);border:1px solid var(--color-border-light);" />
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Course.Description))
            {
                <div class="detail-item" style="margin-top: var(--space-4);">
                    <div class="detail-label">Mô tả khóa học</div>
                    <div class="detail-box">@Model.Course.Description</div>
                </div>
            }

            @if (Model.Course.Status == CourseStatus.Rejected && !string.IsNullOrWhiteSpace(Model.Course.RejectionReason))
            {
                <div class="detail-item" style="margin-top: var(--space-4);">
                    <div class="detail-label">Lý do từ chối</div>
                    <div class="reject-box">@Model.Course.RejectionReason</div>
                </div>
            }

        </div>
    </div>

    @if (Model.Course.Status == CourseStatus.Pending)
    {
        <div class="review-section fade-up">
            <h3>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
                Hành động duyệt
            </h3>

            <!-- Approve -->
            <form method="post" asp-page-handler="Approve" asp-route-id="@Model.Course.CourseId" style="margin-bottom: var(--space-5);">
                <button type="submit" class="btn btn-primary"
                        onclick="return confirm('Xác nhận phê duyệt khóa học này?')">
                    ✓ Phê duyệt & Xuất bản
                </button>
            </form>

            <!-- Reject -->
            <form method="post" asp-page-handler="Reject" asp-route-id="@Model.Course.CourseId">
                <div style="margin-bottom: var(--space-3);">
                    <label asp-for="RejectionReason" class="detail-label" style="display:block;margin-bottom:6px;">
                        Lý do từ chối <span style="color:var(--color-red)">*</span>
                    </label>
                    <textarea asp-for="RejectionReason"
                              class="form-control"
                              rows="3"
                              placeholder="Nhập lý do từ chối (bắt buộc)..."
                              style="resize:vertical;"></textarea>
                    <span asp-validation-for="RejectionReason" class="text-danger" style="font-size:12px;"></span>
                </div>
                <button type="submit" class="btn btn-danger"
                        onclick="return confirm('Xác nhận từ chối khóa học này?')">
                    ✕ Từ chối
                </button>
            </form>
        </div>
    }
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
