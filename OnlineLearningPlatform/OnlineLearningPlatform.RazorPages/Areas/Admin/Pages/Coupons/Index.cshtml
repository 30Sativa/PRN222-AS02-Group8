@page
@model OnlineLearningPlatform.RazorPages.Areas.Admin.Pages.Coupons.IndexModel
@{
    ViewData["Title"] = "Quản lý mã khuyến mãi";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1 fw-bold">Quản lý mã khuyến mãi</h2>
            <p class="text-muted mb-0">Tạo và quản lý các mã khuyến mãi cho học viên.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" asp-area="Admin" asp-page="/Dashboard">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
            <a class="btn btn-primary" asp-area="Admin" asp-page="/Coupons/Create">
                <i class="bi bi-plus-circle me-1"></i> Tạo mã mới
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã</th>
                            <th>Mô tả</th>
                            <th>Loại</th>
                            <th>Giá trị</th>
                            <th>Đơn hàng tối thiểu</th>
                            <th>Hiệu lực</th>
                            <th>Đã dùng</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Coupons.Count == 0)
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted py-4">
                                    Chưa có mã khuyến mãi nào.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var c in Model.Coupons)
                            {
                                var now = DateTime.UtcNow;
                                var isExpired = c.EndDate < now;
                                var isNotStarted = c.StartDate > now;
                                var statusClass = !c.IsActive ? "bg-secondary" : isExpired ? "bg-danger" : isNotStarted ? "bg-warning text-dark" : "bg-success";
                                var statusText = !c.IsActive ? "Tắt" : isExpired ? "Hết hạn" : isNotStarted ? "Chưa bắt đầu" : "Hoạt động";
                                var discountDisplay = c.DiscountType == CouponDiscountType.Percentage
                                    ? $"{c.DiscountValue}%"
                                    : $"{c.DiscountValue:N0} đ";
                                <tr>
                                    <td><code class="fs-6">@c.Code</code></td>
                                    <td>@(string.IsNullOrEmpty(c.Description) ? "—" : c.Description)</td>
                                    <td>
                                        <span class="badge bg-@(c.DiscountType == CouponDiscountType.Percentage ? "info" : "primary")">
                                            @(c.DiscountType == CouponDiscountType.Percentage ? "%" : "VNĐ")
                                        </span>
                                    </td>
                                    <td>@discountDisplay</td>
                                    <td>@(c.MinOrderAmount.HasValue ? $"{c.MinOrderAmount.Value:N0} đ" : "—")</td>
                                    <td>
                                        <small>
                                            @c.StartDate.ToString("dd/MM/yyyy")<br />
                                            <span class="text-muted">→ @c.EndDate.ToString("dd/MM/yyyy")</span>
                                        </small>
                                    </td>
                                    <td>
                                        @(c.UsageLimit.HasValue ? $"{c.UsedCount} / {c.UsageLimit}" : $"{c.UsedCount} (∞)")
                                    </td>
                                    <td><span class="badge @statusClass">@statusText</span></td>
                                    <td class="text-end">
                                        @if (c.IsActive)
                                        {
                                            <form method="post" asp-page-handler="Deactivate" asp-route-couponId="@c.CouponId" class="d-inline"
                                                  onsubmit="return confirm('Vô hiệu hóa mã @c.Code?')">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-x-circle"></i> Tắt
                                                </button>
                                            </form>
                                        }
                                        <a class="btn btn-sm btn-outline-warning" asp-area="Admin" asp-page="/Coupons/Edit" asp-route-id="@c.CouponId">
                                            <i class="bi bi-pencil"></i> Sửa
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
