@page
@model OnlineLearningPlatform.RazorPages.Areas.Admin.Pages.Coupons.IndexModel
@{
    ViewData["Title"] = "Quản lý mã khuyến mãi";
}

<div class="ud-page-wide">
    <div class="ud-page-head ud-fade-up">
        <div class="ud-page-head-row">
            <div>
                <h1>Quản lý mã khuyến mãi</h1>
                <p>Tạo và quản lý các mã khuyến mãi cho học viên.</p>
            </div>
            <div class="ud-flex ud-align-center ud-gap-2">
                <a class="btn btn-outline" asp-area="Admin" asp-page="/Dashboard">
                    @Html.Raw("<i class=\"bi bi-arrow-left\"></i>")
                    Quay lại
                </a>
                <a class="btn btn-primary" asp-area="Admin" asp-page="/Coupons/Create">
                    @Html.Raw("<i class=\"bi bi-plus-circle\"></i>")
                    Tạo mã mới
                </a>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success ud-fade-up">
            @Html.Raw("<i class=\"bi bi-check-circle\"></i>")
            @successMessage
        </div>
    }
    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger ud-fade-up">
            @Html.Raw("<i class=\"bi bi-exclamation-circle\"></i>")
            @errorMessage
        </div>
    }

    <div class="ud-card ud-fade-up">
        <div class="ud-table-wrap">
            <table class="ud-table">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Mô tả</th>
                        <th>Loại</th>
                        <th>Giá trị</th>
                        <th>Đơn hàng tối thiểu</th>
                        <th>Hiệu lực</th>
                        <th>Đã dùng</th>
                        <th>Trạng thái</th>
                        <th class="ud-text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Coupons.Count == 0)
                    {
                        <tr>
                            <td colspan="9">
                                <div class="ud-empty">
                                    @Html.Raw("<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"48\" height=\"48\" fill=\"currentColor\" viewBox=\"0 0 16 16\"><path d=\"M2.5 3.5a.5.5 0 0 1 0-1h11a.5.5 0 0 1 0 1h-11zm2-2a.5.5 0 0 1 0-1h11a.5.5 0 0 1 0 1h-11zM.5 6a.5.5 0 0 0 0 1h15a.5.5 0 0 0 0-1H.5zM3.5 10.5a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5zm1 2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5z\"/></svg>")
                                    <h3>Chưa có mã khuyến mãi nào</h3>
                                    <p>Tạo mã khuyến mãi đầu tiên để bắt đầu.</p>
                                    <a class="btn btn-primary btn-sm" asp-area="Admin" asp-page="/Coupons/Create">
                                        @Html.Raw("<i class=\"bi bi-plus-circle\"></i>")
                                        Tạo mã mới
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var c in Model.Coupons)
                        {
                            var now = DateTime.UtcNow;
                            var isExpired = c.EndDate < now;
                            var isNotStarted = c.StartDate > now;
                            var statusClass = !c.IsActive ? "badge-muted" : isExpired ? "badge-muted" : isNotStarted ? "badge-purple" : "badge-green";
                            var statusText = !c.IsActive ? "Tắt" : isExpired ? "Hết hạn" : isNotStarted ? "Chưa bắt đầu" : "Hoạt động";
                            var discountDisplay = c.DiscountType == CouponDiscountType.Percentage
                                ? $"{c.DiscountValue}%"
                                : $"{c.DiscountValue:N0} đ";
                            var typeBadgeClass = c.DiscountType == CouponDiscountType.Percentage ? "badge-purple" : "badge-green";
                            <tr>
                                <td>
                                    <code style="font-size: 0.9rem; background: var(--ud-surface); padding: 2px 6px; border-radius: var(--ud-radius);">@c.Code</code>
                                </td>
                                <td class="ud-text-muted">@(string.IsNullOrEmpty(c.Description) ? "—" : c.Description)</td>
                                <td>
                                    <span class="badge @typeBadgeClass">
                                        @(c.DiscountType == CouponDiscountType.Percentage ? "%" : "VNĐ")
                                    </span>
                                </td>
                                <td>@discountDisplay</td>
                                <td class="ud-text-muted">@(c.MinOrderAmount.HasValue ? $"{c.MinOrderAmount.Value:N0} đ" : "—")</td>
                                <td>
                                    <div style="font-size: 0.8rem;">
                                        <div>@c.StartDate.ToString("dd/MM/yyyy")</div>
                                        <div class="ud-text-muted">→ @c.EndDate.ToString("dd/MM/yyyy")</div>
                                    </div>
                                </td>
                                <td>
                                    @(c.UsageLimit.HasValue ? $"{c.UsedCount} / {c.UsageLimit}" : $"{c.UsedCount} (∞)")
                                </td>
                                <td>
                                    <span class="badge @statusClass">@statusText</span>
                                </td>
                                <td class="ud-text-end">
                                    <div class="ud-flex ud-justify-end ud-gap-2">
                                        @if (c.IsActive)
                                        {
                                            <form method="post" asp-page-handler="Deactivate" asp-route-couponId="@c.CouponId"
                                                  onsubmit="return confirm('Vô hiệu hóa mã @c.Code?')">
                                                <button type="submit" class="btn btn-outline btn-sm" style="border-color: var(--ud-red); color: var(--ud-red);">
                                                    @Html.Raw("<i class=\"bi bi-x-circle\"></i>")
                                                    Tắt
                                                </button>
                                            </form>
                                        }
                                        <a class="btn btn-outline btn-sm" asp-area="Admin" asp-page="/Coupons/Edit" asp-route-id="@c.CouponId">
                                            @Html.Raw("<i class=\"bi bi-pencil\"></i>")
                                            Sửa
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
