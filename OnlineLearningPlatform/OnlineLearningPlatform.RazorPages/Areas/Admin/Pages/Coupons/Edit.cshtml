@page "{id:int}"
@model OnlineLearningPlatform.RazorPages.Areas.Admin.Pages.Coupons.EditModel
@{
    ViewData["Title"] = "Sửa mã khuyến mãi";
}

<div class="ud-page">
    <div class="ud-card" style="max-width:640px;margin:0 auto;">

        <div style="padding:var(--ud-sp6) var(--ud-sp6) var(--ud-sp4);border-bottom:1px solid var(--ud-border-light);">
            <div class="ud-page-head-row">
                <div>
                    <h1 style="font-size:1.25rem;font-weight:800;letter-spacing:-0.02em;margin-bottom:var(--ud-sp2);">Sửa mã khuyến mãi</h1>
                    <p style="font-size:0.875rem;color:var(--ud-text-muted);margin:0;">Cập nhật thông tin mã giảm giá.</p>
                </div>
                <a class="btn btn-outline btn-sm" asp-area="Admin" asp-page="/Coupons/Index">
                    @Html.Raw("<i class=\"bi bi-arrow-left\"></i>")
                    Danh sách mã
                </a>
            </div>
        </div>

        <form method="post" style="margin:0;">

            <div style="padding:var(--ud-sp6) var(--ud-sp6) var(--ud-sp4);border-bottom:1px solid var(--ud-border-light);">
                <p style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ud-text-muted);margin-bottom:var(--ud-sp4);">Thông tin mã</p>
                <div class="ud-grid" style="grid-template-columns:1fr;">
                    <div class="form-group">
                        <label class="form-label" asp-for="Code">Mã coupon <span style="color:var(--ud-red);">*</span></label>
                        <input type="text" class="form-control text-uppercase" asp-for="Code" placeholder="VD: SUMMER2026" maxlength="50" autocomplete="off" />
                        <p style="font-size:0.75rem;color:var(--ud-text-muted);margin-top:var(--ud-sp2);margin-bottom:0;">Lưu dưới dạng chữ in hoa, không dấu cách.</p>
                        <span class="form-error" asp-validation-for="Code"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="Description">Mô tả ngắn</label>
                        <input type="text" class="form-control" asp-for="Description" placeholder="VD: Giảm 10% tháng 4" maxlength="255" />
                    </div>
                </div>
            </div>

            <div style="padding:var(--ud-sp6) var(--ud-sp6) var(--ud-sp4);border-bottom:1px solid var(--ud-border-light);">
                <p style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ud-text-muted);margin-bottom:var(--ud-sp4);">Giảm giá</p>
                <div class="ud-grid" style="grid-template-columns:1fr 1fr;">
                    <div class="form-group">
                        <label class="form-label" asp-for="DiscountType">Loại <span style="color:var(--ud-red);">*</span></label>
                        <select class="form-control" asp-for="DiscountType" id="discountTypeSelect">
                            <option value="Percentage">Phần trăm (%)</option>
                            <option value="FixedAmount">Số tiền cố định (VNĐ)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="DiscountValue">Giá trị <span style="color:var(--ud-red);">*</span></label>
                        <input type="number" class="form-control" asp-for="DiscountValue" min="1" step="any" id="discountValueInput" />
                        <p id="discountValueHint" style="font-size:0.75rem;color:var(--ud-text-muted);margin-top:var(--ud-sp2);margin-bottom:0;"></p>
                    </div>
                    <div class="form-group" style="grid-column:1/-1;" id="percentageCapBlock">
                        <div class="form-check" style="margin-bottom:var(--ud-sp3);">
                            <input class="form-check-input" type="checkbox" asp-for="LimitMaxDiscount" id="limitMaxDiscountCb" />
                            <label class="form-check-label" for="limitMaxDiscountCb">Giới hạn mức giảm tối đa (VNĐ)</label>
                        </div>
                        <p style="font-size:0.75rem;color:var(--ud-text-muted);margin-bottom:var(--ud-sp4);">Tuỳ chọn: ví dụ "giảm 50% nhưng tối đa 100.000đ". Không chọn thì giảm đúng theo % trên giá khóa.</p>
                        <div id="maxDiscountAmountWrapper" style="display:none;">
                            <label class="form-label" asp-for="MaxDiscountAmount">Mức trần (VNĐ) <span style="color:var(--ud-red);">*</span></label>
                            <input type="number" class="form-control" asp-for="MaxDiscountAmount" min="1" step="1" placeholder="VD: 100000" />
                            <span class="form-error" asp-validation-for="MaxDiscountAmount"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div style="padding:var(--ud-sp6) var(--ud-sp6) var(--ud-sp4);border-bottom:1px solid var(--ud-border-light);">
                <p style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ud-text-muted);margin-bottom:var(--ud-sp4);">Thời gian &amp; giới hạn</p>
                <div class="ud-grid" style="grid-template-columns:1fr 1fr;">
                    <div class="form-group">
                        <label class="form-label" asp-for="StartDate">Bắt đầu <span style="color:var(--ud-red);">*</span></label>
                        <input type="datetime-local" class="form-control" asp-for="StartDate" step="60" />
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="EndDate">Kết thúc <span style="color:var(--ud-red);">*</span></label>
                        <input type="datetime-local" class="form-control" asp-for="EndDate" step="60" />
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="UsageLimit">Tổng lượt dùng</label>
                        <input type="number" class="form-control" asp-for="UsageLimit" min="1" placeholder="Để trống = không giới hạn" />
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="MaxUsagePerUser">Mỗi tài khoản tối đa</label>
                        <input type="number" class="form-control" asp-for="MaxUsagePerUser" min="1" />
                    </div>
                    <div class="form-group" style="grid-column:1/-1;">
                        <label class="form-label" asp-for="MinOrderAmount">Đơn tối thiểu (VNĐ)</label>
                        <input type="number" class="form-control" asp-for="MinOrderAmount" min="0" placeholder="VD: 100000" />
                    </div>
                </div>
            </div>

            <div style="padding:var(--ud-sp6) var(--ud-sp6) var(--ud-sp4);border-bottom:1px solid var(--ud-border-light);">
                <p style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ud-text-muted);margin-bottom:var(--ud-sp4);">Phạm vi áp dụng</p>
                <div class="form-check form-switch" style="margin-bottom:var(--ud-sp4);">
                    <input class="form-check-input" type="checkbox" asp-for="IsCourseSpecific" id="isCourseSpecific" />
                    <label class="form-check-label" for="isCourseSpecific">Chỉ áp dụng cho <strong>một</strong> khóa học cụ thể</label>
                </div>
                <div id="courseSelectSection" style="display:none;">
                    <div class="form-group">
                        <label class="form-label" asp-for="CourseId">Khóa học</label>
                        <select class="form-control" asp-for="CourseId" asp-items="Model.CourseOptions"></select>
                        <p style="font-size:0.75rem;color:var(--ud-text-muted);margin-top:var(--ud-sp2);margin-bottom:0;">Danh sách lấy từ tất cả khóa (chưa xóa) trên hệ thống.</p>
                        <span class="form-error d-block" asp-validation-for="CourseId"></span>
                    </div>
                </div>
            </div>

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div style="padding:0 var(--ud-sp6) var(--ud-sp4);">
                    <div class="alert alert-danger">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                </div>
            }

            <div style="padding:var(--ud-sp5) var(--ud-sp6);background:var(--ud-surface);border-top:1px solid var(--ud-border-light);display:flex;flex-wrap:wrap;gap:var(--ud-sp3);">
                <button type="submit" class="btn btn-primary">
                    @Html.Raw("<i class=\"bi bi-check2-circle\"></i>")
                    Cập nhật
                </button>
                <a class="btn btn-outline" asp-area="Admin" asp-page="/Coupons/Index">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var cb = document.getElementById('isCourseSpecific');
            var section = document.getElementById('courseSelectSection');
            function syncCourse() {
                if (cb.checked) section.style.display = '';
                else section.style.display = 'none';
            }
            cb.addEventListener('change', syncCourse);
            syncCourse();

            var typeSel = document.getElementById('discountTypeSelect');
            var pctBlock = document.getElementById('percentageCapBlock');
            var limitCb = document.getElementById('limitMaxDiscountCb');
            var maxWrap = document.getElementById('maxDiscountAmountWrapper');
            var hint = document.getElementById('discountValueHint');
            function syncDiscountType() {
                if (!typeSel || !pctBlock) return;
                var isPct = typeSel.value === 'Percentage';
                pctBlock.style.display = '';
                if (!isPct && limitCb) limitCb.checked = false;
                if (hint) hint.textContent = isPct ? 'Nhập phần trăm (vd: 10 = giảm 10%).' : 'Nhập số tiền giảm (VNĐ).';
                syncMaxCap();
            }
            function syncMaxCap() {
                if (!maxWrap || !limitCb || !typeSel) return;
                var show = typeSel.value === 'Percentage' && limitCb.checked;
                maxWrap.style.display = show ? '' : 'none';
            }
            if (typeSel) typeSel.addEventListener('change', syncDiscountType);
            if (limitCb) limitCb.addEventListener('change', syncMaxCap);
            syncDiscountType();
        })();
    </script>
}
