@page
@model OnlineLearningPlatform.RazorPages.Areas.Admin.Pages.DashboardModel
@using OnlineLearningPlatform.Services.DTOs.Dashboard
@{
    ViewData["Title"] = "Dashboard";

    string RelativeTime(DateTime dt)
    {
        var d = (DateTime.UtcNow - dt).Days;
        return d == 0 ? "Hôm nay"
             : d == 1 ? "Hôm qua"
             : d < 7  ? $"{d} ngày trước"
             : dt.ToString("dd/MM/yyyy");
    }
}

<style>
    .admin-dash-hero {
        background: linear-gradient(135deg, var(--ud-purple) 0%, var(--ud-magenta) 100%);
        border-radius: 16px;
        padding: clamp(var(--ud-sp6), 4vw, var(--ud-sp10)) clamp(var(--ud-sp6), 4vw, var(--ud-sp10));
        margin-bottom: var(--ud-sp8);
        color: #fff;
        position: relative;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(86, 36, 208, 0.22);
    }
    .admin-dash-hero::before {
        content: "";
        position: absolute;
        width: 220px;
        height: 220px;
        border-radius: 50%;
        background: rgba(255,255,255,.07);
        top: -100px;
        right: -40px;
    }
    .admin-dash-hero::after {
        content: "";
        position: absolute;
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: rgba(255,255,255,.05);
        bottom: -50px;
        left: 15%;
    }
    .admin-dash-hero-inner { position: relative; z-index: 1; }
    .admin-dash-hero h2 {
        color: #fff;
        font-size: clamp(1.2rem, 2.5vw, 1.45rem);
        font-weight: 800;
        margin: 0 0 var(--ud-sp3);
        letter-spacing: -0.02em;
    }
    .admin-dash-hero p {
        margin: 0;
        opacity: 0.9;
        font-size: 0.92rem;
        max-width: 540px;
        line-height: 1.55;
    }
    .admin-dash-panel {
        border-radius: 14px !important;
        overflow: hidden;
        box-shadow: var(--ud-shadow-sm);
        border: 1px solid var(--ud-border);
    }

    .dash-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--ud-sp5);
        margin-top: var(--ud-sp5);
    }
    @@media (max-width: 768px) {
        .dash-grid { grid-template-columns: 1fr; }
    }

    .chart-container { position: relative; height: 220px; width: 100%; }

    .stat-section-label {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: var(--ud-text-muted);
        margin-bottom: var(--ud-sp3);
        margin-top: var(--ud-sp6);
    }
    .stat-section-label:first-of-type { margin-top: 0; }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--ud-sp4);
    }
    @@media (max-width: 1024px) {
        .stat-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @@media (max-width: 576px) {
        .stat-grid { grid-template-columns: 1fr; }
    }

    .stat-card {
        background: var(--ud-white);
        border: 1px solid var(--ud-border);
        border-radius: 12px;
        padding: var(--ud-sp5);
        box-shadow: var(--ud-shadow-sm);
        transition: box-shadow var(--ud-ease), transform var(--ud-ease);
    }
    .stat-card:hover {
        box-shadow: var(--ud-shadow);
        transform: translateY(-2px);
    }

    .stat-card-icon {
        width: 40px;
        height: 40px;
        border-radius: var(--ud-radius);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: var(--ud-sp3);
    }
    .stat-card-icon svg { width: 18px; height: 18px; }

    .icon-blue   { background: rgba(0,113,227,.1);  color: #0071e3; }
    .icon-green  { background: var(--ud-green-bg); color: var(--ud-green); }
    .icon-red    { background: var(--ud-red-bg);   color: var(--ud-red); }
    .icon-amber  { background: var(--ud-amber-bg); color: var(--ud-amber); }
    .icon-purple { background: rgba(86,36,208,.1); color: var(--ud-purple); }
    .icon-gray   { background: var(--ud-surface);  color: var(--ud-text-muted); }

    .stat-label {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--ud-text-muted);
        margin-bottom: var(--ud-sp2);
    }

    .stat-value {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--ud-text);
        line-height: 1.2;
        letter-spacing: -0.02em;
    }

    .stat-sub {
        font-size: 0.72rem;
        color: var(--ud-text-muted);
        margin-top: var(--ud-sp2);
    }

    .card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--ud-sp4) var(--ud-sp5);
        border-bottom: 1px solid var(--ud-border-light, #e8e8ed);
    }
    .card-head h2 {
        font-size: 0.9rem;
        font-weight: 800;
        color: var(--ud-text);
        display: flex;
        align-items: center;
        gap: var(--ud-sp2);
        margin: 0;
    }
    .card-head h2 svg { color: var(--ud-purple); }
    .card-head span {
        font-size: 0.72rem;
        color: var(--ud-text-muted);
        font-weight: 500;
    }

    .card-body { padding: var(--ud-sp4) var(--ud-sp5); }

    .mini-list { list-style: none; padding: 0; margin: 0; }
    .mini-list-item {
        display: flex;
        align-items: center;
        gap: var(--ud-sp3);
        padding: var(--ud-sp3) 0;
        border-bottom: 1px solid var(--ud-border-light, #e8e8ed);
    }
    .mini-list-item:last-child { border-bottom: none; }

    .mini-list-icon {
        width: 36px;
        height: 36px;
        border-radius: var(--ud-radius);
        background: var(--ud-surface);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .mini-list-icon svg { width: 16px; height: 16px; color: var(--ud-text-muted); }

    .mini-list-body { flex: 1; min-width: 0; }
    .mini-list-title {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--ud-text);
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
    }
    .mini-list-meta {
        font-size: 0.72rem;
        color: var(--ud-text-muted);
        margin-top: 2px;
    }

    .rank-badge {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 800;
        flex-shrink: 0;
    }
    .rank-1 { background: #ffd700; color: #7d5800; }
    .rank-2 { background: #c0c0c0; color: #555; }
    .rank-3 { background: #cd7f32; color: #5c3300; }
    .rank-n { background: var(--ud-surface); color: var(--ud-text-muted); }

    .enroll-count {
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--ud-purple);
        white-space: nowrap;
    }

    .quick-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--ud-sp3);
    }
    @@media (max-width: 576px) {
        .quick-grid { grid-template-columns: 1fr; }
    }

    .quick-item {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        padding: var(--ud-sp4);
        border: 1px solid var(--ud-border);
        border-radius: var(--ud-radius);
        background: var(--ud-white);
        text-decoration: none;
        color: inherit;
        transition: border-color var(--ud-ease), box-shadow var(--ud-ease), transform var(--ud-ease);
    }
    .quick-item:hover {
        border-color: var(--ud-purple);
        box-shadow: var(--ud-shadow);
        transform: translateY(-1px);
        text-decoration: none;
        color: inherit;
    }

    .quick-item-icon {
        width: 36px;
        height: 36px;
        border-radius: var(--ud-radius);
        background: rgba(86,36,208,.08);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: var(--ud-sp3);
    }
    .quick-item-icon svg { width: 16px; height: 16px; color: var(--ud-purple); }

    .quick-item-title {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--ud-text);
        margin-bottom: 2px;
    }
    .quick-item-desc {
        font-size: 0.72rem;
        color: var(--ud-text-muted);
        line-height: 1.4;
    }

    .quick-item-disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    .quick-item-disabled:hover {
        transform: none;
        border-color: var(--ud-border);
        box-shadow: none;
    }

    .badge-soon {
        display: inline-flex;
        align-items: center;
        padding: 2px 6px;
        border-radius: var(--ud-radius);
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        background: var(--ud-surface);
        color: var(--ud-text-muted);
        border: 1px solid var(--ud-border);
        margin-bottom: var(--ud-sp2);
    }

    .alert-banner {
        display: flex;
        align-items: center;
        gap: var(--ud-sp3);
        padding: var(--ud-sp4) var(--ud-sp5);
        border-radius: var(--ud-radius);
        margin-bottom: var(--ud-sp6);
        font-size: 0.875rem;
        font-weight: 500;
        animation: udFadeUp .3s ease forwards;
    }
    .alert-banner-warning {
        background: var(--ud-amber-bg);
        border: 1px solid rgba(146,97,10,.2);
        color: var(--ud-amber);
    }
    .alert-banner svg { flex-shrink: 0; }

    @@keyframes udFadeUp {
        from { opacity: 0; transform: translateY(-8px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="ud-page-wide">
    <div class="ud-page-head ud-fade-up">
        <h1>Bảng điều khiển</h1>
        <p style="color: var(--ud-text-muted); font-size: 0.9rem; margin: 0;">
            <span>Admin</span>
            <span style="color: var(--ud-border);"> / </span>
            <span>Tổng quan hệ thống</span>
        </p>
    </div>

    <div class="admin-dash-hero ud-fade-up">
        <div class="admin-dash-hero-inner">
            <h2>Xin chào@(User.Identity?.Name != null ? $", {User.Identity.Name.Split('@')[0]}" : "")</h2>
            <p>Theo dõi người dùng, khóa học, doanh thu và xử lý duyệt / hoàn tiền từ một nơi.</p>
        </div>
    </div>

    @if (Model.PendingCourses > 0 || Model.PendingRefunds > 0)
    {
        <div class="alert-banner alert-banner-warning ud-fade-up">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <span>
                Bạn có
                @if (Model.PendingCourses > 0)
                {
                    <strong>@Model.PendingCourses khóa học</strong>
                    @: chờ duyệt
                }
                @if (Model.PendingCourses > 0 && Model.PendingRefunds > 0)
                {
                    @: và
                }
                @if (Model.PendingRefunds > 0)
                {
                    <strong>@Model.PendingRefunds yêu cầu hoàn tiền</strong>
                    @: cần xử lý
                }
                — hãy xử lý sớm để tránh ảnh hưởng trải nghiệm người dùng.
            </span>
        </div>
    }

    <p class="stat-section-label ud-fade-up">Người dùng</p>
    <div class="stat-grid ud-fade-up">
        <div class="stat-card">
            <div class="stat-card-icon icon-blue">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
            </div>
            <div class="stat-label">Tổng người dùng</div>
            <div class="stat-value">@Model.TotalUsers</div>
        </div>

        <div class="stat-card">
            <div class="stat-card-icon icon-green">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                    <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                </svg>
            </div>
            <div class="stat-label">Học viên</div>
            <div class="stat-value">@Model.TotalStudents</div>
        </div>

        <div class="stat-card">
            <div class="stat-card-icon icon-blue">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="8" r="4"/>
                    <path d="M20 21a8 8 0 1 0-16 0"/>
                    <path d="M15 3h6M18 3v6"/>
                </svg>
            </div>
            <div class="stat-label">Giảng viên</div>
            <div class="stat-value">@Model.TotalTeachers</div>
        </div>

        <div class="stat-card">
            <div class="stat-card-icon icon-gray">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
            </div>
            <div class="stat-label">Quản trị</div>
            <div class="stat-value">@Model.TotalAdmins</div>
        </div>
    </div>

    <p class="stat-section-label ud-fade-up">Khóa học &amp; Đăng ký</p>
    <div class="stat-grid ud-fade-up">
        <div class="stat-card">
            <div class="stat-card-icon icon-blue">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                    <line x1="8" y1="21" x2="16" y2="21"/>
                    <line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
            </div>
            <div class="stat-label">Tổng khóa học</div>
            <div class="stat-value">@Model.TotalCourses</div>
            <div class="stat-sub">@Model.PublishedCourses đã xuất bản</div>
        </div>

        <div class="stat-card">
            <div class="stat-card-icon icon-amber">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                </svg>
            </div>
            <div class="stat-label">Chờ duyệt</div>
            <div class="stat-value">@Model.PendingCourses</div>
            <div class="stat-sub">Khóa học cần review</div>
        </div>

        <div class="stat-card">
            <div class="stat-card-icon icon-green">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <polyline points="16 11 18 13 22 9"/>
                </svg>
            </div>
            <div class="stat-label">Tổng đăng ký</div>
            <div class="stat-value">@Model.TotalEnrollments</div>
            <div class="stat-sub">+@Model.NewEnrollmentsThisMonth trong 30 ngày qua</div>
        </div>

        <div class="stat-card">
            <div class="stat-card-icon icon-red">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="1 4 1 10 7 10"/>
                    <path d="M3.51 15a9 9 0 1 0 .49-3.51"/>
                </svg>
            </div>
            <div class="stat-label">Hoàn tiền chờ duyệt</div>
            <div class="stat-value">@Model.PendingRefunds</div>
            <div class="stat-sub">Yêu cầu cần xử lý</div>
        </div>
    </div>

    <p class="stat-section-label ud-fade-up">Doanh thu</p>
    <div class="ud-fade-up" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--ud-sp4); max-width: 560px;">
        <div class="stat-card">
            <div class="stat-card-icon icon-purple">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="1" x2="12" y2="23"/>
                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                </svg>
            </div>
            <div class="stat-label">Tổng doanh thu</div>
            <div class="stat-value" style="font-size: 1.4rem;">
                @Model.TotalRevenue.ToString("N0")
                <span style="font-size: 0.875rem; font-weight: 500; color: var(--ud-text-muted);">đ</span>
            </div>
            <div class="stat-sub">Từ các đơn đã hoàn thành</div>
        </div>

        <div class="stat-card">
            <div class="stat-card-icon icon-purple">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                    <polyline points="17 6 23 6 23 12"/>
                </svg>
            </div>
            <div class="stat-label">30 ngày gần đây</div>
            <div class="stat-value" style="font-size: 1.4rem;">
                @Model.RevenueThisMonth.ToString("N0")
                <span style="font-size: 0.875rem; font-weight: 500; color: var(--ud-text-muted);">đ</span>
            </div>
            <div class="stat-sub">Doanh thu tháng này</div>
        </div>
    </div>

    <div class="dash-grid ud-fade-up">
        <div class="ud-card admin-dash-panel">
            <div class="card-head">
                <h2>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="20" x2="18" y2="10"/>
                        <line x1="12" y1="20" x2="12" y2="4"/>
                        <line x1="6" y1="20" x2="6" y2="14"/>
                    </svg>
                    Doanh thu theo tháng
                </h2>
                <span>Năm @DateTime.Now.Year</span>
            </div>
            <div class="card-body">
                <div class="chart-container">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>

        <div class="ud-card admin-dash-panel">
            <div class="card-head">
                <h2>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                    Top khóa học
                </h2>
                <span>Theo lượt đăng ký</span>
            </div>
            <div class="card-body" style="padding-top: var(--ud-sp3);">
                @if (!Model.Stats.TopCourses.Any())
                {
                    <div class="ud-empty">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <rect x="2" y="3" width="20" height="14" rx="2"/>
                            <line x1="8" y1="21" x2="16" y2="21"/>
                            <line x1="12" y1="17" x2="12" y2="21"/>
                        </svg>
                        <p>Chưa có dữ liệu</p>
                    </div>
                }
                else
                {
                    <ul class="mini-list">
                        @{
                            int rankIdx = 0;
                        }
                        @foreach (var item in Model.Stats.TopCourses)
                        {
                            rankIdx++;
                            string rankClass = rankIdx == 1 ? "rank-1"
                                             : rankIdx == 2 ? "rank-2"
                                             : rankIdx == 3 ? "rank-3"
                                             : "rank-n";
                            <li class="mini-list-item">
                                <span class="rank-badge @rankClass">@rankIdx</span>
                                <div class="mini-list-body">
                                    <div class="mini-list-title" title="@item.Course.Title">@item.Course.Title</div>
                                    <div class="mini-list-meta">
                                        @item.Course.TeacherName
                                        @if (!string.IsNullOrEmpty(item.Course.CategoryName))
                                        {
                                            <span> · @item.Course.CategoryName</span>
                                        }
                                    </div>
                                </div>
                                <span class="enroll-count">@item.EnrollmentCount HV</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    <div class="dash-grid ud-fade-up">
        <div class="ud-card admin-dash-panel">
            <div class="card-head">
                <h2>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    Khóa học chờ duyệt
                </h2>
                <a asp-area="Admin" asp-page="/Courses/Index" class="btn btn-sm btn-ghost">Xem tất cả</a>
            </div>
            <div class="card-body" style="padding-top: var(--ud-sp3);">
                @if (!Model.Stats.RecentPendingCourses.Any())
                {
                    <div class="ud-empty">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        <p>Không có khóa học nào chờ duyệt</p>
                    </div>
                }
                else
                {
                    <ul class="mini-list">
                        @foreach (var course in Model.Stats.RecentPendingCourses)
                        {
                            <li class="mini-list-item">
                                <div class="mini-list-icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                                        <line x1="8" y1="21" x2="16" y2="21"/>
                                        <line x1="12" y1="17" x2="12" y2="21"/>
                                    </svg>
                                </div>
                                <div class="mini-list-body">
                                    <div class="mini-list-title" title="@course.Title">@course.Title</div>
                                    <div class="mini-list-meta">
                                        <span>@course.TeacherName</span>
                                        <span style="margin-left: 8px;">@RelativeTime(course.CreatedAt)</span>
                                    </div>
                                </div>
                                <a asp-area="Admin" asp-page="/Courses/Details" asp-route-id="@course.CourseId"
                                   class="btn btn-sm btn-outline" style="flex-shrink: 0;">Duyệt</a>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        <div class="ud-card admin-dash-panel">
            <div class="card-head">
                <h2>Truy cập nhanh</h2>
            </div>
            <div class="card-body">
                <div class="quick-grid">
                    <a asp-area="Admin" asp-page="/Users/Index" class="quick-item">
                        <div class="quick-item-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                <circle cx="9" cy="7" r="4"/>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                        </div>
                        <div class="quick-item-title">Người dùng</div>
                        <div class="quick-item-desc">Xem, chỉnh sửa, đổi role</div>
                    </a>

                    <a asp-area="Admin" asp-page="/Courses/Index" class="quick-item">
                        <div class="quick-item-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                                <line x1="8" y1="21" x2="16" y2="21"/>
                                <line x1="12" y1="17" x2="12" y2="21"/>
                            </svg>
                        </div>
                        <div class="quick-item-title">Khóa học</div>
                        <div class="quick-item-desc">Duyệt và quản lý nội dung</div>
                    </a>

                    <a asp-area="Admin" asp-page="/Categories/Index" class="quick-item">
                        <div class="quick-item-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/>
                                <line x1="4" y1="22" x2="4" y2="15"/>
                            </svg>
                        </div>
                        <div class="quick-item-title">Danh mục</div>
                        <div class="quick-item-desc">Quản lý phân loại khóa học</div>
                    </a>

                    <div class="quick-item quick-item-disabled">
                        <span class="badge-soon">Sắp có</span>
                        <div class="quick-item-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="18" y1="20" x2="18" y2="10"/>
                                <line x1="12" y1="20" x2="12" y2="4"/>
                                <line x1="6" y1="20" x2="6" y2="14"/>
                            </svg>
                        </div>
                        <div class="quick-item-title">Báo cáo</div>
                        <div class="quick-item-desc">Doanh thu &amp; hoạt động hệ thống</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    (function () {
        const monthlyData = @Html.Raw(Model.MonthlyRevenueJson);
        const labels = ['T1','T2','T3','T4','T5','T6','T7','T8','T9','T10','T11','T12'];

        const ctx = document.getElementById('revenueChart').getContext('2d');
        const gradient = ctx.createLinearGradient(0, 0, 0, 220);
        gradient.addColorStop(0, 'rgba(86,36,208,0.2)');
        gradient.addColorStop(1, 'rgba(86,36,208,0)');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Doanh thu (đ)',
                    data: monthlyData,
                    fill: true,
                    backgroundColor: gradient,
                    borderColor: 'var(--ud-purple)',
                    borderWidth: 2,
                    pointBackgroundColor: 'var(--ud-purple)',
                    pointRadius: 3,
                    pointHoverRadius: 5,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function(ctx) {
                                return ctx.parsed.y.toLocaleString('vi-VN') + ' đ';
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        border: { display: false },
                        ticks: { font: { size: 11 }, color: '#6a6f73' }
                    },
                    y: {
                        grid: { color: 'rgba(0,0,0,.04)' },
                        border: { display: false },
                        ticks: {
                            font: { size: 11 }, color: '#6a6f73',
                            callback: function(val) {
                                if (val >= 1000000) return (val / 1000000).toFixed(1) + 'tr';
                                if (val >= 1000) return (val / 1000).toFixed(0) + 'K';
                                return val;
                            }
                        }
                    }
                }
            }
        });
    })();
</script>
}
