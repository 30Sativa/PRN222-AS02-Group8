@page
@model OnlineLearningPlatform.RazorPages.Areas.Student.Pages.MyLearningModel
@{
    ViewData["Title"] = "Khóa học của tôi";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="ud-page-wide ud-fade-up">
    <div class="ud-page-head">
        <h1>@ViewData["Title"]</h1>
        <p>Tiếp tục học tập và theo dõi tiến độ của bạn</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" role="alert">
            @Html.Raw("<i class=\"bi bi-check-circle-fill\"></i>") @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger" role="alert">
            @Html.Raw("<i class=\"bi bi-x-circle-fill\"></i>") @TempData["ErrorMessage"]
        </div>
    }

    @if (Model.EnrolledCourses.Any())
    {
        <div class="ud-grid ud-grid-auto">
            @foreach (var item in Model.EnrolledCourses)
            {
                var course = item.Enrollment.Course;
                var progress = item.Progress;
                var isDone = progress.IsCompleted;

                <div class="ud-course-card">
                    @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                    {
                        <div class="ud-course-thumb">
                            <img src="@course.ThumbnailUrl" alt="@course.Title" />
                        </div>
                    }
                    else
                    {
                        <div class="ud-course-thumb">
                            <div class="ud-course-thumb-placeholder">
                                @Html.Raw("<i class=\"bi bi-book\"></i>")
                            </div>
                        </div>
                    }

                    <div class="ud-course-body">
                        <div class="ud-course-title">@course.Title</div>
                        <div class="ud-course-instructor">@course.Teacher?.FullName</div>

                        <div style="margin-top: var(--ud-sp3);">
                            <div class="ud-progress">
                                <div class="ud-progress-bar" style="width: @progress.PercentComplete%;"></div>
                            </div>
                            <div class="ud-flex ud-align-center ud-justify-between ud-text-xs ud-text-muted" style="margin-top: var(--ud-sp2);">
                                <span>@progress.CompletedLessons / @progress.TotalLessons bài</span>
                                <span class="ud-fw-800" style="color: @(isDone ? "var(--ud-green)" : "var(--ud-magenta)");">
                                    @progress.PercentComplete%
                                </span>
                            </div>
                        </div>

                        <div style="margin-top: var(--ud-sp4);">
                            @if (isDone)
                            {
                                <a class="btn btn-success btn-full"
                                   href="/Student/LearnCourse?courseId=@course.CourseId">
                                    @Html.Raw("<i class=\"bi bi-check2-circle\"></i>") Đã hoàn thành — Xem lại
                                </a>
                            }
                            else
                            {
                                <a class="btn btn-primary btn-full"
                                   href="/Student/LearnCourse?courseId=@course.CourseId@(item.ResumeLessonId.HasValue ? $"&lessonId={item.ResumeLessonId}" : "")">
                                    @Html.Raw("<i class=\"bi bi-play-fill\"></i>") Tiếp tục học
                                </a>
                            }
                        </div>

                        @if (item.Enrollment.LastAccessedAt.HasValue)
                        {
                            <div class="ud-text-xs ud-text-muted" style="margin-top: var(--ud-sp3);">
                                @Html.Raw("<i class=\"bi bi-clock\"></i>") Lần truy cập cuối: @item.Enrollment.LastAccessedAt.Value.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        }

                        @if (!isDone)
                        {
                            <div style="margin-top: var(--ud-sp4); padding-top: var(--ud-sp3); border-top: 1px solid var(--ud-border-light, #e8e8ed);">
                                <form method="post" asp-page-handler="Refund" asp-route-courseId="@course.CourseId"
                                      onsubmit="return confirm('Bạn có chắc chắn muốn yêu cầu hoàn tiền khóa học này không? Quyền truy cập sẽ bị hủy lập tức!');">
                                    <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--ud-red);">
                                        @Html.Raw("<i class=\"bi bi-arrow-return-left\"></i>") Hoàn tiền về ví
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="ud-empty">
            @Html.Raw("<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"48\" height=\"48\" fill=\"currentColor\" viewBox=\"0 0 16 16\">")
                @Html.Raw("<path d=\"M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5l2.404.961L10.404 2l-2.218-.887zm3.564 1.426L5.596 5 8 5.961 14.154 3.5l-2.404-.961zm3.25 1.7-6.5 2.6v7.922l6.5-2.6V4.24zM7.5 14.762V6.838L1 4.239v7.923l6.5 2.6zM7.443.184a1.5 1.5 0 0 1 1.114 0l7.129 2.852A.5.5 0 0 1 16 3.5v8.662a1 1 0 0 1-.629.928l-7.185 2.874a.5.5 0 0 1-.372 0L.63 13.09a1 1 0 0 1-.63-.928V3.5a.5.5 0 0 1 .314-.464L7.443.184z\"/>")
            @Html.Raw("</svg>")
            <h3>Bạn chưa ghi danh khóa học nào</h3>
            <p>Khám phá các khóa học và bắt đầu hành trình học tập của bạn.</p>
            <a href="/Student/Dashboard" class="btn btn-primary" style="margin-top: var(--ud-sp4);">
                @Html.Raw("<i class=\"bi bi-compass\"></i>") Khám phá khóa học
            </a>
        </div>
    }
</div>
