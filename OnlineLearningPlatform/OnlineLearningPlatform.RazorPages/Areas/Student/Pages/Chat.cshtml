@page
@model OnlineLearningPlatform.RazorPages.Areas.Student.Pages.ChatModel
@{
    ViewData["Title"] = "Tin nhắn";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<style>
    .chat-page {
        max-width: 1220px;
        margin: 0 auto;
        padding: var(--ud-sp6) var(--ud-sp4) var(--ud-sp8);
        box-sizing: border-box;
    }
    .chat-page-title {
        font-size: clamp(1.25rem, 2.5vw, 1.5rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        color: var(--ud-text);
        margin: 0 0 6px;
    }
    .chat-page-sub { font-size: 0.88rem; color: var(--ud-text-muted); margin: 0 0 var(--ud-sp5); }
    .chat-wrapper {
        display: flex;
        height: min(720px, calc(100vh - 220px));
        min-height: 440px;
        margin: 0;
        background: var(--ud-white);
        border: 1px solid var(--ud-border);
        border-radius: var(--radius-xl);
        box-shadow: var(--ud-shadow);
        overflow: hidden;
    }
    .chat-sidebar {
        width: 320px;
        min-width: 260px;
        max-width: 38%;
        background: var(--ud-surface);
        border-right: 1px solid var(--ud-border-light);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .chat-sidebar-header {
        padding: 18px 18px 14px;
        border-bottom: 1px solid var(--ud-border-light);
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--ud-text);
        background: linear-gradient(180deg, rgba(86,36,208,0.06) 0%, transparent 100%);
    }
    .chat-conv-list { flex: 1; overflow-y: auto; padding: 10px 8px; }
    .chat-conv-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 14px;
        margin: 0 4px 4px;
        border-radius: 12px;
        cursor: pointer;
        text-decoration: none;
        border: 1px solid transparent;
        transition: background 0.15s, border-color 0.15s, box-shadow 0.15s;
    }
    .chat-conv-item:hover { background: var(--ud-white); border-color: var(--ud-border-light); box-shadow: var(--ud-shadow-sm); }
    .chat-conv-item.active { background: var(--ud-white); border-color: rgba(0,113,227,0.25); box-shadow: 0 0 0 2px rgba(0,113,227,0.12); }
    .chat-conv-avatar {
        width: 40px; height: 40px; border-radius: 50%;
        background: var(--ud-purple);
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 16px; font-weight: 700; flex-shrink: 0;
    }
    .chat-conv-info { flex: 1; overflow: hidden; }
    .chat-conv-name { font-size: 14px; font-weight: 600; color: var(--color-label-1); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .chat-conv-course { font-size: 11px; color: var(--color-blue); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .chat-conv-last { font-size: 12px; color: var(--color-label-3); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .chat-unread {
        background: var(--ud-magenta);
        color: #fff;
        border-radius: 10px;
        font-size: 11px;
        font-weight: 700;
        padding: 2px 7px;
        min-width: 20px;
        text-align: center;
        flex-shrink: 0;
    }
    .chat-new-section {
        padding: 8px 16px 6px;
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--ud-text-muted);
    }
    .chat-new-btn {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 14px;
        margin: 0 8px 8px;
        border-radius: 12px;
        border: 1px solid var(--ud-border);
        background: var(--ud-white);
        cursor: pointer;
        text-align: left;
        font-family: inherit;
        font-size: 14px;
        color: var(--ud-text);
        width: calc(100% - 16px);
        box-sizing: border-box;
        transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
    }
    .chat-new-btn:hover {
        border-color: var(--ud-magenta);
        background: rgba(164, 53, 240, 0.04);
        box-shadow: var(--ud-shadow-sm);
    }
    .chat-new-btn-name { font-weight: 700; color: var(--ud-text); }
    .chat-new-btn-course { font-size: 11px; color: var(--ud-text-muted); margin-top: 2px; }
    .chat-new-btn .chat-conv-avatar { width: 36px; height: 36px; font-size: 14px; }
    .chat-sidebar-empty {
        padding: 28px 18px;
        margin: 12px;
        text-align: center;
        font-size: 0.88rem;
        color: var(--ud-text-muted);
        line-height: 1.55;
        background: var(--ud-white);
        border: 1px dashed var(--ud-border);
        border-radius: 12px;
    }
    .chat-main { flex: 1; display: flex; flex-direction: column; background: var(--ud-white); overflow: hidden; min-width: 0; }
    .chat-main-header {
        padding: 14px 22px;
        border-bottom: 1px solid var(--ud-border-light);
        background: var(--ud-white);
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .chat-main-header-info h3 { font-size: 15px; font-weight: 700; color: var(--color-label-1); margin: 0; }
    .chat-main-header-info p { font-size: 12px; color: var(--color-label-2); margin: 0; }
    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 22px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        background: linear-gradient(180deg, var(--ud-surface) 0%, var(--ud-white) 28%);
    }
    .chat-bubble-wrap { display: flex; align-items: flex-end; gap: 8px; }
    .chat-bubble-wrap.mine { flex-direction: row-reverse; }
    .chat-bubble-avatar {
        width: 32px; height: 32px; border-radius: 50%;
        background: var(--color-surface-2);
        color: var(--color-label-2);
        display: flex; align-items: center; justify-content: center;
        font-size: 13px; font-weight: 700; flex-shrink: 0;
    }
    .chat-bubble-avatar.mine { background: var(--color-green); color: #fff; }
    .chat-bubble-wrap > div:not(.chat-bubble-avatar) { max-width: calc(65% - 50px); min-width: 0; }
    .chat-bubble {
        max-width: 100%;
        padding: 10px 14px;
        border-radius: 18px;
        font-size: 14px;
        line-height: 1.5;
        word-break: break-word;
        white-space: pre-wrap;
    }
    .chat-bubble.other { background: var(--color-surface); border: 1px solid var(--color-border-light); border-bottom-left-radius: 4px; color: var(--color-label-1); }
    .chat-bubble.mine { background: var(--color-green); color: #fff; border-bottom-right-radius: 4px; }
    .chat-bubble-time { font-size: 10px; color: var(--color-label-3); margin-top: 3px; text-align: right; }
    .chat-input-bar { padding: 12px 20px; border-top: 1px solid var(--color-border-light); background: var(--color-surface); display: flex; gap: 10px; align-items: flex-end; }
    .chat-input {
        flex: 1;
        border: 1.5px solid var(--color-border);
        border-radius: var(--radius-full);
        padding: 10px 18px;
        font-size: 14px;
        font-family: inherit;
        background: var(--color-bg);
        color: var(--color-label-1);
        resize: none;
        outline: none;
        line-height: 1.4;
        max-height: 120px;
        transition: border-color 0.2s;
    }
    .chat-input:focus { border-color: var(--color-green); }
    .chat-send-btn {
        width: 42px; height: 42px; border-radius: 50%;
        background: var(--color-green);
        color: #fff;
        border: none;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        transition: background 0.2s, transform 0.15s;
    }
    .chat-send-btn:hover { opacity: 0.9; transform: scale(1.05); }
    .chat-send-btn:disabled { opacity: 0.5; cursor: default; transform: none; }
    .chat-empty {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 14px;
        text-align: center;
        padding: 48px 32px;
        background: linear-gradient(180deg, var(--ud-surface) 0%, var(--ud-white) 45%);
    }
    .chat-empty-icon {
        width: 88px;
        height: 88px;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(86,36,208,0.12), rgba(164,53,240,0.1));
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .chat-empty svg { color: var(--ud-purple); opacity: 0.85; }
    .chat-empty h3 { font-size: 1.15rem; font-weight: 800; color: var(--ud-text); margin: 0; letter-spacing: -0.02em; }
    .chat-empty p { font-size: 0.9rem; color: var(--ud-text-muted); margin: 0; max-width: 320px; line-height: 1.55; }
    @@media (max-width: 768px) {
        .chat-wrapper { flex-direction: column; height: auto; min-height: 520px; }
        .chat-sidebar { max-width: none; width: 100%; border-right: none; border-bottom: 1px solid var(--ud-border-light); max-height: 280px; }
    }
</style>

<div class="chat-page">
    <h1 class="chat-page-title">Tin nhắn</h1>
    <p class="chat-page-sub">Trao đổi với giảng viên theo từng khóa học bạn đã đăng ký.</p>

    <div class="chat-wrapper">
        <aside class="chat-sidebar">
            <div class="chat-sidebar-header">💬 Tin nhắn với giảng viên</div>
            <div class="chat-conv-list">
                @if (Model.Conversations.Any())
                {
                    <div class="chat-new-section">@Model.Conversations.Count cuộc trò chuyện</div>
                    @foreach (var conv in Model.Conversations)
                    {
                        var isActive = Model.ActiveConversationId == conv.ConversationId;
                        <a class="chat-conv-item @(isActive ? "active" : "")"
                           href="/Student/Chat?conversationId=@conv.ConversationId">
                            <div class="chat-conv-avatar">@conv.OtherUserName[0]</div>
                            <div class="chat-conv-info">
                                <div class="chat-conv-name">@conv.OtherUserName</div>
                                <div class="chat-conv-course">@conv.CourseTitle</div>
                                @if (!string.IsNullOrEmpty(conv.LastMessage))
                                {
                                    <div class="chat-conv-last">@conv.LastMessage</div>
                                }
                            </div>
                            @if (conv.UnreadCount > 0)
                            {
                                <span class="chat-unread">@conv.UnreadCount</span>
                            }
                        </a>
                    }
                }

                @{
                    var newTeachers = Model.AvailableTeachers
                        .Where(t => !Model.Conversations.Any(c => c.OtherUserId == t.OtherUserId && c.CourseId == t.CourseId))
                        .ToList();
                }
                @if (newTeachers.Any())
                {
                    <div class="chat-new-section">Nhắn tin mới</div>
                    @foreach (var t in newTeachers)
                    {
                        <form method="post" asp-page-handler="Start" style="margin:0">
                            <input type="hidden" name="teacherId" value="@t.OtherUserId" />
                            <input type="hidden" name="courseId" value="@t.CourseId" />
                            <button type="submit" class="chat-new-btn">
                                <div class="chat-conv-avatar">@t.OtherUserName[0]</div>
                                <div>
                                    <div class="chat-new-btn-name">@t.OtherUserName</div>
                                    <div class="chat-new-btn-course">@t.CourseTitle</div>
                                </div>
                            </button>
                        </form>
                    }
                }

                @if (!Model.Conversations.Any() && !newTeachers.Any())
                {
                    <div class="chat-sidebar-empty">
                        Hãy đăng ký khóa học để bắt đầu nhắn tin với giảng viên. Danh sách cuộc trò chuyện sẽ hiện ở đây.
                    </div>
                }
            </div>
        </aside>

        <main class="chat-main">
            @if (Model.ActiveConversationId.HasValue)
            {
                <div class="chat-main-header">
                    <div class="chat-conv-avatar">@(Model.ActiveOtherUserName?[0] ?? '?')</div>
                    <div class="chat-main-header-info">
                        <h3>@Model.ActiveOtherUserName</h3>
                        <p>@Model.ActiveCourseTitle</p>
                    </div>
                </div>

                <div class="chat-messages" id="chatMessages">
                    @foreach (var msg in Model.Messages)
                    {
                        var isMine = msg.SenderId == Model.CurrentUserId;
                        <div class="chat-bubble-wrap @(isMine ? "mine" : "")">
                            <div class="chat-bubble-avatar @(isMine ? "mine" : "")">@msg.SenderName[0]</div>
                            <div>
                                <div class="chat-bubble @(isMine ? "mine" : "other")">@msg.Content</div>
                                <div class="chat-bubble-time">@msg.SentAt.ToLocalTime().ToString("HH:mm")</div>
                            </div>
                        </div>
                    }
                </div>

                <div class="chat-input-bar">
                    <textarea id="chatInput" class="chat-input" rows="1"
                              placeholder="Nhắn tin cho giảng viên..." maxlength="2000"
                              onkeydown="handleKey(event)"></textarea>
                    <button class="chat-send-btn" id="sendBtn" onclick="sendMessage()" title="Gửi" type="button">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="22" y1="2" x2="11" y2="13" />
                            <polygon points="22 2 15 22 11 13 2 9 22 2" />
                        </svg>
                    </button>
                </div>
            }
            else
            {
                <div class="chat-empty">
                    <div class="chat-empty-icon">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                        </svg>
                    </div>
                    <h3>Chọn cuộc trò chuyện</h3>
                    <p>Chọn một cuộc trò chuyện bên trái hoặc bắt đầu tin nhắn mới với giảng viên.</p>
                </div>
            }
        </main>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
(function () {
    const conversationId = '@Model.ActiveConversationId';
    const currentUserId  = '@Model.CurrentUserId';
    if (!conversationId) return;

    function scrollBottom() {
        const box = document.getElementById('chatMessages');
        if (box) box.scrollTop = box.scrollHeight;
    }
    scrollBottom();

    const input = document.getElementById('chatInput');
    input?.addEventListener('input', function () {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 120) + 'px';
    });

    window.handleKey = function (e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    };

    const conn = new signalR.HubConnectionBuilder()
        .withUrl('/hubs/chat')
        .withAutomaticReconnect()
        .build();

    conn.on('ReceiveMessage', function (data) {
        appendMessage(data);
        scrollBottom();
        if (data.senderId !== currentUserId) {
            conn.invoke('MarkRead', conversationId).catch(() => {});
        }
    });

    conn.start().then(() => {
        conn.invoke('JoinConversation', conversationId).catch(console.error);
    }).catch(console.error);

    window.addEventListener('beforeunload', () => {
        if (conn.state === signalR.HubConnectionState.Connected)
            conn.invoke('LeaveConversation', conversationId).catch(() => {});
    });

    function appendMessage(data) {
        const box = document.getElementById('chatMessages');
        if (!box) return;
        const isMine = data.senderId === currentUserId;
        const time = new Date(data.sentAt).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });

        const wrap = document.createElement('div');
        wrap.className = 'chat-bubble-wrap' + (isMine ? ' mine' : '');
        wrap.innerHTML = `
            <div class="chat-bubble-avatar ${isMine ? 'mine' : ''}">${data.senderName[0]}</div>
            <div>
                <div class="chat-bubble ${isMine ? 'mine' : 'other'}">${escHtml(data.content)}</div>
                <div class="chat-bubble-time">${time}</div>
            </div>`;
        box.appendChild(wrap);
    }

    function escHtml(str) {
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    window.sendMessage = function () {
        const txt = input?.value?.trim();
        if (!txt) return;
        const btn = document.getElementById('sendBtn');
        btn.disabled = true;
        conn.invoke('SendMessage', conversationId, txt)
            .then(() => { input.value = ''; input.style.height = 'auto'; })
            .catch(console.error)
            .finally(() => { btn.disabled = false; input.focus(); });
    };
})();
</script>
}
