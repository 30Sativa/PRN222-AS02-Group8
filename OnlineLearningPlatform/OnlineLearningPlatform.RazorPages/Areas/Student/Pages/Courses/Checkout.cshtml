@page "{id:guid}"
@model OnlineLearningPlatform.RazorPages.Areas.Student.Pages.Courses.CheckoutModel
@{
    ViewData["Title"] = "Thanh toán";
}

<style>
    .co-page { background: var(--ud-surface); min-height: 100vh; padding-bottom: 3rem; }
    .co-inner { max-width: 1180px; margin: 0 auto; padding: 1.5rem 1rem 3rem; }

    /* Breadcrumb */
    .co-breadcrumb { display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; font-size: .82rem; font-weight: 600; color: var(--ud-text-muted); margin-bottom: 1.5rem; }
    .co-breadcrumb a { color: var(--ud-magenta) !important; text-decoration: none !important; }
    .co-breadcrumb a:hover { text-decoration: underline !important; }
    .co-breadcrumb span { color: var(--ud-text-muted); }
    .co-breadcrumb .sep { color: var(--ud-border); }

    /* Title */
    .co-title { font-size: clamp(1.45rem, 3vw, 1.85rem); font-weight: 800; letter-spacing: -0.02em; color: var(--ud-text); margin-bottom: 1.5rem; }

    /* Layout */
    .co-layout { display: flex; flex-direction: column; gap: 1.5rem; }
    .co-main { flex: 1; min-width: 0; }
    .co-aside { flex: 0 0 360px; width: 360px; }
    @@media (min-width: 992px) {
        .co-layout { flex-direction: row; align-items: flex-start; gap: 2rem; }
        .co-main { flex: 1 1 0; max-width: calc(100% - 380px); }
        .co-aside { flex: 0 0 360px; width: 360px; }
        .co-sticky { position: sticky; top: 4.75rem; }
    }

    /* Card */
    .co-card { background: #fff; border: 1px solid var(--ud-border); border-radius: var(--ud-radius); padding: 1.15rem 1.25rem; margin-bottom: 1rem; box-shadow: var(--ud-shadow-sm); }
    .co-card-title { font-size: .95rem; font-weight: 800; text-transform: uppercase; letter-spacing: .05em; color: var(--ud-text-muted); margin-bottom: .85rem; }
    .co-card-title a { color: var(--ud-magenta) !important; font-weight: 700; font-size: .82rem; text-transform: none; letter-spacing: 0; }

    /* Course row */
    .co-course { display: flex; gap: 1rem; align-items: flex-start; }
    .co-course-thumb { width: 128px; height: 72px; object-fit: cover; border-radius: var(--ud-radius); background: #1c1d1f; flex-shrink: 0; }
    .co-course-info { flex: 1; min-width: 0; }
    .co-course-title { font-size: .95rem; font-weight: 700; line-height: 1.35; margin-bottom: .3rem; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; color: var(--ud-text); }
    .co-course-teacher { font-size: .78rem; color: var(--ud-text-muted); }

    /* Coupon */
    .co-coupon-row { display: flex; gap: .5rem; align-items: stretch; }
    .co-coupon-in { flex: 1; display: flex; }
    .co-coupon-in input { border-radius: var(--ud-radius) 0 0 var(--ud-radius); }
    .co-coupon-btn { border-radius: 0 var(--ud-radius) var(--ud-radius) 0; padding: 0 .85rem; font-size: .82rem; font-weight: 800; border: 1px solid var(--ud-border); border-left: none; background: #f7f9fa; color: var(--ud-text); cursor: pointer; white-space: nowrap; transition: background .15s; }
    .co-coupon-btn:hover { background: #eee; }
    .co-applied-coupon { display: flex; align-items: center; justify-content: space-between; padding: .5rem .75rem; border-radius: var(--ud-radius); background: var(--ud-green-bg); border: 1px solid rgba(21,115,71,.2); font-size: .85rem; font-weight: 600; color: var(--ud-green); }
    .co-applied-coupon .remove { font-size: .75rem; color: var(--ud-green); font-weight: 700; text-decoration: underline; background: none; border: none; cursor: pointer; }

    /* Refund */
    .co-refund { font-size: .8rem; color: var(--ud-text-muted); line-height: 1.5; }
    .co-check-row { display: flex; align-items: flex-start; gap: .6rem; font-size: .88rem; }
    .co-check-row input { width: 1.1rem; height: 1.1rem; margin-top: .2rem; flex-shrink: 0; accent-color: var(--ud-magenta); }
    .co-check-row label { line-height: 1.5; color: var(--ud-text); cursor: pointer; }

    /* Wallet */
    .co-wallet { display: flex; align-items: center; justify-content: space-between; padding: .65rem .85rem; border-radius: var(--ud-radius); background: rgba(86,36,208,.05); border: 1px solid rgba(86,36,208,.14); font-size: .85rem; }
    .co-wallet-info { font-weight: 700; color: var(--ud-text); }
    .co-wallet-info .bal { color: var(--ud-purple); font-weight: 800; }

    /* Summary card */
    .co-summary { background: #fff; border: 1px solid var(--ud-border); border-radius: var(--ud-radius); overflow: hidden; box-shadow: var(--ud-shadow-sm); }
    .co-summary-head { padding: .85rem 1.25rem; font-weight: 800; font-size: .82rem; text-transform: uppercase; letter-spacing: .06em; color: var(--ud-text-muted); border-bottom: 1px solid var(--ud-border); background: #fafafa; }
    .co-summary-body { padding: 1rem 1.25rem; }
    .co-summary-thumb { width: 100%; height: 160px; object-fit: cover; border-radius: var(--ud-radius) var(--ud-radius) 0 0; margin: -1rem -1px 1rem; display: block; background: #1c1d1f; }
    .co-sum-row { display: flex; justify-content: space-between; align-items: baseline; gap: .75rem; margin-bottom: .45rem; font-size: .9rem; }
    .co-sum-row .lbl { color: var(--ud-text-muted); }
    .co-sum-row .val { font-weight: 600; }
    .co-sum-row .val.green { color: var(--ud-green); }
    .co-sum-total { margin-top: .85rem; padding-top: .85rem; border-top: 1px solid var(--ud-border); }
    .co-sum-total .lbl { font-size: .72rem; font-weight: 800; text-transform: uppercase; letter-spacing: .06em; color: var(--ud-text-muted); display: block; margin-bottom: .2rem; }
    .co-sum-total .val { font-size: 1.6rem; font-weight: 800; letter-spacing: -0.02em; color: var(--ud-text); }
    .co-btn-pay { width: 100%; padding: .8rem 1rem; font-size: .95rem; font-weight: 800; border: none; border-radius: var(--ud-radius); background: var(--ud-magenta); color: #fff; cursor: pointer; transition: background .15s, transform .1s; box-shadow: 0 2px 8px rgba(164,53,240,.32); margin-top: 1rem; }
    .co-btn-pay:hover { background: var(--ud-magenta-dk); color: #fff; }
    .co-btn-pay:active { transform: scale(.995); }
    .co-trust { font-size: .75rem; color: var(--ud-text-muted); line-height: 1.5; margin-top: .85rem; text-align: center; }
    .co-secure { display: flex; align-items: center; justify-content: center; gap: .4rem; font-size: .75rem; color: var(--ud-text-muted); margin-top: .65rem; }
</style>

<div class="co-page">
    <div class="co-inner">
        <!-- Breadcrumb -->
        <nav class="co-breadcrumb" aria-label="breadcrumb">
            <a asp-area="Student" asp-page="/Cart/Index">Giỏ hàng</a>
            <span class="sep">›</span>
            <span>Thanh toán</span>
        </nav>

        <h1 class="co-title">Thanh toán</h1>

        @if (TempData["Message"] is string msg)
        {
            <div class="alert alert-danger" style="margin-bottom:1rem;border-radius:var(--ud-radius);">@msg</div>
        }

        <div class="co-layout">
            <div class="co-main">
                <!-- Course info -->
                <div class="co-card">
                    <div class="co-card-title">Khóa học đã chọn</div>
                    <div class="co-course">
                        @if (!string.IsNullOrEmpty(Model.Course.ThumbnailUrl))
                        {
                            <img class="co-course-thumb" src="@Model.Course.ThumbnailUrl" alt="" />
                        }
                        else
                        {
                            <div class="co-course-thumb" style="display:flex;align-items:center;justify-content:center;">
                                <i class="bi bi-image" style="font-size:1.5rem;color:#fff;"></i>
                            </div>
                        }
                        <div class="co-course-info">
                            <div class="co-course-title">@Model.Course.Title</div>
                            <div class="co-course-teacher">Giảng viên: @Model.Course.TeacherName</div>
                        </div>
                    </div>
                </div>

                <!-- Coupon -->
                <div class="co-card">
                    <div class="co-card-title">Mã khuyến mãi</div>
                    @if (Model.CouponApplied && !string.IsNullOrWhiteSpace(Model.CouponCode))
                    {
                        <div class="co-applied-coupon">
                            <span><i class="bi bi-tag me-1"></i> @Model.CouponCode (−@Model.CouponDiscount.ToString("N0") ₫)</span>
                        </div>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="ApplyCoupon" asp-route-id="@Model.Course.CourseId" class="co-coupon-row" style="margin:0;">
                            <div class="co-coupon-in" style="flex:1;">
                                <input asp-for="CouponCode" class="form-control" placeholder="Nhập mã khuyến mãi..." style="border-radius:var(--ud-radius);" />
                                <button type="submit" class="co-coupon-btn">Áp dụng</button>
                            </div>
                        </form>
                    }
                    @if (!string.IsNullOrEmpty(Model.CouponMessage))
                    {
                        <div style="font-size:.82rem;margin-top:.5rem;color:@(Model.CouponApplied ? "var(--ud-green)" : "var(--ud-red)");">@Model.CouponMessage</div>
                    }
                </div>

                <!-- Wallet (hiển thị số dư; bật/tắt trừ ví trong form thanh toán bên dưới) -->
                @if (Model.WalletBalance > 0 && Model.Course.Price > 0)
                {
                    <div class="co-card">
                        <div class="co-card-title">Ví EduLearn</div>
                        <div class="co-wallet">
                            <div class="co-wallet-info">
                                <i class="bi bi-wallet2 me-1"></i> Số dư: <span class="bal">@Model.WalletBalance.ToString("N0") ₫</span>
                            </div>
                        </div>
                    </div>
                }

                <!-- Refund policy + thanh toán -->
                <div class="co-card">
                    <div class="co-card-title">Chính sách hoàn tiền</div>
                    <details class="co-refund">
                        <summary style="cursor:pointer;font-weight:700;color:var(--ud-text);margin-bottom:.4rem;">Xem chính sách hoàn tiền</summary>
                        EduLearn đảm bảo hoàn tiền 100% trong vòng 7 ngày nếu khóa học không đáp ứng kỳ vọng của bạn.
                    </details>
                    <form method="post" asp-route-id="@Model.Course.CourseId" id="checkout-pay-form" style="margin:1.25rem 0 0;">
                        @if (Model.CouponApplied && !string.IsNullOrWhiteSpace(Model.CouponCode))
                        {
                            <input type="hidden" asp-for="CouponCode" />
                        }
                        @if (Model.WalletBalance > 0 && Model.Course.Price > 0)
                        {
                            <div class="co-check-row" style="margin-bottom:.85rem;">
                                <input asp-for="UseWallet" />
                                <label asp-for="UseWallet">Trừ từ ví (tối đa @Math.Min(Model.WalletBalance, Math.Max(0, Model.FinalPrice)).ToString("N0") ₫)</label>
                            </div>
                        }
                        <div class="co-check-row" style="margin-bottom:.85rem;">
                            <input asp-for="AgreeRefundPolicy" />
                            <label asp-for="AgreeRefundPolicy">Tôi đồng ý với chính sách hoàn tiền 7 ngày và điều khoản sử dụng của EduLearn.</label>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.RefundPolicyError))
                        {
                            <div class="text-danger small mb-2">@Model.RefundPolicyError</div>
                        }
                        <button type="submit" class="co-btn-pay" style="width:100%;">
                            @(Model.FinalPrice <= 0 ? "Hoàn tất đăng ký" : "Thanh toán ngay")
                        </button>
                    </form>
                </div>
            </div>

            <!-- Sidebar summary -->
            <aside class="co-aside">
                <div class="co-summary co-sticky">
                    <div class="co-summary-head">Tóm tắt đơn hàng</div>
                    <div class="co-summary-body">
                        @if (!string.IsNullOrEmpty(Model.Course.ThumbnailUrl))
                        {
                            <img class="co-summary-thumb" src="@Model.Course.ThumbnailUrl" alt="" />
                        }
                        else
                        {
                            <div class="co-summary-thumb" style="display:flex;align-items:center;justify-content:center;">
                                <i class="bi bi-image" style="font-size:2.5rem;color:#6a6f73;"></i>
                            </div>
                        }

                        <div class="co-sum-row">
                            <span class="lbl">Giá gốc</span>
                            <span class="val">@Model.Course.Price.ToString("N0") ₫</span>
                        </div>
                        @if (Model.Course.DiscountPrice.HasValue && Model.Course.DiscountPrice < Model.Course.Price)
                        {
                            <div class="co-sum-row">
                                <span class="lbl">Giảm giá</span>
                                <span class="val green">−@((Model.Course.Price - Model.Course.DiscountPrice.Value).ToString("N0")) ₫</span>
                            </div>
                        }
                        @if (Model.CouponApplied && Model.CouponDiscount > 0)
                        {
                            <div class="co-sum-row">
                                <span class="lbl">Mã: @(Model.CouponCode ?? "")</span>
                                <span class="val green">−@Model.CouponDiscount.ToString("N0") ₫</span>
                            </div>
                        }
                        @if (Model.UseWallet && Model.WalletBalance > 0 && Model.WalletDeduction > 0)
                        {
                            <div class="co-sum-row">
                                <span class="lbl">Trừ ví</span>
                                <span class="val green">−@Model.WalletDeduction.ToString("N0") ₫</span>
                            </div>
                        }
                        <div class="co-sum-total">
                            <span class="lbl">Tổng thanh toán</span>
                            <span class="val">@(Model.FinalPrice > 0 ? Model.FinalPrice.ToString("N0") + " ₫" : "Miễn phí")</span>
                        </div>
                        @if (Model.FinalPrice > 0 && Model.UseWallet && Model.WalletBalance > 0 && Model.WalletDeduction > 0)
                        {
                            <div style="font-size:.75rem;color:var(--ud-text-muted);margin-top:.4rem;text-align:center;">
                                Phần còn lại qua VNPAY (ước tính): <strong>@Math.Max(0, Model.FinalPrice - Model.WalletDeduction).ToString("N0") ₫</strong>
                            </div>
                        }

                        <button type="submit" form="checkout-pay-form" class="co-btn-pay">
                            @(Model.FinalPrice <= 0 ? "Hoàn tất đăng ký" : "Thanh toán ngay")
                        </button>
                        <div class="co-secure">
                            <i class="bi bi-lock-fill"></i>
                            Thanh toán an toàn &amp; bảo mật
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </div>
</div>
