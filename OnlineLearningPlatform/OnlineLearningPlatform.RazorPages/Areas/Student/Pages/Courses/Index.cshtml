@page
@model OnlineLearningPlatform.RazorPages.Areas.Student.Pages.Courses.IndexModel
@{
    ViewData["Title"] = "Khám phá khóa học";
}

<!-- Page header -->
<div class="ud-page-wide">
    <div class="ud-page-head ud-fade-up">
        <h1>Khám phá khóa học</h1>
        <p>Tìm kiếm và đăng ký các khóa học chất lượng từ nhiều chuyên gia.</p>
    </div>

    <!-- Search bar -->
    <div class="ud-search ud-fade-up">
        <form method="get" class="ud-flex" style="flex:1;gap:0.65rem;flex-wrap:wrap;align-items:center;">
            <div class="ud-search-wrap" style="flex:1;min-width:200px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <input asp-for="SearchRequest.Keyword" placeholder="Bạn muốn học gì hôm nay?" autocomplete="off" />
            </div>
            <button type="submit" class="btn btn-primary btn-sm">Tìm kiếm</button>
            @if (!string.IsNullOrEmpty(Model.SearchRequest.Keyword))
            {
                <a asp-page="./Index" asp-area="Student" class="btn btn-outline btn-sm">✕ Xóa</a>
            }
        </form>
    </div>

    <!-- Course grid -->
    <div class="ud-grid ud-grid-auto ud-fade-up">
        @if (!Model.Courses.Any())
        {
            <div class="ud-empty">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="3" width="20" height="14" rx="2"/>
                    <line x1="8" y1="21" x2="16" y2="21"/>
                    <line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
                @if (!string.IsNullOrEmpty(Model.SearchRequest.Keyword))
                {
                    <h3>Không tìm thấy kết quả</h3>
                    <p>Không có khóa học nào khớp với "<strong>@Model.SearchRequest.Keyword</strong>". Thử từ khóa khác.</p>
                }
                else
                {
                    <h3>Chưa có khóa học nào</h3>
                    <p>Hiện chưa có khóa học nào được xuất bản. Hãy quay lại sau nhé!</p>
                }
            </div>
        }
        else
        {
            @foreach (var course in Model.Courses)
            {
                <a asp-page="./Details" asp-route-id="@course.CourseId" class="ud-course-card">
                    <!-- Thumbnail -->
                    <div class="ud-course-thumb">
                        @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                        {
                            <img src="@course.ThumbnailUrl" alt="@course.Title" loading="lazy" />
                        }
                        else
                        {
                            <div class="ud-course-thumb-placeholder">📚</div>
                        }
                        @if (course.IsEnrolled)
                        {
                            <span class="ud-course-badge-enrolled">
                                <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                    <polyline points="20 6 9 17 4 12"/>
                                </svg>
                                Đã mua
                            </span>
                        }
                    </div>

                    <!-- Body -->
                    <div class="ud-course-body">
                        <div class="ud-course-cat">@course.CategoryName</div>
                        <div class="ud-course-title" title="@course.Title">@course.Title</div>
                        <div class="ud-course-instructor">@course.TeacherName</div>

                        <div class="ud-course-meta">
                            @if (course.DiscountPrice.HasValue && course.DiscountPrice < course.Price)
                            {
                                <span class="ud-price">@course.DiscountPrice.Value.ToString("N0") ₫</span>
                                <span class="ud-price-old">@course.Price.ToString("N0") ₫</span>
                            }
                            else if (course.Price == 0)
                            {
                                <span class="ud-price ud-price-free">Miễn phí</span>
                            }
                            else
                            {
                                <span class="ud-price">@course.Price.ToString("N0") ₫</span>
                            }

                            @if (course.IsEnrolled)
                            {
                                <span class="ud-badge-enrolled">
                                    <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                        <polyline points="20 6 9 17 4 12"/>
                                    </svg>
                                    Đã đăng ký
                                </span>
                            }
                        </div>
                    </div>
                </a>
            }
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav class="ud-pagination" aria-label="Phân trang">
            <ul>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li>
                        @if (i == Model.SearchRequest.PageNumber)
                        {
                            <span class="active">@i</span>
                        }
                        else
                        {
                            <a asp-page="./Index"
                               asp-route-SearchRequest.Keyword="@Model.SearchRequest.Keyword"
                               asp-route-SearchRequest.PageNumber="@i">@i</a>
                        }
                    </li>
                }
            </ul>
        </nav>
    }
</div>
