@page
@model OnlineLearningPlatform.RazorPages.Areas.Student.Pages.Courses.IndexModel
@{
    ViewData["Title"] = "Khám phá khóa học";
}

<style>
/* ── Page header ── */
.courses-head {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: var(--space-4); margin-bottom: var(--space-6); flex-wrap: wrap;
}
.courses-head-left h1 { margin-bottom: 4px; }
.courses-head-left p  { font-size: var(--text-sm); color: var(--color-label-2); }

/* ── Search bar ── */
.courses-filter {
    display: flex; align-items: center; gap: var(--space-3);
    margin-bottom: var(--space-6); flex-wrap: wrap;
}
.courses-filter .search-wrap {
    flex: 1; min-width: 220px; max-width: 440px;
    display: flex; align-items: center;
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: var(--radius-full); padding: 0 var(--space-4);
    gap: var(--space-2); transition: border-color .2s, box-shadow .2s;
}
.courses-filter .search-wrap:focus-within {
    border-color: var(--color-blue);
    box-shadow: 0 0 0 3px rgba(0,113,227,.12);
}
.courses-filter .search-wrap svg { width: 14px; height: 14px; color: var(--color-label-3); flex-shrink: 0; }
.courses-filter .search-wrap input {
    border: none; background: transparent; font-family: inherit;
    font-size: var(--text-sm); color: var(--color-label-1);
    outline: none; padding: 9px 0; width: 100%;
}
.courses-filter .search-wrap input::placeholder { color: var(--color-label-3); }

/* ── Course card grid ── */
.courses-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-5);
}

/* ── Course card ── */
.course-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: box-shadow .22s ease, transform .22s ease, border-color .22s ease;
    display: flex; flex-direction: column;
    position: relative;
    text-decoration: none; color: inherit;
}
.course-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
    border-color: var(--color-border);
    text-decoration: none; color: inherit;
}

/* Thumbnail area */
.course-thumb {
    position: relative;
    aspect-ratio: 16/9;
    background: linear-gradient(135deg, #e8f0fb 0%, #f0eeff 100%);
    overflow: hidden;
    flex-shrink: 0;
}
.course-thumb img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform .3s ease;
}
.course-card:hover .course-thumb img { transform: scale(1.04); }
.course-thumb-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-size: 44px;
}

/* Enrolled badge on thumb */
.enrolled-ribbon {
    position: absolute; top: var(--space-3); left: var(--space-3);
    display: inline-flex; align-items: center; gap: 4px;
    padding: 4px 10px; border-radius: var(--radius-full);
    font-size: 11px; font-weight: 600;
    backdrop-filter: blur(8px);
    background: rgba(234,250,241,.9); color: #1a9e46;
}

/* Card body */
.course-card-body {
    padding: var(--space-4) var(--space-5); flex: 1; display: flex; flex-direction: column;
}
.course-card-cat {
    font-size: 10px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; color: var(--color-blue);
    margin-bottom: var(--space-2);
}
.course-card-title {
    font-size: var(--text-base); font-weight: 600; color: var(--color-label-1);
    letter-spacing: -.01em; line-height: 1.4;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden; margin-bottom: var(--space-2);
}
.course-card-instructor {
    font-size: var(--text-xs); color: var(--color-label-2);
    margin-bottom: 0;
}
.course-card-meta {
    display: flex; align-items: center; gap: var(--space-3);
    flex-wrap: wrap; margin-top: auto; padding-top: var(--space-4);
    border-top: 1px solid var(--color-border-light);
}
.meta-price {
    font-size: var(--text-sm); font-weight: 700;
    color: var(--color-label-1);
}
.meta-price.free { color: var(--color-green); }
.meta-price-original {
    font-size: var(--text-xs); color: var(--color-label-3);
    text-decoration: line-through; font-weight: 400;
    margin-left: var(--space-1);
}
.meta-enrolled-badge {
    margin-left: auto;
    display: inline-flex; align-items: center; gap: 4px;
    padding: 3px 8px; border-radius: var(--radius-full);
    font-size: 11px; font-weight: 600;
    background: rgba(52,199,89,.1); color: #1a9e46;
}

/* ── Empty state ── */
.empty-courses {
    grid-column: 1 / -1;
    padding: var(--space-16) var(--space-8);
    text-align: center; color: var(--color-label-2);
}
.empty-courses svg { margin: 0 auto var(--space-5); display: block; color: var(--color-label-3); }
.empty-courses h3 { font-size: var(--text-lg); font-weight: 700; color: var(--color-label-1); margin-bottom: var(--space-2); }
.empty-courses p  { font-size: var(--text-sm); }

/* ── Pagination ── */
.apple-pagination { margin-top: var(--space-8); }
.apple-pagination .page-link {
    border: 1px solid var(--color-border-light);
    color: var(--color-label-1);
    background: var(--color-surface);
    border-radius: var(--radius);
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 500; margin: 0 3px;
    transition: background-color .15s, border-color .15s;
    font-size: var(--text-sm);
}
.apple-pagination .page-link:hover {
    background: var(--color-surface-2);
    border-color: var(--color-border);
}
.apple-pagination .page-item.active .page-link {
    background: var(--color-blue);
    border-color: var(--color-blue);
    color: #fff;
}
</style>

<!-- Page header -->
<div class="courses-head fade-up">
    <div class="courses-head-left">
        <h1>Khám phá khóa học</h1>
        <p>Tìm kiếm và đăng ký các khóa học chất lượng từ nhiều chuyên gia.</p>
    </div>
</div>

<!-- Search bar -->
<div class="courses-filter fade-up">
    <form method="get" style="display:contents">
        <div class="search-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input asp-for="SearchRequest.Keyword" placeholder="Bạn muốn học gì hôm nay?" autocomplete="off" />
        </div>
        <button type="submit" class="btn btn-primary btn-sm">Tìm kiếm</button>
        @if (!string.IsNullOrEmpty(Model.SearchRequest.Keyword))
        {
            <a asp-page="./Index" asp-area="Student" class="btn btn-secondary btn-sm">✕ Xóa</a>
        }
    </form>
</div>

<!-- Course grid -->
<div class="courses-grid fade-up">
    @if (!Model.Courses.Any())
    {
        <div class="empty-courses">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
            @if (!string.IsNullOrEmpty(Model.SearchRequest.Keyword))
            {
                <h3>Không tìm thấy kết quả</h3>
                <p>Không có khóa học nào khớp với "<strong>@Model.SearchRequest.Keyword</strong>". Thử từ khóa khác.</p>
            }
            else
            {
                <h3>Chưa có khóa học nào</h3>
                <p>Hiện chưa có khóa học nào được xuất bản. Hãy quay lại sau nhé!</p>
            }
        </div>
    }
    else
    {
        @foreach (var course in Model.Courses)
        {
            <a asp-page="./Details" asp-route-id="@course.CourseId" class="course-card">
                <!-- Thumbnail -->
                <div class="course-thumb">
                    @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                    {
                        <img src="@course.ThumbnailUrl" alt="@course.Title" loading="lazy" />
                    }
                    else
                    {
                        <div class="course-thumb-placeholder">📚</div>
                    }
                    @if (course.IsEnrolled)
                    {
                        <span class="enrolled-ribbon">
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            Đã mua
                        </span>
                    }
                </div>

                <!-- Body -->
                <div class="course-card-body">
                    <div class="course-card-cat">@course.CategoryName</div>
                    <div class="course-card-title" title="@course.Title">@course.Title</div>
                    <div class="course-card-instructor">Dr. @course.TeacherName</div>

                    <div class="course-card-meta">
                        @if (course.DiscountPrice.HasValue && course.DiscountPrice < course.Price)
                        {
                            <span class="meta-price">@course.DiscountPrice.Value.ToString("N0") ₫</span>
                            <span class="meta-price-original">@course.Price.ToString("N0") ₫</span>
                        }
                        else if (course.Price == 0)
                        {
                            <span class="meta-price free">Miễn phí</span>
                        }
                        else
                        {
                            <span class="meta-price">@course.Price.ToString("N0") ₫</span>
                        }

                        @if (course.IsEnrolled)
                        {
                            <span class="meta-enrolled-badge">
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <polyline points="20 6 9 17 4 12"/>
                                </svg>
                                Đã đăng ký
                            </span>
                        }
                    </div>
                </div>
            </a>
        }
    }
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <nav class="apple-pagination d-flex justify-content-center mt-5">
        <ul class="pagination m-0">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.SearchRequest.PageNumber ? "active" : "")">
                    <a class="page-link"
                       asp-page="./Index"
                       asp-route-SearchRequest.Keyword="@Model.SearchRequest.Keyword"
                       asp-route-SearchRequest.PageNumber="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
