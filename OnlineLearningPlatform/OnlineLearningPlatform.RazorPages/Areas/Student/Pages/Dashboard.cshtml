@page
@model OnlineLearningPlatform.RazorPages.Areas.Student.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<style>
    /* Bo góc & khoảng cách riêng dashboard (site.css dùng --ud-radius 2px) */
    .student-dashboard {
        --dash-r: 14px;
        --dash-r-md: 16px;
        --dash-r-lg: 20px;
        --dash-r-xl: 24px;
        --dash-gap-stat: 1.25rem;
        --dash-gap-cols: 1.75rem;
    }

    .student-dashboard .ud-card {
        border-radius: var(--dash-r-lg);
        padding: var(--ud-sp5) var(--ud-sp6);
        box-sizing: border-box;
    }

    .student-dashboard .ud-empty {
        border-radius: var(--dash-r-lg);
        padding: var(--ud-sp10) var(--ud-sp8);
        margin-top: var(--ud-sp2);
    }

    .student-dashboard .ud-page-head {
        margin-bottom: var(--ud-sp5);
    }

    /* ── Welcome Banner ── */
    .dash-welcome {
        background: linear-gradient(135deg, var(--ud-purple) 0%, var(--ud-magenta) 100%);
        border-radius: var(--dash-r-xl);
        padding: var(--ud-sp8) clamp(var(--ud-sp6), 4vw, var(--ud-sp10));
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--ud-sp6);
        margin-bottom: var(--ud-sp8);
        overflow: hidden;
        position: relative;
    }
    .dash-welcome::before {
        content: '';
        position: absolute;
        top: -40px; right: -40px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,.08);
    }
    .dash-welcome::after {
        content: '';
        position: absolute;
        bottom: -60px; right: 80px;
        width: 150px; height: 150px;
        border-radius: 50%;
        background: rgba(255,255,255,.05);
    }
    .dash-welcome-text { position: relative; z-index: 1; }
    .dash-welcome-text h2 {
        font-size: clamp(1.2rem, 2.5vw, 1.5rem);
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.02em;
        margin-bottom: var(--ud-sp2);
    }
    .dash-welcome-text p {
        font-size: 0.875rem;
        color: rgba(255,255,255,.80);
    }
    .dash-welcome-actions {
        position: relative;
        z-index: 1;
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem 1rem;
        flex-shrink: 0;
    }
    .dash-btn-white {
        background: #fff;
        color: var(--ud-purple) !important;
        font-size: 0.8rem;
        font-weight: 700;
        border-radius: var(--ud-radius-pill);
        padding: 10px 20px;
        text-decoration: none !important;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: opacity var(--ud-ease);
        border: none;
        cursor: pointer;
    }
    .dash-btn-white:hover { opacity: .88; color: var(--ud-purple-dk); }
    .dash-btn-ghost {
        background: rgba(255,255,255,.18);
        color: #fff !important;
        border: 1px solid rgba(255,255,255,.30);
        backdrop-filter: blur(8px);
        font-size: 0.8rem;
        font-weight: 600;
        border-radius: var(--ud-radius-pill);
        padding: 10px 20px;
        text-decoration: none !important;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: background var(--ud-ease);
    }
    .dash-btn-ghost:hover { background: rgba(255,255,255,.28); color: #fff; }

    /* ── Stat Cards ── */
    .dash-stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--dash-gap-stat);
        margin-bottom: var(--ud-sp8);
    }
    .dash-stat-card {
        background: var(--ud-white);
        border: 1px solid var(--ud-border);
        border-radius: var(--dash-r-lg);
        padding: var(--ud-sp5) var(--ud-sp6);
        box-shadow: var(--ud-shadow-sm);
    }
    .dash-stat-icon {
        width: 42px; height: 42px;
        border-radius: var(--dash-r);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        margin-bottom: var(--ud-sp3);
    }
    .dash-stat-icon-blue   { background: rgba(0,113,227,.08); color: #0055b3; }
    .dash-stat-icon-green  { background: var(--ud-green-bg); color: var(--ud-green); }
    .dash-stat-icon-amber  { background: var(--ud-amber-bg); color: var(--ud-amber); }
    .dash-stat-icon-purple { background: rgba(86,36,208,.08); color: var(--ud-purple); }
    .dash-stat-label {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--ud-text-muted);
        margin-bottom: .25rem;
    }
    .dash-stat-value {
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--ud-text);
        line-height: 1;
        letter-spacing: -0.03em;
        margin-bottom: .25rem;
    }
    .dash-stat-sub {
        font-size: 0.72rem;
        color: var(--ud-text-muted);
    }

    /* ── Two-column section ── */
    .dash-two-col {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: var(--dash-gap-cols);
        align-items: flex-start;
    }
    .dash-section-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--ud-sp4);
        flex-wrap: wrap;
        margin-bottom: var(--ud-sp5);
        padding-bottom: var(--ud-sp5);
        border-bottom: 1px solid var(--ud-border);
    }
    .dash-section-head .btn {
        border-radius: var(--ud-radius-pill);
        flex-shrink: 0;
    }
    .dash-section-head h2 {
        font-size: 1rem;
        font-weight: 800;
        color: var(--ud-text);
        display: flex;
        align-items: center;
        gap: var(--ud-sp2);
    }
    .dash-section-head h2 i { color: var(--ud-purple); }

    /* ── Course mini cards ── */
    .dash-course-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: var(--ud-sp5);
        padding-top: var(--ud-sp2);
    }
    .dash-course-card {
        background: var(--ud-white);
        border: 1px solid var(--ud-border);
        border-radius: var(--dash-r-lg);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        box-shadow: var(--ud-shadow-sm);
        transition: box-shadow var(--ud-ease), transform var(--ud-ease);
    }
    .dash-course-card:hover { box-shadow: var(--ud-shadow-lg); transform: translateY(-2px); }
    .dash-course-thumb {
        height: 110px;
        background: #1c1d1f;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: #6a6f73;
        flex-shrink: 0;
    }
    .dash-course-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .dash-course-body {
        padding: var(--ud-sp4);
        flex: 1;
        display: flex;
        flex-direction: column;
    }
    .dash-course-title {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--ud-text);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: .25rem;
    }
    .dash-course-teacher {
        font-size: 0.72rem;
        color: var(--ud-text-muted);
        margin-bottom: var(--ud-sp3);
    }
    .dash-progress-track {
        background: var(--ud-border);
        border-radius: var(--ud-radius-pill);
        height: 4px;
        overflow: hidden;
        margin-bottom: .3rem;
    }
    .dash-progress-fill {
        height: 100%;
        border-radius: var(--ud-radius-pill);
        background: var(--ud-magenta);
        transition: width .4s ease;
    }
    .dash-progress-fill.done { background: var(--ud-green); }
    .dash-progress-info {
        display: flex;
        justify-content: space-between;
        font-size: 0.7rem;
        color: var(--ud-text-muted);
        margin-bottom: var(--ud-sp3);
    }
    .dash-progress-info .pct { font-weight: 700; color: var(--ud-magenta); }
    .dash-progress-info .pct.done { color: var(--ud-green); }
    .dash-btn-continue {
        display: block;
        text-align: center;
        padding: 9px 16px;
        border-radius: var(--ud-radius-pill);
        font-size: 0.78rem;
        font-weight: 700;
        text-decoration: none !important;
        transition: opacity var(--ud-ease);
        margin-top: auto;
    }
    .dash-btn-continue.blue {
        background: var(--ud-magenta);
        color: #fff !important;
    }
    .dash-btn-continue.green {
        background: var(--ud-green-bg);
        color: var(--ud-green) !important;
        border: 1px solid rgba(21,115,71,.2);
    }
    .dash-btn-continue:hover { opacity: .82; }

    /* ── Quick Access sidebar ── */
    .dash-quick-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem 1.1rem;
        padding-top: var(--ud-sp2);
    }
    .dash-quick-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: var(--ud-sp5) var(--ud-sp4);
        background: var(--ud-surface);
        border: 1px solid var(--ud-border);
        border-radius: var(--dash-r-lg);
        text-decoration: none !important;
        transition: border-color var(--ud-ease), box-shadow var(--ud-ease);
        gap: var(--ud-sp2);
    }
    .dash-quick-item:hover {
        border-color: var(--ud-purple);
        box-shadow: 0 0 0 2px rgba(86,36,208,.10);
    }
    .dash-quick-icon {
        width: 44px; height: 44px;
        border-radius: var(--dash-r-md);
        background: rgba(86,36,208,.08);
        color: var(--ud-purple);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }
    .dash-quick-icon.green { background: var(--ud-green-bg); color: var(--ud-green); }
    .dash-quick-title {
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--ud-text);
    }
    .dash-quick-desc {
        font-size: 0.68rem;
        color: var(--ud-text-muted);
    }

    /* ── Responsive ── */
    @@media (max-width: 1024px) {
        .dash-two-col { grid-template-columns: 1fr; }
    }
    @@media (max-width: 768px) {
        .dash-welcome { flex-direction: column; padding: var(--ud-sp6); align-items: stretch; }
        .dash-welcome-actions { flex-wrap: wrap; justify-content: flex-start; }
        .dash-stat-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
        .dash-quick-grid { grid-template-columns: repeat(2, 1fr); gap: 0.9rem 1rem; }
    }
    @@media (max-width: 480px) {
        .dash-stat-grid { grid-template-columns: 1fr; }
    }
</style>

@* ── PAGE WRAPPER ── *@
<div class="ud-page-wide student-dashboard">

    @* ── PAGE HEADER ── *@
    <div class="ud-page-head ud-fade-up">
        <h1>Dashboard</h1>
        <p>Học viên &rarr; Tổng quan</p>
    </div>

    @* ── WELCOME BANNER ── *@
    <div class="dash-welcome ud-fade-up" style="animation-delay:.05s">
        <div class="dash-welcome-text">
            <h2>Xin chào, @(Model.UserInfo?.FullName ?? "Bạn")!</h2>
            <p>Tiếp tục hành trình học tập — mỗi bài học đưa bạn đến gần mục tiêu hơn.</p>
        </div>
        <div class="dash-welcome-actions">
            <a asp-area="Student" asp-page="/MyLearning" class="dash-btn-white">
                @Html.Raw("<i class=\"bi bi-book\"></i>")
                Khóa học của tôi
            </a>
            <a asp-area="Student" asp-page="/Profile" class="dash-btn-ghost">
                @Html.Raw("<i class=\"bi bi-person\"></i>")
                Hồ sơ
            </a>
        </div>
    </div>

    @* ── STAT CARDS ── *@
    <div class="dash-stat-grid ud-fade-up" style="animation-delay:.10s">

        <div class="dash-stat-card">
            <div class="dash-stat-icon dash-stat-icon-blue">
                @Html.Raw("<i class=\"bi bi-journal-bookmark\"></i>")
            </div>
            <div class="dash-stat-label">Khóa đã đăng ký</div>
            <div class="dash-stat-value">@Model.TotalEnrolled</div>
            <div class="dash-stat-sub">Tổng khóa học</div>
        </div>

        <div class="dash-stat-card">
            <div class="dash-stat-icon dash-stat-icon-green">
                @Html.Raw("<i class=\"bi bi-check-circle\"></i>")
            </div>
            <div class="dash-stat-label">Đã hoàn thành</div>
            <div class="dash-stat-value">@Model.CompletedCourses</div>
            <div class="dash-stat-sub">Hoàn thành 100%</div>
        </div>

        <div class="dash-stat-card">
            <div class="dash-stat-icon dash-stat-icon-amber">
                @Html.Raw("<i class=\"bi bi-lightning-charge\"></i>")
            </div>
            <div class="dash-stat-label">Đang học</div>
            <div class="dash-stat-value">@Model.InProgressCourses</div>
            <div class="dash-stat-sub">Tiến độ &gt; 0%</div>
        </div>

        <div class="dash-stat-card">
            <div class="dash-stat-icon dash-stat-icon-purple">
                @Html.Raw("<i class=\"bi bi-patch-check\"></i>")
            </div>
            <div class="dash-stat-label">Chứng chỉ</div>
            <div class="dash-stat-value">@Model.CompletedCourses</div>
            <div class="dash-stat-sub">Đã nhận được</div>
        </div>

    </div>

    @* ── TWO COLUMN: Recent courses + Quick Access ── *@
    <div class="dash-two-col ud-fade-up" style="animation-delay:.15s">

        @* Recent Courses *@
        <div class="ud-card">
            <div class="dash-section-head">
                <h2>
                    @Html.Raw("<i class=\"bi bi-play-circle\"></i>")
                    Tiếp tục học
                </h2>
                <a asp-area="Student" asp-page="/MyLearning" class="btn btn-sm btn-outline">
                    Xem tất cả
                </a>
            </div>

            @if (!Model.RecentCourses.Any())
            {
                <div class="ud-empty">
                    @Html.Raw("<i class=\"bi bi-book\" style=\"font-size:2.5rem\"></i>")
                    <h3>Chưa có khóa học nào</h3>
                    <p>Khám phá và đăng ký khóa học để bắt đầu học tập.</p>
                    <a asp-area="" asp-page="/Index" class="btn btn-primary btn-sm" style="margin-top:var(--ud-sp4);border-radius:var(--ud-radius-pill);">
                        @Html.Raw("<i class=\"bi bi-compass\"></i>")
                        Khám phá khóa học
                    </a>
                </div>
            }
            else
            {
                <div class="dash-course-grid" style="padding-bottom:var(--ud-sp2)">
                    @foreach (var item in Model.RecentCourses)
                    {
                        bool isDone = item.Progress?.IsCompleted ?? false;
                        int pct = (int)(item.Progress?.PercentComplete ?? 0);
                        string learnUrl = $"/Student/LearnCourse?courseId={item.CourseId}{(item.ResumeLessonId.HasValue ? $"&lessonId={item.ResumeLessonId}" : "")}";
                        <div class="dash-course-card">
                            @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                            {
                                <div class="dash-course-thumb">
                                    <img src="@item.ThumbnailUrl" alt="@item.Title" />
                                </div>
                            }
                            else
                            {
                                <div class="dash-course-thumb">
                                    @Html.Raw("<i class=\"bi bi-book\"></i>")
                                </div>
                            }
                            <div class="dash-course-body">
                                <div class="dash-course-title" title="@item.Title">@item.Title</div>
                                <div class="dash-course-teacher">@item.TeacherName</div>
                                <div class="dash-progress-track">
                                    <div class="dash-progress-fill @(isDone ? "done" : "")" style="width:@pct%"></div>
                                </div>
                                <div class="dash-progress-info">
                                    <span>@(item.Progress?.CompletedLessons ?? 0)/@(item.Progress?.TotalLessons ?? 0) bài</span>
                                    <span class="pct @(isDone ? "done" : "")">@pct%</span>
                                </div>
                                @if (isDone)
                                {
                                    <a href="@learnUrl" class="dash-btn-continue green">@Html.Raw("<i class=\"bi bi-arrow-repeat\"></i>") Xem lại</a>
                                }
                                else
                                {
                                    <a href="@learnUrl" class="dash-btn-continue blue">@Html.Raw("<i class=\"bi bi-play-fill\"></i>") Tiếp tục</a>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        @* Quick Access Sidebar *@
        <div class="ud-card">
            <div class="dash-section-head">
                <h2>
                    @Html.Raw("<i class=\"bi bi-grid-3x3-gap\"></i>")
                    Truy cập nhanh
                </h2>
            </div>
            <div style="padding-bottom:var(--ud-sp2)">
                <div class="dash-quick-grid">

                    <a asp-area="Student" asp-page="/MyLearning" class="dash-quick-item">
                        <div class="dash-quick-icon">
                            @Html.Raw("<i class=\"bi bi-journal-bookmark\"></i>")
                        </div>
                        <div class="dash-quick-title">Khóa học</div>
                        <div class="dash-quick-desc">Xem & tiếp tục</div>
                    </a>

                    <a asp-area="Student" asp-page="/Profile" class="dash-quick-item">
                        <div class="dash-quick-icon">
                            @Html.Raw("<i class=\"bi bi-person\"></i>")
                        </div>
                        <div class="dash-quick-title">Hồ sơ</div>
                        <div class="dash-quick-desc">Thông tin cá nhân</div>
                    </a>

                    <a asp-area="Student" asp-page="/EditProfile" class="dash-quick-item">
                        <div class="dash-quick-icon">
                            @Html.Raw("<i class=\"bi bi-pencil-square\"></i>")
                        </div>
                        <div class="dash-quick-title">Chỉnh sửa</div>
                        <div class="dash-quick-desc">Cập nhật hồ sơ</div>
                    </a>

                    <a asp-area="Student" asp-page="/Certificates/Index" class="dash-quick-item">
                        <div class="dash-quick-icon green">
                            @Html.Raw("<i class=\"bi bi-patch-check\"></i>")
                        </div>
                        <div class="dash-quick-title">Chứng chỉ</div>
                        <div class="dash-quick-desc">Xem tất cả</div>
                    </a>

                </div>
            </div>
        </div>

    </div>

</div>
