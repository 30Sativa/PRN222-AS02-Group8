@page
@model OnlineLearningPlatform.RazorPages.Areas.Student.Pages.Certificates.IndexModel
@{
    ViewData["Title"] = "Chứng chỉ của tôi";
}

<div class="ud-page">
    <div class="ud-page-head">
        <div class="ud-flex ud-align-center ud-justify-between ud-flex-wrap" style="gap: var(--ud-sp4);">
            <div>
                <h1>Chứng chỉ hoàn thành</h1>
                <p>Xem và tải chứng chỉ hoàn thành khóa học của bạn</p>
            </div>
            <span class="badge badge-green">@Model.Certificates.Count() chứng chỉ</span>
        </div>
    </div>

    @if (!Model.Certificates.Any())
    {
        <div class="ud-empty">
            <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="6"></circle>
                <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"></path>
            </svg>
            <h3>Bạn chưa có chứng chỉ nào</h3>
            <p>Hãy hoàn thành khóa học để nhận chứng chỉ nhé.</p>
            <div style="margin-top: var(--ud-sp5);">
                <a asp-area="Student" asp-page="/Courses/Index" class="btn btn-primary">Khám phá khóa học</a>
            </div>
        </div>
    }
    else
    {
        <div class="ud-grid" style="grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: var(--ud-sp6);">
            @foreach (var c in Model.Certificates)
            {
                <div class="ud-card ud-fade-up" style="padding: var(--ud-sp6);">
                    <div class="ud-flex" style="gap: var(--ud-sp4); margin-bottom: var(--ud-sp5);">
                        <div style="width: 52px; height: 52px; border-radius: var(--ud-radius); background: rgba(86,36,208,.08); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--ud-purple)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="8" r="6"></circle>
                                <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"></path>
                            </svg>
                        </div>
                        <div style="flex: 1; min-width: 0;">
                            <span class="badge badge-green" style="margin-bottom: var(--ud-sp2);">Hoàn thành</span>
                            <h3 style="font-size: 0.95rem; font-weight: 700; line-height: 1.4; color: var(--ud-text); margin: 0; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                                @c.CourseTitle
                            </h3>
                        </div>
                    </div>

                    <div style="margin-bottom: var(--ud-sp4); padding-bottom: var(--ud-sp4); border-bottom: 1px solid var(--ud-border-light);">
                        <p style="font-size: 0.82rem; color: var(--ud-text-muted); margin: 0 0 var(--ud-sp2);">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: inline-block; vertical-align: -2px; margin-right: 4px;">
                                <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                            Giảng viên: @c.TeacherName
                        </p>
                        <p style="font-size: 0.82rem; color: var(--ud-text-muted); margin: 0;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: inline-block; vertical-align: -2px; margin-right: 4px;">
                                <rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect>
                                <line x1="16" x2="16" y1="2" y2="6"></line>
                                <line x1="8" x2="8" y1="2" y2="6"></line>
                                <line x1="3" x2="21" y1="10" y2="10"></line>
                            </svg>
                            Ngày cấp: @c.IssuedAt.ToLocalTime().ToString("dd MMM yyyy", System.Globalization.CultureInfo.GetCultureInfo("vi-VN"))
                        </p>
                    </div>

                    <div class="ud-flex" style="gap: var(--ud-sp2); margin-bottom: var(--ud-sp4);">
                        <span class="badge badge-muted" style="font-family: monospace; letter-spacing: 0.5px;">@c.CertificateCode</span>
                    </div>

                    <div class="ud-flex" style="gap: var(--ud-sp2);">
                        <a asp-page-handler="View" asp-route-code="@c.CertificateCode" target="_blank" class="btn btn-outline" style="flex: 1;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                            Xem PDF
                        </a>
                        <a asp-page-handler="Download" asp-route-code="@c.CertificateCode" class="btn btn-primary" style="flex: 1;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                <polyline points="7 10 12 15 17 10"></polyline>
                                <line x1="12" x2="12" y1="15" y2="3"></line>
                            </svg>
                            Tải PDF
                        </a>
                        <button class="btn btn-ghost btn-icon" onclick="copyCode('@c.CertificateCode')" title="Sao chép mã chứng chỉ" style="flex: 0 0 auto;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
                                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
                            </svg>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        function copyCode(code) {
            navigator.clipboard.writeText(code).then(() => {
                var btn = event.currentTarget;
                var originalHTML = btn.innerHTML;
                btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--ud-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
                btn.style.background = 'rgba(21, 115, 71, .1)';
                setTimeout(function() {
                    btn.innerHTML = originalHTML;
                    btn.style.background = '';
                }, 1500);
            }).catch(function() {
                alert("Mã chứng chỉ: " + code);
            });
        }
    </script>
}
