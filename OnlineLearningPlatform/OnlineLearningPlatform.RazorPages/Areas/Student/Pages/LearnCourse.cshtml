@page
@model OnlineLearningPlatform.RazorPages.Areas.Student.Pages.LearnCourseModel
@{
    ViewData["Title"] = Model.Course?.Title ?? "Học bài";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<style>
    .learn-wrapper {
        display: flex;
        gap: 0;
        min-height: calc(100vh - 140px);
        margin: -24px -32px;
    }

    .learn-sidebar {
        width: 340px;
        min-width: 300px;
        background: var(--ud-white);
        border-right: 1px solid var(--ud-border);
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

    .learn-sidebar-header {
        padding: var(--ud-sp5);
        border-bottom: 1px solid var(--ud-border);
    }

    .learn-sidebar-header h2 {
        font-size: 15px;
        font-weight: 800;
        color: var(--ud-text);
        margin: 0 0 var(--ud-sp3);
        line-height: 1.35;
    }

    .progress-bar-container {
        background: var(--ud-border);
        border-radius: var(--ud-radius-pill);
        height: 6px;
        overflow: hidden;
        margin-bottom: var(--ud-sp2);
    }

    .progress-bar-fill {
        background: linear-gradient(90deg, var(--ud-purple), var(--ud-magenta));
        height: 100%;
        border-radius: var(--ud-radius-pill);
        transition: width 0.5s ease;
    }

    .progress-text {
        font-size: 12px;
        color: var(--ud-text-muted);
        font-weight: 600;
    }

    .learn-sections {
        flex: 1;
        overflow-y: auto;
        padding: var(--ud-sp2) 0;
    }

    .learn-section {
        margin-bottom: var(--ud-sp1);
    }

    .learn-section-title {
        display: flex;
        align-items: center;
        gap: var(--ud-sp2);
        padding: var(--ud-sp3) var(--ud-sp5);
        font-size: 12px;
        font-weight: 700;
        color: var(--ud-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        cursor: pointer;
        user-select: none;
    }

    .learn-section-title:hover {
        color: var(--ud-text);
    }

    .learn-section-title .chevron {
        transition: transform 0.2s;
        font-size: 10px;
    }

    .learn-section.collapsed .chevron {
        transform: rotate(-90deg);
    }

    .learn-section.collapsed .learn-lesson-list {
        display: none;
    }

    .learn-lesson-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .learn-lesson-item {
        display: flex;
        align-items: center;
        gap: var(--ud-sp3);
        padding: var(--ud-sp3) var(--ud-sp5) var(--ud-sp3) var(--ud-sp8);
        font-size: 13px;
        color: var(--ud-text);
        cursor: pointer;
        text-decoration: none;
        transition: background 0.15s;
        border-left: 3px solid transparent;
    }

    .learn-lesson-item:hover {
        background: var(--ud-surface);
        text-decoration: none;
        color: var(--ud-text);
    }

    .learn-lesson-item.active {
        background: rgba(164, 53, 240, 0.08);
        border-left-color: var(--ud-magenta);
        font-weight: 700;
    }

    .learn-lesson-item .lesson-icon {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        flex-shrink: 0;
    }

    .lesson-icon.completed {
        background: var(--ud-green);
        color: #fff;
    }

    .lesson-icon.incomplete {
        border: 2px solid var(--ud-border);
        background: transparent;
        color: var(--ud-text-muted);
    }

    .learn-lesson-item .lesson-title {
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .lesson-type-badge {
        font-size: 10px;
        padding: 2px 6px;
        border-radius: var(--ud-radius);
        background: var(--ud-surface);
        color: var(--ud-text-muted);
        font-weight: 700;
        flex-shrink: 0;
        border: 1px solid var(--ud-border);
    }

    .learn-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: var(--ud-surface);
        overflow-y: auto;
    }

    .learn-content-inner {
        max-width: 900px;
        width: 100%;
        margin: 0 auto;
        padding: var(--ud-sp8) var(--ud-sp10);
    }

    .lesson-tabs {
        display: flex;
        gap: var(--ud-sp2);
        margin-bottom: var(--ud-sp6);
        border-bottom: none;
    }

    .lesson-tab {
        display: inline-flex;
        align-items: center;
        padding: var(--ud-sp2) var(--ud-sp5);
        font-size: 13px;
        font-weight: 700;
        color: var(--ud-text-muted);
        background: transparent;
        border: none;
        border-radius: var(--ud-radius-pill);
        cursor: pointer;
        transition: background 0.18s, color 0.18s;
    }

    .lesson-tab:hover:not(.active) {
        background: rgba(0,0,0,0.06);
        color: var(--ud-text);
    }

    .lesson-tab.active {
        background: var(--ud-black);
        color: white;
    }

    .lesson-tab.highlight {
        color: var(--ud-star);
    }

    .tab-content {
        display: block;
    }

    .tab-pane {
        display: none;
    }

    .tab-pane.active {
        display: block;
    }

    .lesson-header {
        margin-bottom: var(--ud-sp6);
    }

    .lesson-header h1 {
        font-size: 22px;
        font-weight: 800;
        color: var(--ud-text);
        margin: 0 0 var(--ud-sp2);
    }

    .lesson-meta {
        font-size: 13px;
        color: var(--ud-text-muted);
        display: flex;
        gap: var(--ud-sp4);
        align-items: center;
    }

    .video-container {
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
        overflow: hidden;
        border-radius: var(--ud-radius);
        background: #000;
        margin-bottom: var(--ud-sp6);
        box-shadow: var(--ud-shadow-lg);
    }

    .video-container video {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .reading-content {
        background: var(--ud-white);
        border: 1px solid var(--ud-border);
        border-radius: var(--ud-radius);
        padding: var(--ud-sp8);
        box-shadow: var(--ud-shadow-sm);
        line-height: 1.8;
        font-size: 15px;
        color: var(--ud-text);
    }

    .reading-content h2,
    .reading-content h3 {
        margin-top: var(--ud-sp6);
        margin-bottom: var(--ud-sp3);
    }

    .reading-content pre {
        background: var(--ud-surface);
        padding: var(--ud-sp4);
        border-radius: var(--ud-radius-md);
        overflow-x: auto;
        border: 1px solid var(--ud-border);
    }

    .lesson-actions {
        display: flex;
        align-items: center;
        gap: var(--ud-sp3);
        margin-top: var(--ud-sp6);
        padding-top: var(--ud-sp5);
        border-top: 1px solid var(--ud-border);
    }

    .btn-mark-complete {
        display: inline-flex;
        align-items: center;
        gap: var(--ud-sp2);
        padding: 10px 20px;
        border-radius: var(--ud-radius);
        font-size: 13px;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-mark-complete.incomplete {
        background: var(--ud-green);
        color: #fff;
    }

    .btn-mark-complete.incomplete:hover {
        background: #0e5a38;
    }

    .btn-mark-complete.completed {
        background: var(--ud-green-bg);
        color: var(--ud-green);
        cursor: default;
    }

    .btn-next-lesson {
        display: inline-flex;
        align-items: center;
        gap: var(--ud-sp2);
        padding: 10px 18px;
        border-radius: var(--ud-radius);
        font-size: 13px;
        font-weight: 600;
        border: 1px solid var(--ud-border);
        background: var(--ud-white);
        color: var(--ud-text);
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-next-lesson:hover {
        background: var(--ud-surface);
        text-decoration: none;
        color: var(--ud-text);
    }

    .no-lesson {
        text-align: center;
        padding: var(--ud-sp10) var(--ud-sp6);
    }

    .no-lesson h2 {
        font-size: 18px;
        margin-bottom: var(--ud-sp2);
        color: var(--ud-text);
    }

    .no-lesson p {
        font-size: 14px;
        color: var(--ud-text-muted);
    }

    .toast-notification {
        position: fixed;
        bottom: var(--ud-sp6);
        right: var(--ud-sp6);
        padding: var(--ud-sp3) var(--ud-sp6);
        border-radius: var(--ud-radius);
        font-size: 13px;
        font-weight: 700;
        color: #fff;
        z-index: 9999;
        transform: translateY(100px);
        opacity: 0;
        transition: all 0.3s ease;
        box-shadow: var(--ud-shadow-lg);
    }

    .toast-notification.show {
        transform: translateY(0);
        opacity: 1;
    }

    .toast-notification.success {
        background: var(--ud-green);
    }

    .toast-notification.error {
        background: var(--ud-red);
    }

    .discussion-section {
        margin-top: var(--ud-sp6);
    }

    .discussion-section h3 {
        font-size: 18px;
        font-weight: 800;
        margin-bottom: var(--ud-sp5);
    }

    .discussion-form {
        background: var(--ud-white);
        border: 1px solid var(--ud-border);
        border-radius: var(--ud-radius);
        padding: var(--ud-sp5);
        margin-bottom: var(--ud-sp5);
        box-shadow: var(--ud-shadow-sm);
    }

    .discussion-form textarea {
        width: 100%;
        font-family: inherit;
        font-size: 14px;
        color: var(--ud-text);
        background: var(--ud-surface);
        border: 1px solid var(--ud-border);
        border-radius: var(--ud-radius);
        padding: var(--ud-sp3) var(--ud-sp4);
        outline: none;
        resize: vertical;
        min-height: 80px;
        margin-bottom: var(--ud-sp3);
    }

    .discussion-form textarea:focus {
        border-color: var(--ud-magenta);
        box-shadow: 0 0 0 3px rgba(164,53,240,.14);
    }

    .discussion-item {
        background: var(--ud-white);
        border: 1px solid var(--ud-border);
        border-radius: var(--ud-radius);
        padding: var(--ud-sp5);
        margin-bottom: var(--ud-sp4);
        box-shadow: var(--ud-shadow-sm);
    }

    .discussion-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: var(--ud-sp3);
    }

    .discussion-author {
        display: flex;
        align-items: center;
        gap: var(--ud-sp2);
    }

    .discussion-author-name {
        font-weight: 700;
        font-size: 14px;
        color: var(--ud-text);
    }

    .discussion-date {
        font-size: 12px;
        color: var(--ud-text-muted);
    }

    .discussion-title {
        font-size: 15px;
        font-weight: 600;
        color: var(--ud-text);
        margin-bottom: var(--ud-sp3);
    }

    .discussion-replies {
        margin-left: var(--ud-sp6);
        padding-left: var(--ud-sp4);
        border-left: 2px solid var(--ud-border);
    }

    .reply-item {
        margin-bottom: var(--ud-sp4);
    }

    .reply-item:last-child {
        margin-bottom: 0;
    }

    .reply-header {
        display: flex;
        align-items: center;
        gap: var(--ud-sp2);
        margin-bottom: var(--ud-sp1);
    }

    .reply-author {
        font-weight: 700;
        font-size: 13px;
        color: var(--ud-text);
    }

    .reply-date {
        font-size: 11px;
        color: var(--ud-text-muted);
    }

    .reply-content {
        font-size: 14px;
        color: var(--ud-text);
        margin: 0;
    }

    .reply-form {
        display: flex;
        gap: var(--ud-sp2);
        margin-top: var(--ud-sp3);
        margin-left: var(--ud-sp6);
    }

    .reply-form input {
        flex: 1;
        font-family: inherit;
        font-size: 13px;
        color: var(--ud-text);
        background: var(--ud-surface);
        border: 1px solid var(--ud-border);
        border-radius: var(--ud-radius);
        padding: var(--ud-sp2) var(--ud-sp4);
        outline: none;
    }

    .reply-form input:focus {
        border-color: var(--ud-magenta);
        box-shadow: 0 0 0 3px rgba(164,53,240,.14);
    }

    .review-section {
        text-align: center;
        padding: var(--ud-sp6) 0;
    }

    .review-section h2 {
        font-size: 22px;
        font-weight: 800;
        margin-bottom: var(--ud-sp2);
    }

    .review-section p {
        font-size: 15px;
        color: var(--ud-text-muted);
        margin-bottom: var(--ud-sp6);
    }

    .review-form {
        background: var(--ud-white);
        border: 1px solid var(--ud-border);
        border-radius: var(--ud-radius);
        padding: var(--ud-sp6);
        max-width: 560px;
        margin: 0 auto;
        text-align: left;
        box-shadow: var(--ud-shadow);
    }

    .review-form .form-group {
        margin-bottom: var(--ud-sp5);
    }

    .review-form label {
        display: block;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--ud-text-muted);
        margin-bottom: var(--ud-sp2);
    }

    .review-form select,
    .review-form textarea {
        width: 100%;
        font-family: inherit;
        font-size: 14px;
        color: var(--ud-text);
        background: var(--ud-surface);
        border: 1px solid var(--ud-border);
        border-radius: var(--ud-radius);
        padding: var(--ud-sp3) var(--ud-sp4);
        outline: none;
    }

    .review-form select:focus,
    .review-form textarea:focus {
        border-color: var(--ud-magenta);
        box-shadow: 0 0 0 3px rgba(164,53,240,.14);
    }

    .review-form textarea {
        resize: vertical;
        min-height: 100px;
    }

    @@media (max-width: 768px) {
        .learn-wrapper {
            flex-direction: column;
        }

        .learn-sidebar {
            width: 100%;
            min-width: unset;
            max-height: 300px;
            border-right: none;
            border-bottom: 1px solid var(--ud-border);
        }

        .learn-content-inner {
            padding: var(--ud-sp5) var(--ud-sp4);
        }

        .lesson-tabs {
            flex-wrap: wrap;
        }

        .lesson-actions {
            flex-wrap: wrap;
        }
    }
</style>

<div class="learn-wrapper">
    <aside class="learn-sidebar">
        <div class="learn-sidebar-header">
            <h2>@(Model.Course?.Title ?? "")</h2>
            <div class="progress-bar-container">
                <div class="progress-bar-fill" id="progressBar"
                     style="width: @Model.Progress.PercentComplete%"></div>
            </div>
            <span class="progress-text" id="progressText">
                @Model.Progress.CompletedLessons / @Model.Progress.TotalLessons bài hoàn thành
                (@Model.Progress.PercentComplete%)
            </span>
        </div>

        <div class="learn-sections">
            @foreach (var section in (Model.Course?.Sections ?? new List<Section>()).OrderBy(s => s.OrderIndex))
            {
                var sectionLessons = section.Lessons
                    .Where(l => !l.IsDeleted)
                    .OrderBy(l => l.OrderIndex)
                    .ToList();

                if (!sectionLessons.Any()) continue;

                <div class="learn-section">
                    <div class="learn-section-title" onclick="toggleSection(this)">
                        <span class="chevron">@Html.Raw("<i class=\"bi bi-chevron-down\"></i>")</span>
                        @(section.Title)
                    </div>
                    <ul class="learn-lesson-list">
                        @foreach (var lesson in sectionLessons)
                        {
                            var isActive = Model.CurrentLesson?.LessonId == lesson.LessonId;
                            var isCompleted = Model.CompletedLessonIds.Contains(lesson.LessonId);
                            var typeLabel = lesson.LessonType switch
                            {
                                LessonType.Video => "Video",
                                LessonType.Reading => "Doc",
                                LessonType.Quiz => "Quiz",
                                LessonType.Assignment => "BT",
                                _ => ""
                            };

                            <li>
                                <a class="learn-lesson-item @(isActive ? "active" : "")"
                                   href="/Student/LearnCourse?courseId=@Model.Course.CourseId&lessonId=@lesson.LessonId">
                                    <span class="lesson-icon @(isCompleted ? "completed" : "incomplete")">
                                        @if (isCompleted)
                                        {
                                            @Html.Raw("<i class=\"bi bi-check\"></i>")
                                        }
                                    </span>
                                    <span class="lesson-title">@lesson.Title</span>
                                    <span class="lesson-type-badge">@typeLabel</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    </aside>

    <main class="learn-content">
        @if (Model.CurrentLesson != null)
        {
            var lesson = Model.CurrentLesson;
            var isCompleted = Model.CompletedLessonIds.Contains(lesson.LessonId);

            <div class="learn-content-inner">
                <div class="lesson-tabs">
                    <button class="lesson-tab active" data-tab="content" onclick="switchTab('content')">
                        @Html.Raw("<i class=\"bi bi-play-circle\"></i>") Noi dung bai hoc
                    </button>
                    <button class="lesson-tab" data-tab="discuss" onclick="switchTab('discuss')">
                        @Html.Raw("<i class=\"bi bi-chat-dots\"></i>") Thao luan chung
                    </button>
                    @if (Model.Progress.PercentComplete >= 100)
                    {
                        <button class="lesson-tab highlight" data-tab="review" onclick="switchTab('review')">
                            @Html.Raw("<i class=\"bi bi-star\"></i>") Danh gia khoa hoc
                        </button>
                    }
                </div>

                <div class="tab-content">
                    <div class="tab-pane active" id="content">
                        <div class="lesson-header">
                            <h1>@lesson.Title</h1>
                            <div class="lesson-meta">
                                @{
                                    var lessonTypeIcon = lesson.LessonType switch
                                    {
                                        LessonType.Video => "bi-camera-video",
                                        LessonType.Reading => "bi-book",
                                        LessonType.Quiz => "bi-pencil-square",
                                        LessonType.Assignment => "bi-list-task",
                                        _ => "bi-file-text"
                                    };
                                    var lessonTypeName = lesson.LessonType switch
                                    {
                                        LessonType.Video => "Video",
                                        LessonType.Reading => "Bai doc",
                                        LessonType.Quiz => "Quiz",
                                        LessonType.Assignment => "Bai tap",
                                        _ => ""
                                    };
                                }
                                <span>@Html.Raw($"<i class=\"bi {lessonTypeIcon}\"></i>") @lessonTypeName</span>
                                @if (lesson.VideoDurationSeconds.HasValue)
                                {
                                    var mins = lesson.VideoDurationSeconds.Value / 60;
                                    var secs = lesson.VideoDurationSeconds.Value % 60;
                                    <span>@Html.Raw("<i class=\"bi bi-clock\"></i>") @(mins):@(secs.ToString("D2"))</span>
                                }
                            </div>
                        </div>

                        @if (lesson.LessonType == LessonType.Video && !string.IsNullOrEmpty(lesson.VideoStoragePath))
                        {
                            <div class="video-container">
                                <video id="videoPlayer" controls preload="metadata">
                                    <source src="@lesson.VideoStoragePath" type="video/mp4" />
                                    Trinh duyet khong ho tro video.
                                </video>
                            </div>
                        }

                        @if (lesson.LessonType == LessonType.Reading && !string.IsNullOrEmpty(lesson.Content))
                        {
                            <div class="reading-content">
                                @Html.Raw(lesson.Content)
                            </div>
                        }

                        @if (lesson.LessonType == LessonType.Quiz)
                        {
                            <div class="reading-content">
                                <p>Bai quiz nay se duoc lam trong phan Quiz.</p>
                            </div>
                        }
                        @if (lesson.LessonType == LessonType.Assignment)
                        {
                            <div class="reading-content">
                                <p>Bai tap se duoc nop trong phan Assignment.</p>
                            </div>
                        }

                        <div class="lesson-actions">
                            @if (isCompleted)
                            {
                                <button class="btn-mark-complete completed" disabled id="btnMarkComplete">
                                    @Html.Raw("<i class=\"bi bi-check-circle\"></i>") Da hoan thanh
                                </button>
                            }
                            else
                            {
                                <button class="btn-mark-complete incomplete" id="btnMarkComplete"
                                        onclick="markComplete(@lesson.LessonId, '@Model.Course.CourseId')">
                                    @Html.Raw("<i class=\"bi bi-check-circle\"></i>") Danh dau hoan thanh
                                </button>
                            }

                            @{
                                var allLessons = Model.Course.Sections
                                    .OrderBy(s => s.OrderIndex)
                                    .SelectMany(s => s.Lessons.Where(l => !l.IsDeleted).OrderBy(l => l.OrderIndex))
                                    .ToList();
                                var currentIdx = allLessons.FindIndex(l => l.LessonId == lesson.LessonId);
                                var nextLesson = currentIdx >= 0 && currentIdx < allLessons.Count - 1
                                    ? allLessons[currentIdx + 1]
                                    : null;
                            }

                            @if (nextLesson != null)
                            {
                                <a class="btn-next-lesson"
                                   href="/Student/LearnCourse?courseId=@Model.Course.CourseId&lessonId=@nextLesson.LessonId">
                                    Bai tiep theo @Html.Raw("<i class=\"bi bi-arrow-right\"></i>")
                                </a>
                            }
                        </div>
                    </div>

                    <div class="tab-pane" id="discuss">
                        <div class="discussion-section">
                            <h3>@Html.Raw("<i class=\"bi bi-chat-dots\"></i>") Thao luan chung</h3>

                            <div class="discussion-form">
                                <form method="post" asp-page-handler="CreateTopic" asp-route-courseId="@Model.Course.CourseId" asp-route-lessonId="@lesson.LessonId">
                                    <textarea asp-for="NewTopicTitle" placeholder="Ban co cau hoi gi can trao doi?"></textarea>
                                    <div style="text-align: right;">
                                        <button type="submit" class="btn btn-primary">
                                            @Html.Raw("<i class=\"bi bi-send\"></i>") Dang cau hoi
                                        </button>
                                    </div>
                                </form>
                            </div>

                            @if (Model.Topics != null && Model.Topics.Any())
                            {
                                foreach (var topic in Model.Topics)
                                {
                                    <div class="discussion-item">
                                        <div class="discussion-header">
                                            <div class="discussion-author">
                                                <span class="discussion-author-name">@topic.CreatorName</span>
                                                @if (topic.CreatorRole == "Teacher" || topic.CreatorRole == "Admin")
                                                {
                                                    <span class="badge badge-purple">Giang vien</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-muted">Hoc vien</span>
                                                }
                                            </div>
                                            <span class="discussion-date">@topic.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                        </div>
                                        <p class="discussion-title">@topic.Title</p>

                                        @if (topic.Replies != null && topic.Replies.Any())
                                        {
                                            <div class="discussion-replies">
                                                @foreach (var reply in topic.Replies)
                                                {
                                                    <div class="reply-item">
                                                        <div class="reply-header">
                                                            <span class="reply-author">@reply.UserName</span>
                                                            @if (reply.UserRole == "Teacher" || reply.UserRole == "Admin")
                                                            {
                                                                <span class="badge badge-purple" style="font-size: 9px;">GV</span>
                                                            }
                                                            <span class="reply-date">@reply.CreatedAt.ToString("dd/MM HH:mm")</span>
                                                        </div>
                                                        <p class="reply-content">@reply.Content</p>
                                                    </div>
                                                }
                                            </div>
                                        }

                                        <div class="reply-form">
                                            <form method="post" asp-page-handler="CreateReply" asp-route-courseId="@Model.Course.CourseId" asp-route-lessonId="@lesson.LessonId" asp-route-topicId="@topic.TopicId" style="display: flex; gap: var(--ud-sp2); width: 100%;">
                                                <input type="text" name="NewReplyContent" placeholder="Viet phan hoi...">
                                                <button type="submit" class="btn btn-primary btn-sm">
                                                    @Html.Raw("<i class=\"bi bi-send\"></i>")
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="ud-empty">
                                    @Html.Raw("<i class=\"bi bi-chat-square-text\" style=\"font-size: 2.5rem;\"></i>")
                                    <h3>Chua co thao luan</h3>
                                    <p>Ban hay la nguoi dau tien dat cau hoi!</p>
                                </div>
                            }
                        </div>
                    </div>

                    @if (Model.Progress.PercentComplete >= 100)
                    {
                        <div class="tab-pane" id="review">
                            <div class="review-section">
                                <h2>@Html.Raw("<i class=\"bi bi-trophy\"></i>") Chung minh ban da hoan thanh khoa hoc!</h2>
                                <p>Hay chia se cam nhan cua ban de giup khoa hoc ngay cang hoan thien hon.</p>

                                <div class="review-form">
                                    <form method="post" asp-page-handler="SubmitReview" asp-route-courseId="@Model.Course.CourseId" asp-route-lessonId="@lesson.LessonId">
                                        <div class="form-group">
                                            <label>Cham diem khoa hoc</label>
                                            <select asp-for="ReviewRating" class="form-control">
                                                <option value="5" selected="@(Model.MyReview?.Rating == 5)">@Html.Raw("&#9733;&#9733;&#9733;&#9733;&#9733;") (5) Tuyet voi</option>
                                                <option value="4" selected="@(Model.MyReview?.Rating == 4)">@Html.Raw("&#9733;&#9733;&#9733;&#9733;") (4) Rat tot</option>
                                                <option value="3" selected="@(Model.MyReview?.Rating == 3)">@Html.Raw("&#9733;&#9733;&#9733;") (3) Tam ok</option>
                                                <option value="2" selected="@(Model.MyReview?.Rating == 2)">@Html.Raw("&#9733;&#9733;") (2) Kem</option>
                                                <option value="1" selected="@(Model.MyReview?.Rating == 1)">@Html.Raw("&#9733;") (1) Rat te</option>
                                            </select>
                                        </div>
                                        <div class="form-group">
                                            <label>Nhan xet cua ban</label>
                                            <textarea asp-for="ReviewComment" placeholder="Nhap cam nhan cua ban ve noi dung, giang vien, va chat luong video...">@(Model.MyReview?.Comment)</textarea>
                                        </div>
                                        <button type="submit" class="btn btn-primary btn-full">
                                            @Html.Raw("<i class=\"bi bi-send\"></i>")
                                            @(Model.MyReview != null ? "Cap Nhat Danh Gia" : "Gui Danh Gia Khoa Hoc")
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="learn-content-inner">
                <div class="no-lesson">
                    @Html.Raw("<i class=\"bi bi-book\" style=\"font-size: 3rem; color: var(--ud-text-muted); display: block; margin-bottom: var(--ud-sp4);\"></i>")
                    <h2>Chua co bai hoc</h2>
                    <p>Khoa hoc nay chua co noi dung bai hoc nao.</p>
                </div>
            </div>
        }
    </main>
</div>

<div id="toast" class="toast-notification"></div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        function switchTab(tabName) {
            document.querySelectorAll('.lesson-tab').forEach(tab => {
                tab.classList.remove('active');
                if (tab.dataset.tab === tabName) {
                    tab.classList.add('active');
                }
            });
            document.querySelectorAll('.tab-pane').forEach(pane => {
                pane.classList.remove('active');
            });
            document.getElementById(tabName).classList.add('active');
        }

        function toggleSection(el) {
            el.closest('.learn-section').classList.toggle('collapsed');
        }

        function showToast(message, type) {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.className = 'toast-notification ' + type + ' show';
            setTimeout(() => toast.classList.remove('show'), 3000);
        }

        function markComplete(lessonId, courseId) {
            const btn = document.getElementById('btnMarkComplete');
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Dang xu ly...';

            fetch('/Student/LearnCourse?handler=MarkComplete', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: JSON.stringify({ lessonId: lessonId, courseId: courseId })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    btn.className = 'btn-mark-complete completed';
                    btn.innerHTML = '<i class="bi bi-check-circle"></i> Da hoan thanh';
                    btn.disabled = true;

                    document.getElementById('progressBar').style.width = data.percentComplete + '%';

                    const activeItem = document.querySelector('.learn-lesson-item.active .lesson-icon');
                    if (activeItem) {
                        activeItem.className = 'lesson-icon completed';
                        activeItem.innerHTML = '<i class="bi bi-check"></i>';
                    }

                    const progressText = document.getElementById('progressText');
                    if (progressText) {
                        progressText.textContent = data.completedLessons + ' / ' + data.totalLessons + ' bai hoan thanh (' + data.percentComplete + '%)';
                    }

                    if (data.isCourseCompleted) {
                        showToast('Chuc mung! Ban da hoan thanh khoa hoc!', 'success');
                    } else {
                        showToast('Da hoan thanh bai hoc!', 'success');
                    }
                } else {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-check-circle"></i> Danh dau hoan thanh';
                    showToast(data.message, 'error');
                }
            })
            .catch(err => {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check-circle"></i> Danh dau hoan thanh';
                showToast('Co loi xay ra.', 'error');
            });
        }

        (function () {
            const video = document.getElementById('videoPlayer');
            if (!video) return;

            let lastSaved = 0;

            video.addEventListener('timeupdate', function () {
                const current = Math.floor(video.currentTime);
                if (current - lastSaved >= 10) {
                    lastSaved = current;
                    saveWatchedSeconds(current);
                }
            });

            video.addEventListener('pause', function () {
                const current = Math.floor(video.currentTime);
                if (current > 0) {
                    saveWatchedSeconds(current);
                }
            });

            video.addEventListener('ended', function () {
                const current = Math.floor(video.duration);
                if (current > 0) {
                    saveWatchedSeconds(current);
                }
            });

            window.addEventListener('beforeunload', function () {
                if (video && !video.paused && video.currentTime > 0) {
                    const current = Math.floor(video.currentTime);
                    const lessonId = @(Model.CurrentLesson?.LessonId ?? 0);
                    if (lessonId === 0) return;
                    const data = JSON.stringify({ lessonId: lessonId, watchedSeconds: current });
                    const blob = new Blob([data], { type: 'application/json' });
                    navigator.sendBeacon('/Student/LearnCourse?handler=UpdateWatched', blob);
                }
            });

            function saveWatchedSeconds(seconds) {
                const lessonId = @(Model.CurrentLesson?.LessonId ?? 0);
                if (lessonId === 0) return;

                fetch('/Student/LearnCourse?handler=UpdateWatched', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify({ lessonId: lessonId, watchedSeconds: seconds })
                }).catch(() => { });
            }
        })();

        const progressConnection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/progress")
            .withAutomaticReconnect()
            .build();

        const currentCourseId = '@Model.Course?.CourseId';
        progressConnection.start().then(() => {
            if (currentCourseId) {
                progressConnection.invoke("JoinCourseGroup", currentCourseId);
            }
        }).catch(err => console.error('SignalR error:', err));

        progressConnection.on("LessonCompleted", function (data) {
            document.getElementById('progressBar').style.width = data.percentComplete + '%';
            const progressText = document.getElementById('progressText');
            if (progressText) {
                progressText.textContent = data.completedLessons + ' / ' + data.totalLessons + ' bai hoan thanh (' + data.percentComplete + '%)';
            }

            const lessonLinks = document.querySelectorAll('.learn-lesson-item');
            lessonLinks.forEach(link => {
                if (link.href && link.href.includes('lessonId=' + data.lessonId)) {
                    const icon = link.querySelector('.lesson-icon');
                    if (icon) {
                        icon.className = 'lesson-icon completed';
                        icon.innerHTML = '<i class="bi bi-check"></i>';
                    }
                }
            });
        });

        window.addEventListener('beforeunload', function () {
            if (currentCourseId && progressConnection.state === signalR.HubConnectionState.Connected) {
                progressConnection.invoke("LeaveCourseGroup", currentCourseId);
            }
        });
    </script>
}
