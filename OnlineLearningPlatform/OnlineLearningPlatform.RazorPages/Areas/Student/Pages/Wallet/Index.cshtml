@page
@model OnlineLearningPlatform.RazorPages.Areas.Student.Pages.Wallet.IndexModel
@{
    ViewData["Title"] = "Ví của tôi";
}

<style>
    .wallet-shell {
        max-width: 880px;
        margin: 0 auto;
        padding: var(--ud-sp6) var(--ud-sp4) var(--ud-sp10);
        box-sizing: border-box;
    }
    .wallet-balance-card {
        background: linear-gradient(135deg, var(--ud-purple) 0%, var(--ud-magenta) 100%);
        border-radius: 16px;
        padding: var(--ud-sp6) var(--ud-sp6);
        margin-bottom: var(--ud-sp6);
        color: #fff;
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        justify-content: space-between;
        gap: var(--ud-sp5);
        box-shadow: var(--ud-shadow-lg);
    }
    .wallet-balance-card .balance-label {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        opacity: 0.85;
        margin-bottom: var(--ud-sp2);
    }
    .wallet-balance-card .balance-amount {
        font-size: clamp(1.75rem, 4vw, 2.35rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.15;
    }
    .wallet-balance-card .balance-amount small {
        font-size: 1rem;
        font-weight: 600;
        opacity: 0.85;
        margin-left: 6px;
    }
    .wallet-balance-card .btn-topup {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        border-radius: var(--ud-radius-pill);
        font-weight: 700;
        font-size: 0.875rem;
        background: #fff;
        color: var(--ud-purple) !important;
        border: none;
        text-decoration: none !important;
        box-shadow: 0 2px 12px rgba(0,0,0,.12);
        transition: transform var(--ud-ease), box-shadow var(--ud-ease);
    }
    .wallet-balance-card .btn-topup:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 16px rgba(0,0,0,.15);
        color: var(--ud-magenta-dk) !important;
    }
    .wallet-tx-card .ud-card-header h2 {
        font-size: 1rem;
        font-weight: 800;
        margin: 0;
    }
    .tx-icon-wrap {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1rem;
    }
    .tx-icon-wrap.deposit {
        background: var(--ud-green-bg);
        color: var(--ud-green);
    }
    .tx-icon-wrap.withdraw {
        background: var(--ud-red-bg);
        color: var(--ud-red);
    }
    .tx-row {
        display: flex;
        align-items: center;
        gap: var(--ud-sp4);
    }
    .tx-row:hover {
        background: var(--ud-surface);
    }
    .tx-amount-pos { color: var(--ud-green); font-weight: 700; }
    .tx-amount-neg { color: var(--ud-text); font-weight: 700; }
</style>

<div class="wallet-shell">
    <div class="ud-page-head" style="margin-bottom: var(--ud-sp6);">
        <h1>Ví của tôi</h1>
        <p>Quản lý số dư và xem lịch sử giao dịch.</p>
    </div>

    <div class="wallet-balance-card">
        <div>
            <div class="balance-label">Số dư hiện tại</div>
            <div class="balance-amount">
                @((Model.StudentWallet?.Balance ?? 0).ToString("N0"))<small>VNĐ</small>
            </div>
        </div>
        <a href="/Student/Wallet/TopUp" class="btn-topup">
            <i class="bi bi-plus-lg"></i>
            Nạp tiền
        </a>
    </div>

    <div class="ud-card wallet-tx-card">
        <div class="ud-card-header" style="padding: var(--ud-sp5) var(--ud-sp6); border-bottom: 1px solid var(--ud-border);">
            <h2>Lịch sử giao dịch</h2>
        </div>

        @if (Model.Transactions.Any())
        {
            <div class="ud-table-wrap">
                <table class="ud-table">
                    <thead>
                        <tr>
                            <th>Giao dịch</th>
                            <th>Thời gian</th>
                            <th style="text-align:right;">Số tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tx in Model.Transactions.OrderByDescending(t => t.CreatedAt))
                        {
                            var isCredit = tx.Type == OnlineLearningPlatform.Models.Entities.WalletTransactionType.TopUp
                                           || tx.Type == OnlineLearningPlatform.Models.Entities.WalletTransactionType.Refund;
                            <tr>
                                <td>
                                    <div class="tx-row">
                                        <div class="tx-icon-wrap @(isCredit ? "deposit" : "withdraw")">
                                            @if (isCredit)
                                            {
                                                <i class="bi bi-arrow-down-left"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-arrow-up-right"></i>
                                            }
                                        </div>
                                        <div>
                                            <div style="font-weight: 700; font-size: 0.875rem;">@tx.Description</div>
                                            <div class="ud-text-muted" style="font-size: 0.75rem; margin-top: 2px;">
                                                #@tx.WalletTransactionId
                                                @if (isCredit)
                                                {
                                                    <span class="badge badge-green" style="margin-left: 6px;">Ghi có</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-muted" style="margin-left: 6px;">Ghi nợ</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td style="font-size: 0.8rem; color: var(--ud-text-muted); white-space: nowrap;">
                                    @tx.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td style="text-align:right; white-space:nowrap;">
                                    <span class="@(isCredit ? "tx-amount-pos" : "tx-amount-neg")">
                                        @(isCredit ? "+" : "-")@tx.Amount.ToString("N0") VNĐ
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ud-empty">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 0 0-2.25-2.25H15a3 3 0 1 1-6 0H5.25A2.25 2.25 0 0 0 3 12m18 0v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 9m18 0V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v3"/></svg>
                <h3>Chưa có giao dịch</h3>
                <p>Nạp tiền vào ví để mua khóa học và thanh toán nhanh hơn.</p>
                <a href="/Student/Wallet/TopUp" class="btn btn-primary" style="margin-top: var(--ud-sp4);">
                    <i class="bi bi-plus-lg"></i>
                    Nạp tiền
                </a>
            </div>
        }
    </div>
</div>
