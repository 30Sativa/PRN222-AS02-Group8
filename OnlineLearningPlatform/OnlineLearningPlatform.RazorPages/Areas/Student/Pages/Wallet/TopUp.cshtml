@page
@model OnlineLearningPlatform.RazorPages.Areas.Student.Pages.Wallet.TopUpModel
@{
    ViewData["Title"] = "Nạp tiền vào ví";
}

<div class="ud-page-narrow ud-fade-up">
    <div class="ud-page-head">
        <a href="/Student/Wallet" class="btn btn-ghost btn-sm" style="margin-bottom: var(--ud-sp3);">
            @Html.Raw("<i class=\"bi bi-arrow-left\"></i>") Quay về ví
        </a>
        <h1>Nạp tiền vào ví</h1>
        <p>Nạp tiền nhanh chóng qua VNPAY để mua khóa học</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" style="margin-bottom: var(--ud-sp5);">
            @Html.Raw("<i class=\"bi bi-exclamation-circle-fill\"></i>") @Model.ErrorMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success" style="margin-bottom: var(--ud-sp5);">
            @Html.Raw("<i class=\"bi bi-check-circle-fill\"></i>") @Model.SuccessMessage
        </div>
    }

    <div class="ud-card" style="padding: var(--ud-sp6);">
        <div style="background: linear-gradient(135deg, var(--ud-purple) 0%, var(--ud-magenta) 100%); border-radius: var(--ud-radius); padding: var(--ud-sp5) var(--ud-sp6); text-align: center; margin-bottom: var(--ud-sp6);">
            <div style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(255,255,255,0.85); margin-bottom: var(--ud-sp2);">
                Số dư hiện tại
            </div>
            <div style="font-size: 2.25rem; font-weight: 800; color: #fff; letter-spacing: -0.02em;">
                @(Model.StudentWallet?.Balance.ToString("N0") ?? "0")
                <span style="font-size: 1.1rem; font-weight: 400; opacity: 0.8;">VNĐ</span>
            </div>
        </div>

        <div style="margin-bottom: var(--ud-sp5);">
            <label class="form-label">Chọn số tiền nạp</label>
            <div class="ud-grid" style="grid-template-columns: repeat(5, 1fr); gap: var(--ud-sp2); margin-bottom: var(--ud-sp5);">
                @foreach (var amount in OnlineLearningPlatform.RazorPages.Areas.Student.Pages.Wallet.TopUpModel.QuickAmounts)
                {
                    <button type="button" 
                            class="quick-amount-btn @(Model.Amount == amount ? "selected" : "")"
                            onclick="selectAmount(@amount)">
                        @amount.ToString("N0")
                    </button>
                }
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Hoặc nhập số tiền khác</label>
            <div style="position: relative;">
                <span style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-weight: 700; color: var(--ud-text-muted); font-size: 1rem;">₫</span>
                <input type="number"
                       id="customAmount"
                       name="Amount"
                       value="@Model.Amount"
                       min="10000"
                       max="100000000"
                       step="1000"
                       placeholder="Nhập số tiền..."
                       class="form-control"
                       style="padding-left: 36px; font-size: 1.1rem; font-weight: 700;"
                       oninput="updateSummary()" />
            </div>
        </div>

        <div style="background: var(--ud-surface); border-radius: var(--ud-radius); padding: var(--ud-sp4) var(--ud-sp5); margin-bottom: var(--ud-sp5); border: 1px solid var(--ud-border-light, #e8e8ed);">
            <div class="ud-flex ud-justify-between ud-align-center" style="padding: var(--ud-sp2) 0;">
                <span class="ud-text-muted" style="font-size: 0.875rem;">Số tiền nạp</span>
                <span id="summaryAmount" style="font-weight: 700; font-size: 0.95rem;">@Model.Amount.ToString("N0") VNĐ</span>
            </div>
            <div class="ud-flex ud-justify-between ud-align-center" style="padding: var(--ud-sp2) 0; border-top: 1px solid var(--ud-border-light, #e8e8ed); margin-top: var(--ud-sp2); padding-top: var(--ud-sp3);">
                <span class="ud-text-muted" style="font-size: 0.875rem;">Phí giao dịch</span>
                <span style="font-weight: 700; font-size: 0.95rem; color: var(--ud-green);">Miễn phí</span>
            </div>
            <div class="ud-flex ud-justify-between ud-align-center" style="padding: var(--ud-sp3) 0 0 0; border-top: 1px solid var(--ud-border); margin-top: var(--ud-sp2);">
                <span style="font-size: 0.9rem; font-weight: 700;">Số tiền được cộng vào ví</span>
                <span id="summaryTotal" style="font-weight: 800; font-size: 1.1rem; color: var(--ud-purple);">@Model.Amount.ToString("N0") VNĐ</span>
            </div>
        </div>

        <form method="post" action="/api/wallet/topup" id="topupForm">
            <input type="hidden" name="amount" id="hiddenAmount" value="@Model.Amount" />
            <button type="submit" class="btn btn-primary btn-full btn-lg" id="submitBtn">
                @Html.Raw("<i class=\"bi bi-wallet2\"></i>") Nạp @Model.Amount.ToString("N0") VNĐ qua VNPAY
            </button>
        </form>

        <div style="display: flex; align-items: center; justify-content: center; gap: var(--ud-sp2); margin-top: var(--ud-sp4); padding-top: var(--ud-sp4); border-top: 1px solid var(--ud-border-light, #e8e8ed);">
            @Html.Raw("<i class=\"bi bi-shield-lock\" style=\"color: var(--ud-green);\"></i>")
            <span class="ud-text-muted" style="font-size: 0.8rem;">Thanh toán an toàn qua cổng VNPAY</span>
        </div>

        <div style="display: flex; align-items: center; justify-content: center; gap: var(--ud-sp3); margin-top: var(--ud-sp4);">
            <span class="ud-text-muted" style="font-size: 0.75rem;">Hỗ trợ thanh toán:</span>
            <span style="font-weight: 800; color: var(--ud-purple); font-size: 1rem;">VNPAY</span>
        </div>
    </div>
</div>

<style>
    .quick-amount-btn {
        padding: var(--ud-sp3) var(--ud-sp2);
        border: 1px solid var(--ud-border);
        border-radius: var(--ud-radius);
        background: var(--ud-white);
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--ud-text);
        cursor: pointer;
        transition: all var(--ud-ease);
        text-align: center;
    }

    .quick-amount-btn:hover {
        border-color: var(--ud-magenta);
        background: rgba(164, 53, 240, 0.04);
        color: var(--ud-magenta);
    }

    .quick-amount-btn.selected {
        border-color: var(--ud-magenta);
        background: var(--ud-magenta);
        color: #fff;
    }

    .quick-amount-btn.selected:hover {
        background: var(--ud-magenta-dk);
    }
</style>

@section Scripts {
<script>
    let selectedAmount = @Model.Amount;

    function selectAmount(amount) {
        selectedAmount = amount;
        document.getElementById('customAmount').value = amount;
        document.getElementById('hiddenAmount').value = amount;
        document.getElementById('submitBtn').innerHTML = '<i class="bi bi-wallet2"></i> Nạp ' + amount.toLocaleString('vi-VN') + ' VNĐ qua VNPAY';

        document.querySelectorAll('.quick-amount-btn').forEach(btn => {
            var btnText = btn.textContent.trim();
            var btnAmount = parseInt(btnText.replace(/\D/g, ''));
            if (btnAmount === amount) {
                btn.classList.add('selected');
            } else {
                btn.classList.remove('selected');
            }
        });

        updateSummary();
    }

    function updateSummary() {
        var input = document.getElementById('customAmount');
        var amount = parseInt(input.value) || 0;

        if (amount < 10000) amount = 0;
        if (amount > 100000000) amount = 100000000;

        selectedAmount = amount;
        document.getElementById('hiddenAmount').value = amount;
        document.getElementById('summaryAmount').textContent = amount.toLocaleString('vi-VN') + ' VNĐ';
        document.getElementById('summaryTotal').textContent = amount.toLocaleString('vi-VN') + ' VNĐ';

        if (amount >= 10000) {
            document.getElementById('submitBtn').innerHTML = '<i class="bi bi-wallet2"></i> Nạp ' + amount.toLocaleString('vi-VN') + ' VNĐ qua VNPAY';
            document.getElementById('submitBtn').disabled = false;
        } else {
            document.getElementById('submitBtn').innerHTML = '<i class="bi bi-exclamation-circle"></i> Vui lòng nhập số tiền (tối thiểu 10.000 VNĐ)';
            document.getElementById('submitBtn').disabled = true;
        }

        document.querySelectorAll('.quick-amount-btn').forEach(btn => {
            var btnText = btn.textContent.trim();
            var btnAmount = parseInt(btnText.replace(/\D/g, ''));
            if (btnAmount === amount) {
                btn.classList.add('selected');
            } else {
                btn.classList.remove('selected');
            }
        });
    }

    document.getElementById('customAmount').addEventListener('input', updateSummary);

    document.getElementById('topupForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        var amount = parseInt(document.getElementById('hiddenAmount').value);
        if (amount < 10000) {
            alert('Số tiền nạp tối thiểu là 10.000 VNĐ');
            return;
        }

        var btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang xử lý...';

        try {
            var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            var response = await fetch('/api/wallet/topup', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ amount: amount })
            });

            var data = await response.json();

            if (data.success && data.paymentUrl) {
                window.location.href = data.paymentUrl;
            } else {
                alert(data.error || 'Có lỗi xảy ra. Vui lòng thử lại.');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-wallet2"></i> Nạp ' + amount.toLocaleString('vi-VN') + ' VNĐ qua VNPAY';
            }
        } catch (error) {
            alert('Có lỗi xảy ra. Vui lòng thử lại.');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-wallet2"></i> Nạp ' + amount.toLocaleString('vi-VN') + ' VNĐ qua VNPAY';
        }
    });

    updateSummary();
</script>
}
