@page
@model OnlineLearningPlatform.RazorPages.Areas.Teacher.Pages.Courses.IndexModel
@using OnlineLearningPlatform.Models.Entities
@{
    ViewData["Title"] = Model.IsMyCoursesView ? "Khóa học của tôi" : "Tất cả khóa học";
}

<div class="ud-page">
    <div class="ud-page-head ud-fade-up">
        <h1 class="ud-fw-800">@(Model.IsMyCoursesView ? "Khóa học của tôi" : "Tất cả khóa học")</h1>
        <p class="ud-text-muted" style="font-size: 14px; margin-top: 4px;">
            @(Model.IsMyCoursesView
                ? "Quản lý, chỉnh sửa và theo dõi tất cả khóa học bạn đã tạo."
                : "Xem tất cả khóa học đã xuất bản trên hệ thống. Dùng bộ lọc \"Khóa học của tôi\" để chỉ xem khó do bạn tạo.")
        </p>
    </div>

    @if (TempData["SuccessMessage"] is string ok)
    {
        <div class="alert ud-fade-up" style="background: rgba(16, 185, 129, 0.1); border: 1px solid var(--ud-green); color: #059669; padding: 12px 16px; border-radius: var(--ud-radius); display: flex; align-items: center; gap: 8px; margin-bottom: 24px;">
            <i class="bi bi-check-circle"></i>
            @ok
        </div>
    }
    @if (TempData["ErrorMessage"] is string err)
    {
        <div class="alert ud-fade-up" style="background: rgba(239, 68, 68, 0.1); border: 1px solid #ef4444; color: #dc2626; padding: 12px 16px; border-radius: var(--ud-radius); display: flex; align-items: center; gap: 8px; margin-bottom: 24px;">
            <i class="bi bi-exclamation-circle"></i>
            @err
        </div>
    }

    @{
        var total = Model.Courses.Count;
        var published = Model.Courses.Count(c => c.Status == CourseStatus.Published);
        var pending = Model.Courses.Count(c => c.Status == CourseStatus.Pending);
        var rejected = Model.Courses.Count(c => c.Status == CourseStatus.Rejected);
    }

    @if (Model.Courses.Any())
    {
        <div class="ud-fade-up" style="display: flex; gap: var(--ud-sp4); margin-bottom: var(--ud-sp5); flex-wrap: wrap;">
            <div class="ud-card" style="padding: var(--ud-sp3) var(--ud-sp4); display: flex; align-items: center; gap: var(--ud-sp2);">
                <i class="bi bi-collection-play" style="font-size: 16px; color: var(--ud-purple);"></i>
                <span style="font-weight: 700; color: var(--ud-text);">@total</span>
                <span class="ud-text-muted">tổng</span>
            </div>
            <div class="ud-card" style="padding: var(--ud-sp3) var(--ud-sp4); display: flex; align-items: center; gap: var(--ud-sp2);">
                <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--ud-green); animation: pulse 2s infinite;"></span>
                <span style="font-weight: 700; color: var(--ud-text);">@published</span>
                <span class="ud-text-muted">đã xuất bản</span>
            </div>
            <div class="ud-card" style="padding: var(--ud-sp3) var(--ud-sp4); display: flex; align-items: center; gap: var(--ud-sp2);">
                <span style="width: 8px; height: 8px; border-radius: 50%; background: #f59e0b; animation: pulse 2s infinite;"></span>
                <span style="font-weight: 700; color: var(--ud-text);">@pending</span>
                <span class="ud-text-muted">chờ duyệt</span>
            </div>
            @if (rejected > 0)
            {
                <div class="ud-card" style="padding: var(--ud-sp3) var(--ud-sp4); display: flex; align-items: center; gap: var(--ud-sp2);">
                    <span style="width: 8px; height: 8px; border-radius: 50%; background: #ef4444;"></span>
                    <span style="font-weight: 700; color: var(--ud-text);">@rejected</span>
                    <span class="ud-text-muted">từ chối</span>
                </div>
            }
        </div>
    }

    <div class="ud-fade-up teacher-courses-actions">
        <form method="get" class="teacher-course-toolbar">
            <div class="ud-search-wrap">
                <i class="bi bi-search" style="color: var(--ud-text-muted); font-size: 1rem; flex-shrink: 0;"></i>
                <input type="text" name="SearchTitle" value="@Model.SearchTitle" placeholder="Tìm kiếm theo tiêu đề..." autocomplete="off" />
            </div>
            <button type="submit" class="btn btn-primary btn-sm btn-search-submit">Tìm</button>
            @if (!string.IsNullOrEmpty(Model.SearchTitle))
            {
                <a asp-page="/Courses/Index" asp-area="Teacher" asp-route-ViewMode="@Model.ViewMode" class="btn btn-sm btn-outline" style="border-radius:10px;min-height:44px;display:inline-flex;align-items:center;">✕ Xóa</a>
            }
        </form>

        <div class="teacher-course-filter-group">
            <a asp-area="Teacher" asp-page="/Courses/Index"
               asp-route-ViewMode="all"
               asp-route-SearchTitle="@Model.SearchTitle"
               class="btn btn-sm @(Model.IsMyCoursesView ? "btn-outline" : "btn-primary")" style="text-decoration: none;">
                Tất cả khóa học
            </a>
            <a asp-area="Teacher" asp-page="/Courses/Index"
               asp-route-ViewMode="mine"
               asp-route-SearchTitle="@Model.SearchTitle"
               class="btn btn-sm @(Model.IsMyCoursesView ? "btn-primary" : "btn-outline")" style="text-decoration: none;">
                Khóa học của tôi
            </a>
        </div>

        <a asp-area="Teacher" asp-page="/Courses/Create" class="btn btn-primary teacher-course-create-btn" style="text-decoration: none;">
            <i class="bi bi-plus-lg"></i>
            Tạo khóa học mới
        </a>
    </div>

    <div class="ud-grid ud-fade-up" style="grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: var(--ud-sp5);">
        @if (!Model.Courses.Any())
        {
            <div style="grid-column: 1 / -1; padding: 64px 32px; text-align: center;">
                <i class="bi bi-collection-play" style="font-size: 48px; color: var(--ud-text-muted); margin-bottom: 16px; display: block;"></i>
                @if (!string.IsNullOrEmpty(Model.SearchTitle))
                {
                    <h3 class="ud-fw-800" style="font-size: 18px; margin-bottom: 8px;">Không tìm thấy kết quả</h3>
                    <p class="ud-text-muted" style="font-size: 14px; margin-bottom: 24px;">Không có khóa học nào khớp với "<strong>@Model.SearchTitle</strong>". Thử từ khóa khác.</p>
                    <a asp-page="/Courses/Index" asp-area="Teacher" class="btn btn-outline" style="text-decoration: none;">Xem tất cả</a>
                }
                else
                {
                    <h3 class="ud-fw-800" style="font-size: 18px; margin-bottom: 8px;">Chưa có khóa học nào</h3>
                    <p class="ud-text-muted" style="font-size: 14px; margin-bottom: 24px;">Hãy tạo khóa học đầu tiên để bắt đầu chia sẻ kiến thức với học viên của bạn.</p>
                    <a asp-area="Teacher" asp-page="/Courses/Create" class="btn btn-primary" style="text-decoration: none;">
                        <i class="bi bi-plus-lg"></i>
                        Tạo khóa học đầu tiên
                    </a>
                }
            </div>
        }
        else
        {
            @foreach (var course in Model.Courses)
            {
                var isOwner = course.TeacherId == Model.TeacherId;
                var ribbonClass = course.Status switch {
                    CourseStatus.Published => "badge-green",
                    CourseStatus.Rejected  => "badge-muted",
                    _                      => "badge-purple"
                };
                var ribbonLabel = course.Status switch {
                    CourseStatus.Published => "✓ Xuất bản",
                    CourseStatus.Rejected  => "✕ Từ chối",
                    _                      => "⏳ Chờ duyệt"
                };
                var emoji = course.Level switch {
                    CourseLevel.Advanced     => "🚀",
                    CourseLevel.Intermediate => "📖",
                    _                        => "🌱"
                };

                <div class="ud-card" id="card-@course.CourseId" style="overflow: hidden; display: flex; flex-direction: column; transition: transform 0.2s, box-shadow 0.2s;">
                    <div style="position: relative; aspect-ratio: 16/9; background: linear-gradient(135deg, #e8f0fb 0%, #f0eeff 100%); overflow: hidden;">
                        @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                        {
                            <img src="@course.ThumbnailUrl" alt="@course.Title" loading="lazy" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s;" />
                        }
                        else
                        {
                            <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 48px;">
                                @emoji
                            </div>
                        }
                        <span class="badge @ribbonClass course-status-badge" data-cid="@course.CourseId" style="position: absolute; top: 12px; left: 12px; backdrop-filter: blur(8px);">
                            @ribbonLabel
                        </span>
                        <div style="position: absolute; inset: 0; background: rgba(0,0,0,.5); display: flex; align-items: center; justify-content: center; gap: 8px; opacity: 0; transition: opacity 0.2s;" class="card-overlay">
                            <a asp-area="Teacher" asp-page="/Courses/Preview" asp-route-courseId="@course.CourseId" style="background: #fff; color: var(--ud-purple) !important; padding: 8px 16px; border-radius: var(--ud-radius-pill); font-size: 12px; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; transition: transform 0.15s;">
                                <i class="bi bi-play-circle"></i>
                                Xem trước
                            </a>
                            @if (isOwner)
                            {
                                <a asp-area="Teacher" asp-page="/Courses/Edit" asp-route-id="@course.CourseId" style="background: rgba(255,255,255,.2); color: #fff !important; border: 1px solid rgba(255,255,255,.4); padding: 8px 16px; border-radius: var(--ud-radius-pill); font-size: 12px; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; transition: transform 0.15s;">
                                    <i class="bi bi-pencil"></i>
                                    Sửa
                                </a>
                            }
                        </div>
                    </div>

                    <div style="padding: 20px; flex: 1; display: flex; flex-direction: column;">
                        <div style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--ud-purple); margin-bottom: 8px;">@course.CourseCode</div>
                        <div style="font-size: 15px; font-weight: 600; color: var(--ud-text); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 12px;" title="@course.Title">@course.Title</div>
                        <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-top: auto; padding-top: 16px; border-top: 1px solid var(--ud-border);">
                            <span style="display: flex; align-items: center; gap: 4px; font-size: 12px; color: var(--ud-text-muted);">
                                <i class="bi bi-bar-chart"></i>
                                @course.Level
                            </span>
                            <span style="display: flex; align-items: center; gap: 4px; font-size: 12px; color: var(--ud-text-muted);">
                                <i class="bi bi-globe"></i>
                                @course.Language.ToUpper()
                            </span>
                            @{
                                bool cHasDisc = course.DiscountPrice.HasValue && course.DiscountPrice > 0 && course.DiscountPrice < course.Price;
                                decimal cDisplayPrice = cHasDisc ? course.DiscountPrice!.Value : course.Price;
                            }
                            <span style="font-size: 14px; font-weight: 700; color: var(--ud-text); margin-left: auto;">
                                @if (course.Price == 0)
                                {
                                    <span style="color: var(--ud-green);">Miễn phí</span>
                                }
                                else if (cHasDisc)
                                {
                                    <span>@cDisplayPrice.ToString("N0") ₫</span>
                                    <span style="font-size: 11px; font-weight: 400; text-decoration: line-through; color: var(--ud-text-muted); margin-left: 4px;">@course.Price.ToString("N0") ₫</span>
                                }
                                else
                                {
                                    <span>@cDisplayPrice.ToString("N0") ₫</span>
                                }
                            </span>
                        </div>
                    </div>

                    <div class="teacher-course-card-actions">
                        <a asp-area="Teacher" asp-page="/Courses/Preview" asp-route-courseId="@course.CourseId" class="btn btn-sm btn-outline" style="flex: 1; justify-content: center; text-decoration: none; border-radius: 10px;">
                            <i class="bi bi-play-circle"></i>
                            Xem trước
                        </a>
                        @if (isOwner)
                        {
                            <a asp-area="Teacher" asp-page="/Courses/Edit" asp-route-id="@course.CourseId" class="btn btn-sm" style="flex: 1; justify-content: center; text-decoration: none; border: 1px solid var(--ud-border); border-radius: 10px;">
                                <i class="bi bi-pencil"></i>
                                Chỉnh sửa
                            </a>
                            <a asp-area="Teacher" asp-page="/Courses/Delete" asp-route-id="@course.CourseId" class="btn btn-sm" style="flex: 1; justify-content: center; text-decoration: none; border: 1px solid var(--ud-border); color: #ef4444; border-radius: 10px;">
                                <i class="bi bi-trash"></i>
                                Xóa
                            </a>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    .teacher-course-card-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        padding: 14px 20px;
        border-top: 1px solid var(--ud-border);
        background: var(--ud-surface);
    }
    .ud-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--ud-shadow);
    }
    .ud-card:hover .card-overlay {
        opacity: 1 !important;
    }
    .ud-card:hover img {
        transform: scale(1.04);
    }
    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: .4; }
    }
</style>

@section Scripts {
<script src="~/lib/microsoft-signalr/signalr.min.js"></script>
<script>
(function () {
    const connection = new signalR.HubConnectionBuilder()
        .withUrl('/hubs/data')
        .withAutomaticReconnect()
        .build();

    const LABELS = { Published: '✓ Xuất bản', Pending: '⏳ Chờ duyệt', Rejected: '✕ Từ chối' };
    const CLASSES = { Published: 'badge-green', Pending: 'badge-purple', Rejected: 'badge-muted' };

    function escHtml(str) {
        return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function showToast(msg, type) {
        const toast = document.createElement('div');
        const bgColor = type === 'success' ? 'rgba(16, 185, 129, 0.1)' : type === 'danger' ? 'rgba(239, 68, 68, 0.1)' : type === 'warning' ? 'rgba(245, 158, 11, 0.1)' : 'rgba(139, 92, 246, 0.1)';
        const textColor = type === 'success' ? '#059669' : type === 'danger' ? '#dc2626' : type === 'warning' ? '#d97706' : '#7c3aed';
        const borderColor = type === 'success' ? 'var(--ud-green)' : type === 'danger' ? '#ef4444' : type === 'warning' ? '#f59e0b' : 'var(--ud-purple)';
        toast.style.cssText = 'position:fixed;bottom:20px;right:20px;z-index:9999;min-width:300px;padding:12px 16px;border-radius:var(--ud-radius);background:' + bgColor + ';color:' + textColor + ';border:1px solid ' + borderColor + ';animation:fadeUp .3s ease forwards;max-width:420px;';
        toast.textContent = msg;
        document.body.appendChild(toast);
        setTimeout(() => { toast.style.opacity='0'; toast.style.transition='opacity .3s ease'; setTimeout(()=>toast.remove(),300); }, 4000);
    }

    connection.on('CourseStatusChanged', function (data) {
        const badge = document.querySelector('[data-cid="' + data.courseId + '"]');
        if (!badge) return;
        const newClass = CLASSES[data.status] || 'badge-purple';
        badge.className = 'badge ' + newClass + ' course-status-badge';
        badge.textContent = LABELS[data.status] || data.status;
        badge.style.transition = 'none';
        badge.style.transform = 'scale(1.15)';
        setTimeout(() => { badge.style.transition = 'transform .25s ease'; badge.style.transform = 'scale(1)'; }, 50);

        const label = data.status === 'Published' ? 'đã được duyệt' : 'bị từ chối';
        showToast('Khóa học đã ' + label + '. Trang đã được cập nhật.', data.status === 'Published' ? 'success' : 'danger');
    });

    connection.on('CourseDeleted', function (data) {
        const card = document.getElementById('card-' + data.courseId);
        if (!card) return;
        card.style.transition = 'opacity .35s ease, transform .35s ease';
        card.style.opacity = '0';
        card.style.transform = 'scale(0.9)';
        setTimeout(() => card.remove(), 350);
        showToast('Một khóa học đã bị xóa.', 'warning');
    });

    connection.on('CourseUpdated', function (data) {
        const card = document.getElementById('card-' + data.courseId);
        if (!card) return;
        const titleEl = card.querySelector('div[title]');
        if (titleEl && data.title) titleEl.textContent = data.title;
        const priceEl = card.querySelector('span[style*="font-weight: 700"]');
        if (priceEl && data.price !== undefined) {
            const price = Number(data.price) || 0;
            const disc = (data.discountPrice != null) ? Number(data.discountPrice) : 0;
            const hasDisc = disc > 0 && disc < price;
            if (price === 0) {
                priceEl.innerHTML = '<span style="color: var(--ud-green);">Miễn phí</span>';
            } else if (hasDisc) {
                priceEl.innerHTML = '<span>' + disc.toLocaleString('vi-VN') + ' ₫</span>' +
                    '<span style="font-size: 11px; font-weight: 400; text-decoration: line-through; color: var(--ud-text-muted); margin-left: 4px">' +
                    price.toLocaleString('vi-VN') + ' ₫</span>';
            } else {
                priceEl.innerHTML = '<span>' + price.toLocaleString('vi-VN') + ' ₫</span>';
            }
        }
        card.style.outline = '2px solid var(--ud-purple)';
        setTimeout(() => { card.style.transition = 'outline .4s ease'; card.style.outline = '2px solid transparent'; }, 800);
    });

    connection.on('CourseCreated', function (data) {
        showToast('Khóa học mới "' + escHtml(data.title) + '" vừa được tạo. Tải lại để xem.', 'info');
        setTimeout(() => window.location.reload(), 1500);
    });

    connection.start().catch(err => console.warn('[SignalR DataHub] Teacher Courses connect error:', err));
})();
</script>
}
