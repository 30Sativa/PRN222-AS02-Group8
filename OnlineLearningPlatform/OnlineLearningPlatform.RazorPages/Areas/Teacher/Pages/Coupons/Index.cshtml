@page
@model OnlineLearningPlatform.RazorPages.Areas.Teacher.Pages.Coupons.IndexModel
@{
    ViewData["Title"] = "Mã khuyến mãi";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1 fw-bold">Mã khuyến mãi</h2>
            <p class="text-muted mb-0">Quản lý mã giảm giá cho khóa học của bạn.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" asp-area="Teacher" asp-page="/Dashboard">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
            <a class="btn btn-primary" asp-area="Teacher" asp-page="/Coupons/Create">
                <i class="bi bi-plus-circle me-1"></i> Tạo mã mới
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string msg)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @msg <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã</th>
                            <th>Mô tả</th>
                            <th>Khóa học</th>
                            <th>Giá trị</th>
                            <th>Hiệu lực</th>
                            <th>Đã dùng</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Coupons.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    Bạn chưa tạo mã khuyến mãi nào.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var c in Model.Coupons)
                            {
                                var isExpired = c.EndDate < DateTime.UtcNow;
                                var statusClass = !c.IsActive ? "bg-secondary" : isExpired ? "bg-danger" : "bg-success";
                                var statusText = !c.IsActive ? "Tắt" : isExpired ? "Hết hạn" : "Hoạt động";
                                var discountDisplay = c.DiscountType == CouponDiscountType.Percentage
                                    ? $"{c.DiscountValue}%" + (c.MaxDiscountAmount.HasValue ? $" (max {c.MaxDiscountAmount.Value:N0}đ)" : "")
                                    : $"{c.DiscountValue:N0} đ";
                                <tr>
                                    <td><code>@c.Code</code></td>
                                    <td>@(string.IsNullOrEmpty(c.Description) ? "—" : c.Description)</td>
                                    <td>
                                        @if (c.IsCourseSpecific && c.Course != null)
                                        {
                                            <span>@c.Course.Title</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Tất cả khóa</span>
                                        }
                                    </td>
                                    <td>@discountDisplay</td>
                                    <td>
                                        <small>
                                            @c.StartDate.ToString("dd/MM/yy") → @c.EndDate.ToString("dd/MM/yy")
                                        </small>
                                    </td>
                                    <td>
                                        @(c.UsageLimit.HasValue ? $"{c.UsedCount} / {c.UsageLimit}" : $"{c.UsedCount} (∞)")
                                    </td>
                                    <td class="text-end">
                                        @if (c.IsActive && !isExpired)
                                        {
                                            <form method="post" asp-page-handler="Deactivate" asp-route-couponId="@c.CouponId" class="d-inline"
                                                  onsubmit="return confirm('Vô hiệu hóa mã @c.Code?')">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-x-circle"></i> Tắt
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
