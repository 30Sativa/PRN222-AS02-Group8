@page
@model OnlineLearningPlatform.RazorPages.Areas.Teacher.Pages.Coupons.CreateModel
@{
    ViewData["Title"] = "Tạo mã khuyến mãi";
}

<div class="ud-page coupon-create-page">
    <div class="ud-page-head ud-fade-up">
        <div class="coupon-create-head">
            <div>
                <h1 class="ud-fw-800">Tạo mã khuyến mãi</h1>
                <p class="ud-text-muted" style="font-size: 14px; margin-top: 6px;">
                    Tạo mã giảm giá cho khóa học của bạn.
                </p>
            </div>
            <a class="btn btn-outline" asp-area="Teacher" asp-page="/Coupons/Index" style="border-radius: 10px; text-decoration: none; flex-shrink: 0;">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="ud-card ud-fade-up coupon-create-card">
        <form method="post" class="coupon-form">
            <div class="coupon-form-grid">
                <div class="form-group">
                    <label class="form-label" asp-for="Code">Mã coupon <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" asp-for="Code" placeholder="VD: PYTHON30" maxlength="50" />
                    <small class="ud-text-muted" style="font-size: 0.78rem; display: block; margin-top: 6px;">Mã sẽ được tự động viết hoa.</small>
                    <span class="form-error" asp-validation-for="Code"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Description">Mô tả</label>
                    <input type="text" class="form-control" asp-for="Description" placeholder="VD: Giảm 30% cho khóa Python" maxlength="255" />
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="DiscountType">Loại giảm giá <span class="text-danger">*</span></label>
                    <select class="form-select" asp-for="DiscountType" id="discountTypeSelect">
                        <option value="Percentage">Phần trăm (%)</option>
                        <option value="FixedAmount">Số tiền cố định (VNĐ)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="DiscountValue">Giá trị giảm <span class="text-danger">*</span></label>
                    <input type="number" class="form-control" asp-for="DiscountValue" min="1" step="any" />
                    <small class="ud-text-muted" style="font-size: 0.78rem; display: block; margin-top: 6px;" id="discountValueHint"></small>
                </div>

                <div class="form-group coupon-span-2" id="percentageCapBlock">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" asp-for="LimitMaxDiscount" id="limitMaxDiscountCb" />
                        <label class="form-check-label" for="limitMaxDiscountCb" style="font-weight: 600;">Giới hạn mức giảm tối đa</label>
                    </div>
                    <div id="maxDiscountAmountWrapper">
                        <label class="form-label" asp-for="MaxDiscountAmount">Mức trần (VNĐ) <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" asp-for="MaxDiscountAmount" min="1" step="1" placeholder="VD: 50000" />
                        <span class="form-error" asp-validation-for="MaxDiscountAmount"></span>
                    </div>
                    <small class="ud-text-muted" style="font-size: 0.78rem;">Tuỳ chọn khi giảm %: ví dụ 50% nhưng tối đa 50.000đ.</small>
                </div>

                <div class="form-group coupon-span-2">
                    <label class="form-label" asp-for="CourseId">Áp dụng cho khóa học <span class="text-danger">*</span></label>
                    <select class="form-select" asp-for="CourseId">
                        <option value="">— Chọn khóa học —</option>
                        @foreach (var course in Model.MyCourses)
                        {
                            <option value="@course.CourseId">@course.Title</option>
                        }
                    </select>
                    <small class="ud-text-muted" style="font-size: 0.78rem; display: block; margin-top: 6px;">Chỉ áp dụng cho khóa học được chọn.</small>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="StartDate">Ngày bắt đầu <span class="text-danger">*</span></label>
                    <input type="datetime-local" class="form-control" asp-for="StartDate" step="60" />
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="EndDate">Ngày kết thúc <span class="text-danger">*</span></label>
                    <input type="datetime-local" class="form-control" asp-for="EndDate" step="60" />
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="UsageLimit">Giới hạn sử dụng</label>
                    <input type="number" class="form-control" asp-for="UsageLimit" min="1" placeholder="Để trống = không giới hạn" />
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="MaxUsagePerUser">Mỗi user dùng tối đa</label>
                    <input type="number" class="form-control" asp-for="MaxUsagePerUser" min="1" value="1" />
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="MinOrderAmount">Đơn hàng tối thiểu (VNĐ)</label>
                    <input type="number" class="form-control" asp-for="MinOrderAmount" min="0" placeholder="VD: 100000" />
                </div>
            </div>

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div class="alert alert-danger" style="margin-top: var(--ud-sp5); border-radius: 12px; flex-direction: column; align-items: stretch;">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <div class="coupon-form-actions">
                <button type="submit" class="btn btn-primary px-4" style="border-radius: 999px;">
                    <i class="bi bi-check-circle me-1"></i> Tạo mã
                </button>
                <a class="btn btn-outline" asp-area="Teacher" asp-page="/Coupons/Index" style="border-radius: 999px; text-decoration: none;">Hủy</a>
            </div>
        </form>
    </div>
</div>

<style>
    .coupon-create-head {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem 1.5rem;
    }
    .coupon-create-card {
        max-width: 760px;
        margin: 0 auto;
        padding: var(--ud-sp6) var(--ud-sp8);
        border-radius: var(--ud-radius-lg);
    }
    .coupon-form .form-label {
        text-transform: none;
        letter-spacing: 0;
        font-weight: 600;
        font-size: 0.88rem;
        color: var(--ud-text);
    }
    .coupon-form .form-control,
    .coupon-form .form-select {
        border-radius: 10px;
    }
    .coupon-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.15rem 1.35rem;
    }
    .coupon-span-2 { grid-column: 1 / -1; }
    .coupon-form-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: var(--ud-sp6);
        padding-top: var(--ud-sp5);
        border-top: 1px solid var(--ud-border);
    }
    @@media (max-width: 640px) {
        .coupon-form-grid { grid-template-columns: 1fr; }
        .coupon-span-2 { grid-column: 1; }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var typeSel = document.getElementById('discountTypeSelect');
            var pctBlock = document.getElementById('percentageCapBlock');
            var limitCb = document.getElementById('limitMaxDiscountCb');
            var maxWrap = document.getElementById('maxDiscountAmountWrapper');
            var hint = document.getElementById('discountValueHint');
            function syncDiscountType() {
                if (!typeSel || !pctBlock) return;
                var isPct = typeSel.value === 'Percentage';
                pctBlock.style.display = isPct ? '' : 'none';
                if (!isPct && limitCb) limitCb.checked = false;
                if (hint) hint.textContent = isPct ? 'Nhập phần trăm (vd: 10 = 10%).' : 'Số tiền giảm (VNĐ).';
                syncMaxCap();
            }
            function syncMaxCap() {
                if (!maxWrap || !limitCb || !typeSel) return;
                var show = typeSel.value === 'Percentage' && limitCb.checked;
                maxWrap.style.display = show ? '' : 'none';
            }
            if (typeSel) typeSel.addEventListener('change', syncDiscountType);
            if (limitCb) limitCb.addEventListener('change', syncMaxCap);
            syncDiscountType();
        })();
    </script>
}
