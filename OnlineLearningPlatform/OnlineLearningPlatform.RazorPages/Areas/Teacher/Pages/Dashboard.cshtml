@page
@model OnlineLearningPlatform.RazorPages.Areas.Teacher.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="ud-page">
    <div class="ud-page-head ud-fade-up">
        <h1 class="ud-fw-800">Dashboard</h1>
        <div class="ud-text-muted" style="font-size: 14px;">
            <span>Giảng viên</span>
            <span> › </span>
            <span>Tổng quan</span>
        </div>
    </div>

    <div class="ud-fade-up" style="background: linear-gradient(135deg, var(--ud-purple) 0%, var(--ud-magenta) 100%); border-radius: var(--ud-radius); padding: 32px 40px; display: flex; align-items: center; justify-content: space-between; gap: 24px; margin-bottom: 32px; overflow: hidden; position: relative;">
        <div style="position: absolute; top: -40px; right: -40px; width: 200px; height: 200px; border-radius: 50%; background: rgba(255,255,255,.08);"></div>
        <div style="position: absolute; bottom: -60px; right: 80px; width: 150px; height: 150px; border-radius: 50%; background: rgba(255,255,255,.05);"></div>
        <div style="position: relative; z-index: 1;">
            <h2 style="font-size: 24px; font-weight: 700; color: #fff; letter-spacing: -.03em; margin-bottom: 8px;">Xin chào, @(Model.UserInfo?.FullName ?? "Giảng viên")</h2>
            <p style="font-size: 14px; color: rgba(255,255,255,.80);">Quản lý khóa học, bài giảng và theo dõi học viên của bạn tại đây.</p>
        </div>
        <div style="position: relative; z-index: 1; display: flex; gap: 12px; flex-shrink: 0;">
            <a asp-area="Teacher" asp-page="/Courses/Create" style="background: #fff; color: var(--ud-purple) !important; font-size: 14px; font-weight: 600; border-radius: var(--ud-radius-pill); padding: 9px 20px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: opacity 0.2s; border: none;">
                <i class="bi bi-plus-lg"></i>
                Tạo khóa học mới
            </a>
            <a asp-area="Teacher" asp-page="/Courses/Index" style="background: rgba(255,255,255,.18); color: #fff !important; border: 1px solid rgba(255,255,255,.30); backdrop-filter: blur(8px); font-size: 14px; font-weight: 500; border-radius: var(--ud-radius-pill); padding: 9px 20px; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: background 0.2s;">
                <i class="bi bi-collection-play"></i>
                Xem tất cả khóa học
            </a>
        </div>
    </div>

    <div style="margin-bottom: 24px;">
        <h3 class="ud-fw-800 ud-fade-up" style="font-size: 12px; text-transform: uppercase; letter-spacing: .07em; color: var(--ud-text-muted); margin-bottom: 12px;">Tổng quan giảng dạy</h3>
    </div>

    <div class="ud-grid ud-fade-up" style="grid-template-columns: repeat(4, 1fr); gap: var(--ud-sp5); margin-bottom: 40px;">
        <div class="ud-card" style="padding: 24px;">
            <div style="width: 44px; height: 44px; border-radius: var(--ud-radius); background: rgba(0, 113, 227, 0.1); display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                <i class="bi bi-mortarboard" style="font-size: 20px; color: #0071e3;"></i>
            </div>
            <div style="font-size: 12px; color: var(--ud-text-muted); margin-bottom: 4px;">Khóa học của tôi</div>
            <div style="font-size: 32px; font-weight: 700; color: var(--ud-text); margin-bottom: 4px;">@Model.TotalCourses</div>
            <div style="font-size: 11px; color: var(--ud-text-muted);">@Model.PublishedCourses đã xuất bản</div>
        </div>

        <div class="ud-card" style="padding: 24px;">
            <div style="width: 44px; height: 44px; border-radius: var(--ud-radius); background: rgba(16, 185, 129, 0.1); display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                <i class="bi bi-people" style="font-size: 20px; color: #10b981;"></i>
            </div>
            <div style="font-size: 12px; color: var(--ud-text-muted); margin-bottom: 4px;">Tổng học viên</div>
            <div style="font-size: 32px; font-weight: 700; color: var(--ud-text); margin-bottom: 4px;">@Model.TotalStudents</div>
            <div style="font-size: 11px; color: var(--ud-text-muted);">Trên tất cả các khóa học</div>
        </div>

        <div class="ud-card" style="padding: 24px;">
            <div style="width: 44px; height: 44px; border-radius: var(--ud-radius); background: rgba(245, 158, 11, 0.1); display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                <i class="bi bi-hourglass-split" style="font-size: 20px; color: #f59e0b;"></i>
            </div>
            <div style="font-size: 12px; color: var(--ud-text-muted); margin-bottom: 4px;">Chờ duyệt</div>
            <div style="font-size: 32px; font-weight: 700; color: var(--ud-text); margin-bottom: 4px;">@Model.PendingCourses</div>
            <div style="font-size: 11px; color: var(--ud-text-muted);">Khóa học đang chờ admin</div>
        </div>

        <div class="ud-card" style="padding: 24px;">
            <div style="width: 44px; height: 44px; border-radius: var(--ud-radius); background: rgba(139, 92, 246, 0.1); display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                <i class="bi bi-book" style="font-size: 20px; color: #8b5cf6;"></i>
            </div>
            <div style="font-size: 12px; color: var(--ud-text-muted); margin-bottom: 4px;">Tổng bài học</div>
            <div style="font-size: 32px; font-weight: 700; color: var(--ud-text); margin-bottom: 4px;">@Model.TotalLessons</div>
            <div style="font-size: 11px; color: var(--ud-text-muted);">Trên tất cả các khóa học</div>
        </div>
    </div>

    <div class="ud-grid" style="grid-template-columns: 1fr 1fr; gap: var(--ud-sp5);">

        <div class="ud-card ud-fade-up">
            <div style="display: flex; align-items: center; justify-content: space-between; padding: 20px 24px; border-bottom: 1px solid var(--ud-border);">
                <h2 style="font-size: 16px; font-weight: 700; display: flex; align-items: center; gap: 8px; margin: 0;">
                    <i class="bi bi-collection-play" style="color: #0071e3;"></i>
                    Khóa học của tôi
                </h2>
                <a asp-area="Teacher" asp-page="/Courses/Index" class="btn btn-sm" style="text-decoration: none;">Xem tất cả</a>
            </div>
            <div style="padding: 0 24px 16px;">
                @if (!Model.RecentCourses.Any())
                {
                    <div style="text-align: center; padding: 40px 24px; color: var(--ud-text-muted);">
                        <i class="bi bi-collection-play" style="font-size: 28px; margin-bottom: 12px; display: block;"></i>
                        <p style="font-size: 14px; margin-bottom: 8px;">Bạn chưa có khóa học nào.</p>
                        <a asp-area="Teacher" asp-page="/Courses/Create" style="color: var(--ud-purple); font-weight: 500;">Tạo khóa học đầu tiên →</a>
                    </div>
                }
                else
                {
                    <ul style="list-style: none; padding: 0; margin: 0;">
                        @foreach (var course in Model.RecentCourses)
                        {
                            string statusClass = course.Status switch {
                                "Published" => "badge-green",
                                "Pending"   => "badge-purple",
                                "Rejected"  => "badge-muted",
                                _           => "badge-muted"
                            };
                            string statusLabel = course.Status switch {
                                "Published" => "Đã xuất bản",
                                "Pending"   => "Chờ duyệt",
                                "Rejected"  => "Bị từ chối",
                                _           => "Nháp"
                            };
                            <li style="display: flex; align-items: center; gap: 12px; padding: 12px 0; border-bottom: 1px solid var(--ud-border);">
                                <div style="width: 40px; height: 40px; border-radius: var(--ud-radius); background: var(--ud-surface); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                    <i class="bi bi-play-circle" style="color: var(--ud-text-muted);"></i>
                                </div>
                                <div style="flex: 1; min-width: 0;">
                                    <div style="font-size: 14px; font-weight: 500; color: var(--ud-text); overflow: hidden; white-space: nowrap; text-overflow: ellipsis;" title="@course.Title">@course.Title</div>
                                    <div style="font-size: 11px; color: var(--ud-text-muted); margin-top: 4px; display: flex; align-items: center; gap: 8px;">
                                        <span class="badge @statusClass">@statusLabel</span>
                                        <span>@course.EnrollmentCount HV</span>
                                    </div>
                                </div>
                                <a asp-area="Teacher" asp-page="/Courses/Details" asp-route-id="@course.CourseId" class="btn btn-sm" style="flex-shrink: 0; text-decoration: none;">
                                    Chi tiết
                                </a>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        <div class="ud-card ud-fade-up">
            <div style="display: flex; align-items: center; justify-content: space-between; padding: 20px 24px; border-bottom: 1px solid var(--ud-border);">
                <h2 style="font-size: 16px; font-weight: 700; margin: 0;">Truy cập nhanh</h2>
            </div>
            <div style="padding: 16px 24px;">
                <div class="ud-grid" style="grid-template-columns: 1fr 1fr; gap: var(--ud-sp3);">

                    <a asp-area="Teacher" asp-page="/Courses/Index" class="ud-card" style="padding: 20px; text-decoration: none; display: flex; flex-direction: column; gap: 8px; transition: transform 0.2s, box-shadow 0.2s;">
                        <div style="width: 40px; height: 40px; border-radius: var(--ud-radius); background: rgba(0, 113, 227, 0.1); display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-collection-play" style="font-size: 18px; color: #0071e3;"></i>
                        </div>
                        <div style="font-size: 14px; font-weight: 600; color: var(--ud-text);">Khóa học của tôi</div>
                        <div style="font-size: 12px; color: var(--ud-text-muted);">Quản lý và chỉnh sửa nội dung</div>
                    </a>

                    <a asp-area="Teacher" asp-page="/Courses/Create" class="ud-card" style="padding: 20px; text-decoration: none; display: flex; flex-direction: column; gap: 8px; transition: transform 0.2s, box-shadow 0.2s;">
                        <div style="width: 40px; height: 40px; border-radius: var(--ud-radius); background: rgba(16, 185, 129, 0.1); display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-plus-circle" style="font-size: 18px; color: #10b981;"></i>
                        </div>
                        <div style="font-size: 14px; font-weight: 600; color: var(--ud-text);">Tạo khóa học</div>
                        <div style="font-size: 12px; color: var(--ud-text-muted);">Thiết kế và xuất bản khóa học mới</div>
                    </a>

                    <a asp-area="Teacher" asp-page="/Profile" class="ud-card" style="padding: 20px; text-decoration: none; display: flex; flex-direction: column; gap: 8px; transition: transform 0.2s, box-shadow 0.2s;">
                        <div style="width: 40px; height: 40px; border-radius: var(--ud-radius); background: rgba(139, 92, 246, 0.1); display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-person" style="font-size: 18px; color: #8b5cf6;"></i>
                        </div>
                        <div style="font-size: 14px; font-weight: 600; color: var(--ud-text);">Hồ sơ giảng viên</div>
                        <div style="font-size: 12px; color: var(--ud-text-muted);">Xem và cập nhật thông tin của bạn</div>
                    </a>

                    <a asp-area="Teacher" asp-page="/EditProfile" class="ud-card" style="padding: 20px; text-decoration: none; display: flex; flex-direction: column; gap: 8px; transition: transform 0.2s, box-shadow 0.2s;">
                        <div style="width: 40px; height: 40px; border-radius: var(--ud-radius); background: rgba(245, 158, 11, 0.1); display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-pencil-square" style="font-size: 18px; color: #f59e0b;"></i>
                        </div>
                        <div style="font-size: 14px; font-weight: 600; color: var(--ud-text);">Chỉnh sửa hồ sơ</div>
                        <div style="font-size: 12px; color: var(--ud-text-muted);">Cập nhật ảnh đại diện, bio...</div>
                    </a>

                    <a asp-area="Teacher" asp-page="/Categories/Index" class="ud-card" style="padding: 20px; text-decoration: none; display: flex; flex-direction: column; gap: 8px; transition: transform 0.2s, box-shadow 0.2s;">
                        <div style="width: 40px; height: 40px; border-radius: var(--ud-radius); background: rgba(236, 72, 153, 0.1); display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-tags" style="font-size: 18px; color: #ec4899;"></i>
                        </div>
                        <div style="font-size: 14px; font-weight: 600; color: var(--ud-text);">Danh mục</div>
                        <div style="font-size: 12px; color: var(--ud-text-muted);">Quản lý loại & danh mục khóa học</div>
                    </a>

                </div>
            </div>
        </div>

    </div>
</div>
