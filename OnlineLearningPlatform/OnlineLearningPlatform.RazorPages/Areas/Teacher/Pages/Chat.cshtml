@page
@model OnlineLearningPlatform.RazorPages.Areas.Teacher.Pages.ChatModel
@{
    ViewData["Title"] = "Tin nhắn";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<style>
    .chat-wrapper { display:flex; height:calc(100vh - 140px); margin:-24px -32px; background:var(--color-bg); overflow:hidden; }
    .chat-sidebar { width:300px; min-width:260px; background:var(--color-surface); border-right:1px solid var(--color-border-light); display:flex; flex-direction:column; overflow:hidden; }
    .chat-sidebar-header { padding:20px 16px 14px; border-bottom:1px solid var(--color-border-light); font-size:15px; font-weight:700; color:var(--color-label-1); }
    .chat-conv-list { flex:1; overflow-y:auto; padding:8px 0; }
    .chat-conv-item { display:flex; align-items:center; gap:10px; padding:10px 16px; cursor:pointer; text-decoration:none; border-left:3px solid transparent; transition:background 0.15s; }
    .chat-conv-item:hover { background:var(--color-surface-2); }
    .chat-conv-item.active { background:var(--color-blue-tint); border-left-color:var(--color-blue); }
    .chat-conv-avatar { width:40px; height:40px; border-radius:50%; background:var(--color-green); color:#fff; display:flex; align-items:center; justify-content:center; font-size:16px; font-weight:700; flex-shrink:0; }
    .chat-conv-info { flex:1; overflow:hidden; }
    .chat-conv-name { font-size:14px; font-weight:600; color:var(--color-label-1); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .chat-conv-course { font-size:11px; color:var(--color-blue); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .chat-conv-last { font-size:12px; color:var(--color-label-3); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .chat-unread { background:var(--color-blue); color:#fff; border-radius:10px; font-size:11px; font-weight:700; padding:2px 7px; min-width:20px; text-align:center; flex-shrink:0; }
    .chat-main { flex:1; display:flex; flex-direction:column; background:var(--color-bg); overflow:hidden; }
    .chat-main-header { padding:16px 24px; border-bottom:1px solid var(--color-border-light); background:var(--color-surface); display:flex; align-items:center; gap:12px; }
    .chat-main-header-info h3 { font-size:15px; font-weight:700; color:var(--color-label-1); margin:0; }
    .chat-main-header-info p { font-size:12px; color:var(--color-label-2); margin:0; }
    .chat-messages { flex:1; overflow-y:auto; padding:24px; display:flex; flex-direction:column; gap:12px; }
    .chat-bubble-wrap { display:flex; align-items:flex-end; gap:8px; }
    .chat-bubble-wrap.mine { flex-direction:row-reverse; }
    .chat-bubble-avatar { width:32px; height:32px; border-radius:50%; background:var(--color-surface-2); color:var(--color-label-2); display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:700; flex-shrink:0; }
    .chat-bubble-avatar.mine { background:var(--color-green); color:#fff; }
    /* Fix: max-width on wrapper not bubble itself to avoid flex collapse */
    .chat-bubble-wrap > div:not(.chat-bubble-avatar) { max-width: calc(65% - 50px); min-width: 0; }
    .chat-bubble { max-width:100%; padding:10px 14px; border-radius:18px; font-size:14px; line-height:1.5; word-break:break-word; white-space:pre-wrap; }
    .chat-bubble.other { background:var(--color-surface); border:1px solid var(--color-border-light); border-bottom-left-radius:4px; color:var(--color-label-1); }
    .chat-bubble.mine { background:var(--color-green); color:#fff; border-bottom-right-radius:4px; }
    .chat-bubble-time { font-size:10px; color:var(--color-label-3); margin-top:3px; text-align:right; }
    .chat-input-bar { padding:12px 20px; border-top:1px solid var(--color-border-light); background:var(--color-surface); display:flex; gap:10px; align-items:flex-end; }
    .chat-input { flex:1; border:1.5px solid var(--color-border); border-radius:var(--radius-full); padding:10px 18px; font-size:14px; font-family:inherit; background:var(--color-bg); color:var(--color-label-1); resize:none; outline:none; line-height:1.4; max-height:120px; transition:border-color 0.2s; }
    .chat-input:focus { border-color:var(--color-green); }
    .chat-send-btn { width:42px; height:42px; border-radius:50%; background:var(--color-green); color:#fff; border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:background 0.2s, transform 0.15s; }
    .chat-send-btn:hover { opacity:.85; transform:scale(1.05); }
    .chat-send-btn:disabled { opacity:.5; cursor:default; transform:none; }
    .chat-empty { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; color:var(--color-label-2); gap:12px; text-align:center; padding:40px; }
    .chat-empty svg { color:var(--color-label-3); }
    .chat-empty h3 { font-size:18px; color:var(--color-label-1); margin:0; }
    .chat-empty p { font-size:14px; margin:0; }
    .chat-new-section { padding:12px 16px 4px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--color-label-3); }
</style>

<div class="chat-wrapper">
    <!-- ═══ SIDEBAR ═══ -->
    <aside class="chat-sidebar">
        <div class="chat-sidebar-header">📥 Tin nhắn từ học viên</div>
        <div class="chat-conv-list">
            @if (Model.Conversations.Any())
            {
                <div class="chat-new-section">@Model.Conversations.Count cuộc trò chuyện</div>
                @foreach (var conv in Model.Conversations)
                {
                    var isActive = Model.ActiveConversationId == conv.ConversationId;
                    <a class="chat-conv-item @(isActive ? "active" : "")"
                       href="/Teacher/Chat?conversationId=@conv.ConversationId">
                        <div class="chat-conv-avatar">@conv.OtherUserName[0]</div>
                        <div class="chat-conv-info">
                            <div class="chat-conv-name">@conv.OtherUserName</div>
                            <div class="chat-conv-course">@conv.CourseTitle</div>
                            @if (!string.IsNullOrEmpty(conv.LastMessage))
                            {
                                <div class="chat-conv-last">@conv.LastMessage</div>
                            }
                        </div>
                        @if (conv.UnreadCount > 0)
                        {
                            <span class="chat-unread">@conv.UnreadCount</span>
                        }
                    </a>
                }
            }
            else
            {
                <div style="padding:24px 16px;color:var(--color-label-2);font-size:13px;text-align:center">
                    Chưa có học viên nào nhắn tin cho bạn.
                </div>
            }
        </div>
    </aside>

    <!-- ═══ MAIN CHAT AREA ═══ -->
    <main class="chat-main">
        @if (Model.ActiveConversationId.HasValue)
        {
            <div class="chat-main-header">
                <div class="chat-conv-avatar">@(Model.ActiveOtherUserName?[0] ?? '?')</div>
                <div class="chat-main-header-info">
                    <h3>@Model.ActiveOtherUserName</h3>
                    <p>@Model.ActiveCourseTitle</p>
                </div>
            </div>

            <div class="chat-messages" id="chatMessages">
                @foreach (var msg in Model.Messages)
                {
                    var isMine = msg.SenderId == Model.CurrentUserId;
                    <div class="chat-bubble-wrap @(isMine ? "mine" : "")">
                        <div class="chat-bubble-avatar @(isMine ? "mine" : "")">@msg.SenderName[0]</div>
                        <div>
                            <div class="chat-bubble @(isMine ? "mine" : "other")">@msg.Content</div>
                            <div class="chat-bubble-time">@msg.SentAt.ToLocalTime().ToString("HH:mm")</div>
                        </div>
                    </div>
                }
            </div>

            <div class="chat-input-bar">
                <textarea id="chatInput" class="chat-input" rows="1"
                          placeholder="Trả lời học viên..." maxlength="2000"
                          onkeydown="handleKey(event)"></textarea>
                <button class="chat-send-btn" id="sendBtn" onclick="sendMessage()" title="Gửi">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="22" y1="2" x2="11" y2="13"/>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                    </svg>
                </button>
            </div>
        }
        else
        {
            <div class="chat-empty">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                <h3>Chọn cuộc trò chuyện</h3>
                <p>Chọn một cuộc trò chuyện bên trái để trả lời học viên của bạn.</p>
            </div>
        }
    </main>
</div>

@Html.AntiForgeryToken()

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
(function () {
    const conversationId = '@Model.ActiveConversationId';
    const currentUserId  = '@Model.CurrentUserId';
    if (!conversationId) return;

    function scrollBottom() {
        const box = document.getElementById('chatMessages');
        if (box) box.scrollTop = box.scrollHeight;
    }
    scrollBottom();

    const input = document.getElementById('chatInput');
    input?.addEventListener('input', function () {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 120) + 'px';
    });

    window.handleKey = function (e) {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
    };

    const conn = new signalR.HubConnectionBuilder()
        .withUrl('/hubs/chat')
        .withAutomaticReconnect()
        .build();

    conn.on('ReceiveMessage', function (data) {
        appendMessage(data);
        scrollBottom();
        if (data.senderId !== currentUserId)
            conn.invoke('MarkRead', conversationId).catch(() => {});
    });

    conn.start().then(() => {
        conn.invoke('JoinConversation', conversationId).catch(console.error);
    }).catch(console.error);

    window.addEventListener('beforeunload', () => {
        if (conn.state === signalR.HubConnectionState.Connected)
            conn.invoke('LeaveConversation', conversationId).catch(() => {});
    });

    function appendMessage(data) {
        const box = document.getElementById('chatMessages');
        if (!box) return;
        const isMine = data.senderId === currentUserId;
        const time = new Date(data.sentAt).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
        const wrap = document.createElement('div');
        wrap.className = 'chat-bubble-wrap' + (isMine ? ' mine' : '');
        wrap.innerHTML = `
            <div class="chat-bubble-avatar ${isMine ? 'mine' : ''}">${data.senderName[0]}</div>
            <div>
                <div class="chat-bubble ${isMine ? 'mine' : 'other'}">${escHtml(data.content)}</div>
                <div class="chat-bubble-time">${time}</div>
            </div>`;
        box.appendChild(wrap);
    }

    function escHtml(str) {
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    window.sendMessage = function () {
        const txt = input?.value?.trim();
        if (!txt) return;
        const btn = document.getElementById('sendBtn');
        btn.disabled = true;
        conn.invoke('SendMessage', conversationId, txt)
            .then(() => { input.value = ''; input.style.height = 'auto'; })
            .catch(console.error)
            .finally(() => { btn.disabled = false; input.focus(); });
    };
})();
</script>
}
